<%- include('../../components/header', { title: 'Players' }) %>

<main id="page-content" class="">
  <%- include('../../components/template') %>

  <section class="px-4 py-5">

    <header class="mb-5">
      <%- include('../../components/serverHeader') %>
    </header>

    <%- include('../../components/installHeader') %>

    <% if (errorMessage && errorMessage.message) { %>
    <div class="rounded-xl bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 px-4 py-3 mb-4 flex items-start gap-3">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-red-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
      </svg>
      <div>
        <p class="text-xs font-medium text-red-700 dark:text-red-400"><%= req.translations.connectionError || 'Error' %></p>
        <p class="text-xs text-red-600 dark:text-red-400/70 mt-0.5"><%= errorMessage.message %></p>
      </div>
    </div>
    <% } %>

    <%- include('../../components/serverTemplate', { features: features }) %>

    <%- include('../../components/toast') %>

    <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-4 mb-4">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-neutral-800 dark:text-white">Players</p>
          <p class="text-xs text-neutral-500 mt-0.5">
            <% if (typeof serverInfo !== 'undefined') { %>
              <%= serverInfo.onlinePlayers || 0 %> / <%= serverInfo.maxPlayers || 0 %> online
              <% if (serverInfo.version) { %> &middot; v<%= serverInfo.version %><% } %>
            <% } else { %>
              Manage your server's player list
            <% } %>
          </p>
        </div>
        <div class="text-xs text-neutral-500 flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
          <span><span id="refresh-countdown">30</span>s</span>
          <button onclick="window.location.reload()" class="text-blue-500 hover:text-blue-400 transition">now</button>
        </div>
      </div>
    </div>

    <% if (players && players.length > 0) { %>
    <div id="PlayersGrid" class="grid grid-cols-2 gap-3">
      <% players.forEach(function(player) { %>
      <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-3 flex items-center gap-3 cursor-pointer"
           data-uuid="<%= player.uuid %>"
           data-name="<%= player.name %>"
           onclick="openPlayerDetail('<%= player.uuid %>')">
        <img
          src="https://crafatar.com/avatars/<%= player.uuid %>?size=40&overlay"
          alt="<%= player.name %>"
          class="w-10 h-10 rounded-lg border border-neutral-200 dark:border-white/10 shrink-0"
        />
        <div class="min-w-0">
          <p class="text-sm font-medium text-neutral-800 dark:text-white truncate"><%= player.name %></p>
          <div class="flex items-center gap-1 mt-0.5">
            <span class="inline-flex h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
            <span class="text-[10px] text-neutral-500"><%= req.translations.online || 'Online' %></span>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
    <% } else { %>
    <div id="no-players-message" class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-8 text-center">
      <% if (!serverIsOnline && errorMessage && errorMessage.message) { %>
        <div class="w-12 h-12 rounded-full bg-neutral-100 dark:bg-neutral-700/50 flex items-center justify-center mx-auto mb-3">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-neutral-400">
            <path stroke-linecap="round" stroke-linejoin="round" d="m3 3 8.735 8.735m0 0a.374.374 0 1 1 .53.53m-.53-.53.53.53m0 0L21 21M14.652 9.348a3.75 3.75 0 0 1 0 5.304m2.121-7.425a6.75 6.75 0 0 1 0 9.546m2.121-11.667c3.808 3.807 3.808 9.98 0 13.788m-9.546-4.242a3.733 3.733 0 0 1-1.06-2.122m-1.061 4.243a6.75 6.75 0 0 1-1.625-6.929m-.496 9.05c-3.068-3.067-3.664-7.67-1.79-11.334M12 12h.008v.008H12V12Z" />
          </svg>
        </div>
        <p class="text-sm font-medium text-neutral-700 dark:text-neutral-300">Server offline</p>
        <p class="text-xs text-neutral-500 mt-1">Start your server to see online players.</p>
        <button onclick="window.location.reload()" class="mt-4 px-3 py-1.5 rounded-lg bg-neutral-200 dark:bg-neutral-700 text-neutral-700 dark:text-neutral-300 text-xs font-medium hover:bg-neutral-300 dark:hover:bg-neutral-600 transition">Refresh</button>
      <% } else if (serverIsOnline) { %>
        <div class="w-12 h-12 rounded-full bg-emerald-50 dark:bg-emerald-700/20 flex items-center justify-center mx-auto mb-3">
          <span class="inline-flex h-3 w-3 rounded-full bg-emerald-500"></span>
        </div>
        <p class="text-sm font-medium text-neutral-700 dark:text-neutral-300">No players online</p>
        <p class="text-xs text-neutral-500 mt-1">Players appear here when they join.</p>
        <% if (serverInfo) { %>
        <p class="text-xs text-neutral-400 mt-2">v<%= serverInfo.version %> &middot; <%= serverInfo.onlinePlayers %>/<%= serverInfo.maxPlayers %></p>
        <% } %>
      <% } else { %>
        <p class="text-sm font-medium text-neutral-700 dark:text-neutral-300">Status unknown</p>
        <p class="text-xs text-neutral-500 mt-1">The server may be starting up.</p>
      <% } %>
    </div>
    <% } %>

    <!-- Player detail modal (mobile bottom-sheet) -->
    <div id="playerModal" class="fixed inset-0 z-50 flex items-end justify-center opacity-0 pointer-events-none transition-opacity duration-200" aria-hidden="true">
      <div class="absolute inset-0 bg-black/60" id="playerModalBackdrop"></div>
      <div id="playerModalPanel" role="dialog" aria-modal="true" class="relative bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-700/60 rounded-t-2xl shadow-2xl w-full max-w-lg mx-4 transform translate-y-full transition-transform duration-300 max-h-[85vh] overflow-y-auto">
        <div class="p-4">
          <!-- Handle bar -->
          <div class="w-10 h-1 rounded-full bg-neutral-300 dark:bg-neutral-600 mx-auto mb-3"></div>

          <div class="flex flex-col items-center gap-3">
            <!-- Skin canvas -->
            <canvas id="skinCanvas" width="200" height="280" class="rounded-xl bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/60"></canvas>
            <img id="skinFallback" class="hidden rounded-xl border border-neutral-200 dark:border-neutral-700/60 w-20 h-20" />

            <!-- Player info -->
            <div class="text-center w-full">
              <div class="flex items-center justify-between">
                <div class="text-left">
                  <h3 id="playerModalName" class="text-base font-bold text-neutral-800 dark:text-white"></h3>
                  <p id="playerModalUuid" class="text-[10px] text-neutral-500 dark:text-neutral-400 font-mono mt-0.5"></p>
                  <p id="playerModalStatus" class="text-[10px] mt-1"></p>
                </div>
                <button onclick="closePlayerModal()" class="text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-300 transition">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
              </div>

              <div class="flex flex-wrap gap-2 mt-3">
                <button id="actionOp" class="flex-1 px-3 py-2 text-xs font-medium rounded-xl bg-amber-500/20 text-amber-700 dark:text-amber-400 hover:bg-amber-500/30 transition"><%= req.translations.playerMakeOp || 'Make OP' %></button>
                <button id="actionKill" class="flex-1 px-3 py-2 text-xs font-medium rounded-xl bg-orange-500/20 text-orange-700 dark:text-orange-400 hover:bg-orange-500/30 transition"><%= req.translations.playerKill || 'Kill' %></button>
              </div>
              <div class="flex flex-wrap gap-2 mt-2">
                <button id="actionBan" class="flex-1 px-3 py-2 text-xs font-medium rounded-xl bg-red-500/20 text-red-700 dark:text-red-400 hover:bg-red-500/30 transition"><%= req.translations.playerBan || 'Ban' %></button>
                <button id="actionIpBan" class="flex-1 px-3 py-2 text-xs font-medium rounded-xl bg-red-500/20 text-red-700 dark:text-red-400 hover:bg-red-500/30 transition"><%= req.translations.playerIpBan || 'IP Ban' %></button>
              </div>

              <!-- Typed confirm sub-dialog -->
              <div id="typedConfirm" class="hidden bg-neutral-50 dark:bg-neutral-800/50 rounded-xl p-3 border border-neutral-200 dark:border-neutral-700/60 mt-3">
                <p id="typedConfirmBody" class="text-xs text-neutral-700 dark:text-neutral-300 mb-2"></p>
                <input type="text" id="typedConfirmInput" placeholder="Type player name..." class="w-full px-3 py-2 text-xs rounded-lg border border-neutral-300 dark:border-neutral-600 bg-white dark:bg-neutral-800 text-neutral-800 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 mb-2" />
                <textarea id="typedConfirmReason" placeholder="<%= req.translations.playerReasonLabel || 'Reason (optional)' %>" rows="2" class="w-full px-3 py-2 text-xs rounded-lg border border-neutral-300 dark:border-neutral-600 bg-white dark:bg-neutral-800 text-neutral-800 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 mb-2"></textarea>
                <div class="flex gap-2 justify-end">
                  <button id="typedConfirmCancel" class="px-3 py-1.5 text-xs font-medium rounded-xl bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition"><%= req.translations.playerCancelLabel || 'Cancel' %></button>
                  <button id="typedConfirmSubmit" disabled class="px-3 py-1.5 text-xs font-medium rounded-xl bg-red-600 hover:bg-red-500 text-white transition"><%= req.translations.playerConfirmLabel || 'Confirm' %></button>
                </div>
              </div>

              <div id="playerActionResult" class="hidden text-xs mt-2"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/skinview3d@latest/dist/skinview3d.bundle.js"></script>

    <script nonce="<%- nonce %>">
      var PLAYERS = <%- JSON.stringify(players) %>;
      var CSRF_TOKEN = '<%= csrfToken %>';
      var SERVER_ID = '<%= server.UUID %>';
      var TRANSLATIONS = {
        online: '<%= req.translations.playerOnline || "Online" %>',
        offline: '<%= req.translations.playerOffline || "Offline" %>',
        confirmOp: '<%= req.translations.playerConfirmOp || "Make {player} a server operator?" %>',
        confirmKill: '<%= req.translations.playerKill || "Kill {player}? They will be kicked from the server." %>',
        confirmBanTitle: '<%= req.translations.playerConfirmBanTitle || "Ban Player" %>',
        confirmBanBody: '<%= req.translations.playerConfirmBanBody || "Type the player name to confirm the ban" %>',
        confirmIpBanTitle: '<%= req.translations.playerConfirmIpBanTitle || "IP Ban Player" %>',
        confirmIpBanBody: '<%= req.translations.playerConfirmIpBanBody || "Player is online. Type their name to confirm the IP ban" %>',
        actionSuccess: '<%= req.translations.playerActionSuccess || "Action sent to server" %>',
        actionError: '<%= req.translations.playerActionError || "Failed to execute action" %>',
        ipBanOffline: '<%= req.translations.playerIpBanDisabled || "Player must be online to IP ban" %>',
        skinError: '<%= req.translations.playerSkinError || "Could not load skin preview" %>',
      };
    </script>

    <script nonce="<%- nonce %>">
      var playerViewer = null;
      var currentPlayer = null;
      var pendingAction = null;

      function getPlayerByUuid(uuid) {
        for (var i = 0; i < PLAYERS.length; i++) {
          if (PLAYERS[i].uuid === uuid) return PLAYERS[i];
        }
        return null;
      }

      function openPlayerDetail(uuid) {
        currentPlayer = uuid;
        var player = getPlayerByUuid(uuid);
        if (!player) return;

        document.getElementById('playerModalName').textContent = player.name;
        document.getElementById('playerModalUuid').textContent = player.uuid;
        var statusEl = document.getElementById('playerModalStatus');
        statusEl.innerHTML = '<span class="inline-flex h-2 w-2 rounded-full bg-green-500 mr-1"></span> ' + TRANSLATIONS.online;

        var ipBanBtn = document.getElementById('actionIpBan');
        ipBanBtn.disabled = false;
        ipBanBtn.title = '';

        hideTypedConfirm();

        var overlay = document.getElementById('playerModal');
        var panel = document.getElementById('playerModalPanel');
        overlay.setAttribute('aria-hidden', 'false');
        overlay.classList.remove('opacity-0', 'pointer-events-none');
        panel.classList.remove('translate-y-full');
        panel.classList.add('translate-y-0');

        initSkinViewer(player.uuid);
      }

      function closePlayerModal() {
        var overlay = document.getElementById('playerModal');
        var panel = document.getElementById('playerModalPanel');
        overlay.setAttribute('aria-hidden', 'true');
        overlay.classList.add('opacity-0', 'pointer-events-none');
        panel.classList.remove('translate-y-0');
        panel.classList.add('translate-y-full');
        disposeSkinViewer();
        hideTypedConfirm();
        currentPlayer = null;
        pendingAction = null;
      }

      function initSkinViewer(uuid) {
        var canvas = document.getElementById('skinCanvas');
        var fallback = document.getElementById('skinFallback');
        canvas.classList.remove('hidden');
        fallback.classList.add('hidden');

        if (typeof skinview3d === 'undefined') {
          showSkinFallback(uuid);
          return;
        }

        try {
          playerViewer = new skinview3d.SkinViewer({
            canvas: canvas,
            width: 200,
            height: 280,
            skin: 'https://crafatar.com/skins/' + uuid,
          });
          playerViewer.controls.enableRotate = true;
          playerViewer.controls.enableZoom = false;
        } catch (e) {
          showSkinFallback(uuid);
        }
      }

      function showSkinFallback(uuid) {
        var canvas = document.getElementById('skinCanvas');
        var fallback = document.getElementById('skinFallback');
        canvas.classList.add('hidden');
        fallback.src = 'https://crafatar.com/avatars/' + uuid + '?size=80&overlay';
        fallback.classList.remove('hidden');
      }

      function disposeSkinViewer() {
        if (playerViewer) {
          try { playerViewer.dispose(); } catch (e) {}
          playerViewer = null;
        }
      }

      function hideTypedConfirm() {
        document.getElementById('typedConfirm').classList.add('hidden');
        document.getElementById('typedConfirmInput').value = '';
        document.getElementById('typedConfirmReason').value = '';
        document.getElementById('typedConfirmSubmit').disabled = true;
        document.getElementById('typedConfirmSubmit').onclick = null;
        pendingAction = null;
      }

      function showTypedConfirm(body, action) {
        pendingAction = action;
        document.getElementById('typedConfirmBody').textContent = body;
        document.getElementById('typedConfirm').classList.remove('hidden');
        var input = document.getElementById('typedConfirmInput');
        var submitBtn = document.getElementById('typedConfirmSubmit');
        input.value = '';
        submitBtn.disabled = true;

        input.oninput = function() {
          var player = getPlayerByUuid(currentPlayer);
          submitBtn.disabled = (input.value.trim() !== (player ? player.name : ''));
        };

        submitBtn.onclick = function() {
          var reason = document.getElementById('typedConfirmReason').value.trim() || undefined;
          executeAction(currentPlayer, action, reason);
          hideTypedConfirm();
        };

        setTimeout(function() { input.focus(); }, 100);
      }

      function executeAction(uuid, action, reason) {
        var player = getPlayerByUuid(uuid);
        if (!player) return;

        var body = { uuid: uuid, action: action, playerName: player.name };
        if (reason) body.reason = reason;

        fetch('/server/' + SERVER_ID + '/players/api/action', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'x-csrf-token': CSRF_TOKEN },
          body: JSON.stringify(body),
        })
        .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
        .then(function(res) {
          if (res.ok) {
            showToast(TRANSLATIONS.actionSuccess, 'success');
            setTimeout(closePlayerModal, 1500);
          } else {
            showToast(res.data.error || TRANSLATIONS.actionError, 'error');
          }
        })
        .catch(function() {
          showToast(TRANSLATIONS.actionError, 'error');
        });
      }

      document.addEventListener('DOMContentLoaded', function() {
        document.getElementById('playerModalBackdrop').addEventListener('click', closePlayerModal);
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') closePlayerModal();
        });
        document.getElementById('typedConfirmCancel').addEventListener('click', hideTypedConfirm);

        document.getElementById('actionOp').addEventListener('click', function() {
          var player = getPlayerByUuid(currentPlayer);
          if (!player) return;
          if (window.modal && typeof window.modal.confirm === 'function') {
            window.modal.confirm({
              title: TRANSLATIONS.confirmOp,
              body: '',
              danger: false,
              confirmLabel: '<%= req.translations.playerMakeOp || "Make OP" %>',
              onConfirm: function() { executeAction(currentPlayer, 'op'); }
            });
          } else {
            executeAction(currentPlayer, 'op');
          }
        });

        document.getElementById('actionKill').addEventListener('click', function() {
          var player = getPlayerByUuid(currentPlayer);
          if (!player) return;
          if (window.modal && typeof window.modal.confirm === 'function') {
            window.modal.confirm({
              title: TRANSLATIONS.confirmKill.replace('{player}', player.name),
              body: '',
              danger: true,
              confirmLabel: '<%= req.translations.playerKill || "Kill" %>',
              onConfirm: function() { executeAction(currentPlayer, 'kill'); }
            });
          } else {
            executeAction(currentPlayer, 'kill');
          }
        });

        document.getElementById('actionBan').addEventListener('click', function() {
          var player = getPlayerByUuid(currentPlayer);
          if (!player) return;
          showTypedConfirm(TRANSLATIONS.confirmBanBody, 'ban');
        });

        document.getElementById('actionIpBan').addEventListener('click', function() {
          var player = getPlayerByUuid(currentPlayer);
          if (!player) return;
          showTypedConfirm(TRANSLATIONS.confirmIpBanBody, 'ipban');
        });
      });
    </script>

    <script nonce="<%- nonce %>">
      (function() {
        var hasError = <%= errorMessage && errorMessage.message ? 'true' : 'false' %>;
        var refreshInterval = hasError ? 60000 : 30000;
        setTimeout(function() { window.location.reload(); }, refreshInterval);
        var startTime = Date.now();
        var timerEl = document.getElementById('refresh-countdown');
        if (timerEl) {
          (function tick() {
            var remaining = Math.max(0, Math.floor((refreshInterval - (Date.now() - startTime)) / 1000));
            timerEl.textContent = remaining;
            if (remaining > 0) requestAnimationFrame(tick);
          })();
        }
      })();
    </script>

  </section>
</main>

<%- include('../../components/footer') %>
