<%- include('../components/header', { title: 'Instances' }) %>

<main id="page-content" class="relative z-10">
  <%- include('../components/template') %>

  <div class="px-4 pt-5 pb-24 space-y-5">

    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-base font-medium text-neutral-800 dark:text-white">Instances</h1>
        <p class="text-xs text-neutral-500 mt-0.5">Manage your servers and resources.</p>
      </div>
      <div class="flex items-center gap-2">
        <% if (settings && settings.allowUserCreateServer) { %>
          <a href="/create-server" class="px-3 py-1.5 rounded-lg text-xs font-bold bg-white text-black hover:bg-neutral-200 transition shrink-0">Create</a>
        <% } %>
        <div class="flex items-center gap-1.5 bg-white/5 border border-white/10 rounded-xl px-3 py-1.5">
          <%- icon('server', { class: 'w-3.5 h-3.5 text-neutral-400' }) %>
          <span class="text-xs font-bold text-neutral-800 dark:text-white"><%= servers ? servers.length : 0 %></span>
        </div>
      </div>
    </div>

    <div class="relative">
      <%- icon('search', { class: 'absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-neutral-400' }) %>
      <input id="searchInput" type="search" placeholder="Search servers..."
        class="w-full rounded-xl bg-neutral-100 dark:bg-neutral-800/40 border border-neutral-200 dark:border-white/5 pl-9 pr-4 py-2.5 text-sm text-neutral-800 dark:text-white placeholder-neutral-400 focus:outline-none transition">
    </div>

    <% if (typeof daemonOffline !== 'undefined' && daemonOffline) { %>
      <div class="rounded-xl bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 px-4 py-3">
        <p class="text-sm font-medium text-red-700 dark:text-red-400">Connection Error</p>
        <p class="text-xs text-red-600 dark:text-red-400/60 mt-0.5">One or more nodes are offline.</p>
        <button onclick="window.location.reload()" class="mt-2 px-3 py-1 bg-red-600 text-white text-xs rounded-lg">Retry</button>
      </div>
    <% } %>

    <% if (!servers || servers.length === 0) { %>
      <div class="flex flex-col items-center justify-center mt-32 text-center px-4">
        <%- icon('server', { class: 'h-16 w-16 text-neutral-300 dark:text-neutral-600 mb-4' }) %>
        <h2 class="text-base font-medium text-neutral-800 dark:text-white">No instances yet</h2>
        <p class="text-sm text-neutral-500 mt-1">Servers will appear here once created.</p>
      </div>
    <% } else { %>

      <div id="serverList" class="space-y-3">
        <% servers.forEach(function(server) { %>
          <div class="server-card bg-neutral-50 dark:bg-neutral-800/20 rounded-xl border border-neutral-200 dark:border-white/5 overflow-hidden"
            data-name="<%= server.name.toLowerCase() %>"
            data-uuid="<%= server.UUID %>">

            <div class="flex items-start justify-between px-4 pt-4 pb-2">
              <div class="min-w-0 flex-1 mr-3">
                <h3 class="text-sm font-medium text-neutral-900 dark:text-white truncate"><%= server.name %></h3>
                <% if (server.description) { %>
                  <p class="text-xs text-neutral-500 dark:text-neutral-400 truncate mt-0.5"><%= server.description %></p>
                <% } %>
              </div>
              <% if (server.status === 'running') { %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 text-[11px] font-semibold rounded-md bg-emerald-50 dark:bg-emerald-500/20 text-emerald-600 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-500/30 shrink-0">
                  <span class="relative flex h-1.5 w-1.5">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-emerald-500"></span>
                  </span>
                  Running
                </span>
              <% } else { %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 text-[11px] font-semibold rounded-md bg-rose-50 dark:bg-rose-500/10 text-rose-600 dark:text-rose-400 border border-rose-200 dark:border-rose-500/20 shrink-0">
                  <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-rose-500"></span>
                  Stopped
                </span>
              <% } %>
            </div>

            <div class="px-4 pb-2">
              <div class="flex items-center gap-2 text-[10px] text-neutral-500 dark:text-neutral-400">
                <span class="flex items-center gap-1">
                  <%- icon('network', { class: 'w-3 h-3' }) %>
                  <%= server.node ? (server.node.name || 'Node') : 'Unknown' %>
                </span>
                <% if (server.expiresAt) { %>
                  <span class="flex items-center gap-1">
                    <%- icon('clock', { class: 'w-3 h-3' }) %>
                    Expires <%= new Date(server.expiresAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                  </span>
                <% } %>
              </div>
            </div>

            <div class="grid grid-cols-3 gap-px bg-neutral-200 dark:bg-white/5 mx-4 mb-3 rounded-lg overflow-hidden">
              <div class="bg-white dark:bg-neutral-800/40 px-3 py-2 text-center">
                <div class="flex items-center justify-center gap-1 mb-0.5">
                  <%- icon('memory-stick', { class: 'w-3 h-3 text-blue-500' }) %>
                  <span class="text-[10px] text-neutral-500 dark:text-neutral-400">RAM</span>
                </div>
                <p class="text-xs font-semibold text-neutral-800 dark:text-white"><%= server.ramUsage %>%</p>
              </div>
              <div class="bg-white dark:bg-neutral-800/40 px-3 py-2 text-center">
                <div class="flex items-center justify-center gap-1 mb-0.5">
                  <%- icon('cpu', { class: 'w-3 h-3 text-purple-500' }) %>
                  <span class="text-[10px] text-neutral-500 dark:text-neutral-400">CPU</span>
                </div>
                <p class="text-xs font-semibold text-neutral-800 dark:text-white"><%= server.cpuUsage %>%</p>
              </div>
              <div class="bg-white dark:bg-neutral-800/40 px-3 py-2 text-center">
                <div class="flex items-center justify-center gap-1 mb-0.5">
                  <%- icon('hard-drive', { class: 'w-3 h-3 text-emerald-500' }) %>
                  <span class="text-[10px] text-neutral-500 dark:text-neutral-400">Disk</span>
                </div>
                <p class="text-xs font-semibold text-neutral-800 dark:text-white"><%= server.diskUsage ? server.diskUsage + '%' : '—' %></p>
              </div>
            </div>

            <div class="flex gap-px bg-neutral-200 dark:bg-white/5 mx-4 mb-3 rounded-lg overflow-hidden">
              <button onclick="powerAction('<%= server.UUID %>', 'start')"
                class="flex-1 flex items-center justify-center gap-1 py-2.5 bg-white dark:bg-neutral-800/40 text-emerald-600 dark:text-emerald-400 text-[11px] font-medium transition active:bg-emerald-50 dark:active:bg-emerald-500/10">
                <%- icon('play', { class: 'w-3 h-3' }) %> Start
              </button>
              <button onclick="powerAction('<%= server.UUID %>', 'restart')"
                class="flex-1 flex items-center justify-center gap-1 py-2.5 bg-white dark:bg-neutral-800/40 text-amber-600 dark:text-amber-400 text-[11px] font-medium transition active:bg-amber-50 dark:active:bg-amber-500/10">
                <%- icon('refresh-cw', { class: 'w-3 h-3' }) %> Restart
              </button>
              <button onclick="powerAction('<%= server.UUID %>', 'stop')"
                class="flex-1 flex items-center justify-center gap-1 py-2.5 bg-white dark:bg-neutral-800/40 text-red-600 dark:text-red-400 text-[11px] font-medium transition active:bg-red-50 dark:active:bg-red-500/10">
                <%- icon('square', { class: 'w-3 h-3' }) %> Stop
              </button>
              <button onclick="powerAction('<%= server.UUID %>', 'kill')"
                class="flex-1 flex items-center justify-center gap-1 py-2.5 bg-white dark:bg-neutral-800/40 text-red-700 dark:text-red-500 text-[11px] font-medium transition active:bg-red-50 dark:active:bg-red-500/10">
                <%- icon('zap', { class: 'w-3 h-3' }) %> Kill
              </button>
            </div>

            <div class="flex gap-px bg-neutral-200 dark:bg-white/5 mx-4 mb-3 rounded-lg overflow-hidden">
              <button onclick="openUpgradeModal('<%= server.UUID %>', '<%= server.name %>', <%= server.Memory %>, <%= server.Cpu %>, <%= server.Storage %>)"
                class="flex-1 flex items-center justify-center gap-1 py-2.5 bg-white dark:bg-neutral-800/40 text-blue-600 dark:text-blue-400 text-[11px] font-medium transition active:bg-blue-50 dark:active:bg-blue-500/10">
                <%- icon('arrow-up-circle', { class: 'w-3 h-3' }) %> Upgrade
              </button>
              <button onclick="openDowngradeModal('<%= server.UUID %>', '<%= server.name %>', <%= server.Memory %>, <%= server.Cpu %>, <%= server.Storage %>)"
                class="flex-1 flex items-center justify-center gap-1 py-2.5 bg-white dark:bg-neutral-800/40 text-neutral-600 dark:text-neutral-400 text-[11px] font-medium transition active:bg-neutral-50 dark:active:bg-neutral-100 dark:active:bg-white/5">
                <%- icon('arrow-down-circle', { class: 'w-3 h-3' }) %> Downgrade
              </button>
              <button onclick="openRenewModal('<%= server.UUID %>', '<%= server.name %>')"
                class="flex-1 flex items-center justify-center gap-1 py-2.5 bg-white dark:bg-neutral-800/40 text-amber-600 dark:text-amber-400 text-[11px] font-medium transition active:bg-amber-50 dark:active:bg-amber-500/10">
                <%- icon('refresh-cw', { class: 'w-3 h-3' }) %> Renew
              </button>
            </div>

            <a href="/server/<%= server.UUID %>" class="block text-center py-3 text-xs font-medium text-neutral-500 dark:text-neutral-400 border-t border-neutral-200 dark:border-white/5 transition active:bg-neutral-100 dark:active:bg-white/5">
              Manage server
            </a>
          </div>
        <% }); %>
      </div>

    <% } %>
  </div>
</main>

<!-- Upgrade Modal -->
<div id="upgradeSheet" class="hidden fixed inset-0 z-50 bg-black/40 flex items-end p-0">
  <div class="bg-white dark:bg-neutral-800 rounded-t-2xl w-full p-5 max-h-[80dvh] overflow-y-auto">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h2 class="text-base font-medium text-neutral-800 dark:text-white">Upgrade Server</h2>
        <p id="upgradeServerName" class="text-xs text-neutral-500 mt-0.5"></p>
      </div>
      <button onclick="closeSheet('upgradeSheet')" class="text-neutral-400 p-1">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
          <path fill-rule="evenodd" d="M5.47 5.47a.75.75 0 0 1 1.06 0L12 10.94l5.47-5.47a.75.75 0 1 1 1.06 1.06L13.06 12l5.47 5.47a.75.75 0 1 1-1.06 1.06L12 13.06l-5.47 5.47a.75.75 0 0 1-1.06-1.06L10.94 12 5.47 6.53a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
        </svg>
      </button>
    </div>

    <input type="hidden" id="upgradeUUID">

    <div class="space-y-3">
      <div>
        <label class="text-xs font-medium text-neutral-500 dark:text-neutral-400 block mb-1.5">RAM (MB)</label>
        <input id="upgradeRam" type="number" min="64" step="64" class="w-full rounded-xl bg-neutral-100 dark:bg-neutral-700/30 border border-neutral-200 dark:border-neutral-600/30 px-4 py-2.5 text-sm text-neutral-800 dark:text-white outline-none">
      </div>
      <div>
        <label class="text-xs font-medium text-neutral-500 dark:text-neutral-400 block mb-1.5">CPU (%)</label>
        <input id="upgradeCpu" type="number" min="10" step="10" class="w-full rounded-xl bg-neutral-100 dark:bg-neutral-700/30 border border-neutral-200 dark:border-neutral-600/30 px-4 py-2.5 text-sm text-neutral-800 dark:text-white outline-none">
      </div>
      <div>
        <label class="text-xs font-medium text-neutral-500 dark:text-neutral-400 block mb-1.5">Disk (GB)</label>
        <input id="upgradeDisk" type="number" min="1" step="1" class="w-full rounded-xl bg-neutral-100 dark:bg-neutral-700/30 border border-neutral-200 dark:border-neutral-600/30 px-4 py-2.5 text-sm text-neutral-800 dark:text-white outline-none">
      </div>
    </div>

    <div class="flex gap-2 mt-5">
      <button onclick="closeSheet('upgradeSheet')" class="flex-1 py-2.5 text-sm font-medium text-neutral-600 dark:text-neutral-400 bg-neutral-100 dark:bg-neutral-700/30 rounded-xl transition">Cancel</button>
      <button onclick="submitUpgrade()" class="flex-1 py-2.5 text-sm font-medium text-white bg-blue-600 rounded-xl transition active:scale-[0.98]">Upgrade</button>
    </div>
  </div>
</div>

<!-- Downgrade Modal -->
<div id="downgradeSheet" class="hidden fixed inset-0 z-50 bg-black/40 flex items-end p-0">
  <div class="bg-white dark:bg-neutral-800 rounded-t-2xl w-full p-5 max-h-[80dvh] overflow-y-auto">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h2 class="text-base font-medium text-neutral-800 dark:text-white">Downgrade Server</h2>
        <p id="downgradeServerName" class="text-xs text-neutral-500 mt-0.5"></p>
      </div>
      <button onclick="closeSheet('downgradeSheet')" class="text-neutral-400 p-1">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
          <path fill-rule="evenodd" d="M5.47 5.47a.75.75 0 0 1 1.06 0L12 10.94l5.47-5.47a.75.75 0 1 1 1.06 1.06L13.06 12l5.47 5.47a.75.75 0 1 1-1.06 1.06L12 13.06l-5.47 5.47a.75.75 0 0 1-1.06-1.06L10.94 12 5.47 6.53a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
        </svg>
      </button>
    </div>

    <input type="hidden" id="downgradeUUID">

    <div class="space-y-3">
      <div>
        <label class="text-xs font-medium text-neutral-500 dark:text-neutral-400 block mb-1.5">RAM (MB)</label>
        <input id="downgradeRam" type="number" min="64" step="64" class="w-full rounded-xl bg-neutral-100 dark:bg-neutral-700/30 border border-neutral-200 dark:border-neutral-600/30 px-4 py-2.5 text-sm text-neutral-800 dark:text-white outline-none">
      </div>
      <div>
        <label class="text-xs font-medium text-neutral-500 dark:text-neutral-400 block mb-1.5">CPU (%)</label>
        <input id="downgradeCpu" type="number" min="10" step="10" class="w-full rounded-xl bg-neutral-100 dark:bg-neutral-700/30 border border-neutral-200 dark:border-neutral-600/30 px-4 py-2.5 text-sm text-neutral-800 dark:text-white outline-none">
      </div>
      <div>
        <label class="text-xs font-medium text-neutral-500 dark:text-neutral-400 block mb-1.5">Disk (GB)</label>
        <input id="downgradeDisk" type="number" min="1" step="1" class="w-full rounded-xl bg-neutral-100 dark:bg-neutral-700/30 border border-neutral-200 dark:border-neutral-600/30 px-4 py-2.5 text-sm text-neutral-800 dark:text-white outline-none">
      </div>
    </div>

    <div class="flex gap-2 mt-5">
      <button onclick="closeSheet('downgradeSheet')" class="flex-1 py-2.5 text-sm font-medium text-neutral-600 dark:text-neutral-400 bg-neutral-100 dark:bg-neutral-700/30 rounded-xl transition">Cancel</button>
      <button onclick="submitDowngrade()" class="flex-1 py-2.5 text-sm font-medium text-white bg-neutral-800 dark:bg-neutral-600 rounded-xl transition active:scale-[0.98]">Downgrade</button>
    </div>
  </div>
</div>

<!-- Renew Modal -->
<div id="renewSheet" class="hidden fixed inset-0 z-50 bg-black/40 flex items-end p-0">
  <div class="bg-white dark:bg-neutral-800 rounded-t-2xl w-full p-5 max-h-[80dvh] overflow-y-auto">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h2 class="text-base font-medium text-neutral-800 dark:text-white">Renew Server</h2>
        <p id="renewServerName" class="text-xs text-neutral-500 mt-0.5"></p>
      </div>
      <button onclick="closeSheet('renewSheet')" class="text-neutral-400 p-1">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
          <path fill-rule="evenodd" d="M5.47 5.47a.75.75 0 0 1 1.06 0L12 10.94l5.47-5.47a.75.75 0 1 1 1.06 1.06L13.06 12l5.47 5.47a.75.75 0 1 1-1.06 1.06L12 13.06l-5.47 5.47a.75.75 0 0 1-1.06-1.06L10.94 12 5.47 6.53a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
        </svg>
      </button>
    </div>

    <input type="hidden" id="renewUUID">

    <label class="text-xs font-medium text-neutral-500 dark:text-neutral-400 block mb-2">Duration</label>
    <div class="grid grid-cols-5 gap-1.5 mb-4">
      <button onclick="selectRenewDays(7, this)" data-days="7" class="renew-day-btn py-2.5 rounded-lg text-xs font-bold border border-neutral-200 dark:border-white/10 bg-neutral-100 dark:bg-neutral-700/30 text-neutral-400 text-center transition">7<span class="block text-[9px] font-normal">days</span></button>
      <button onclick="selectRenewDays(15, this)" data-days="15" class="renew-day-btn py-2.5 rounded-lg text-xs font-bold border border-neutral-200 dark:border-white/10 bg-neutral-100 dark:bg-neutral-700/30 text-neutral-400 text-center transition">15<span class="block text-[9px] font-normal">days</span></button>
      <button onclick="selectRenewDays(30, this)" data-days="30" class="renew-day-btn py-2.5 rounded-lg text-xs font-bold border border-neutral-200 dark:border-white/10 bg-neutral-100 dark:bg-neutral-700/30 text-neutral-400 text-center transition">30<span class="block text-[9px] font-normal">days</span></button>
      <button onclick="selectRenewDays(60, this)" data-days="60" class="renew-day-btn py-2.5 rounded-lg text-xs font-bold border border-neutral-200 dark:border-white/10 bg-neutral-100 dark:bg-neutral-700/30 text-neutral-400 text-center transition">60<span class="block text-[9px] font-normal">days</span></button>
      <button onclick="selectRenewDays(90, this)" data-days="90" class="renew-day-btn py-2.5 rounded-lg text-xs font-bold border border-neutral-200 dark:border-white/10 bg-neutral-100 dark:bg-neutral-700/30 text-neutral-400 text-center transition">90<span class="block text-[9px] font-normal">days</span></button>
    </div>

    <div id="renewSummary" class="hidden rounded-xl bg-neutral-100 dark:bg-neutral-700/20 border border-neutral-200 dark:border-white/5 p-3 space-y-1.5 mb-4">
      <div class="flex justify-between text-xs"><span class="text-neutral-500">Duration</span><span id="renewDurationText" class="text-neutral-800 dark:text-white font-medium">—</span></div>
      <div class="flex justify-between text-xs"><span class="text-neutral-500">New Expiry</span><span id="renewNewExpiry" class="text-emerald-600 dark:text-emerald-400 font-medium">—</span></div>
    </div>

    <div class="flex gap-2">
      <button onclick="closeSheet('renewSheet')" class="flex-1 py-2.5 text-sm font-medium text-neutral-600 dark:text-neutral-400 bg-neutral-100 dark:bg-neutral-700/30 rounded-xl transition">Cancel</button>
      <button onclick="submitRenew()" id="renewSubmitBtn" disabled class="flex-1 py-2.5 text-sm font-medium text-white bg-amber-600 rounded-xl transition active:scale-[0.98] disabled:opacity-40 disabled:cursor-not-allowed">Renew</button>
    </div>
  </div>
</div>

<script nonce="<%- nonce %>">
(function() {
  var searchInput = document.getElementById('searchInput');
  if (searchInput) {
    searchInput.addEventListener('input', function() {
      var term = this.value.toLowerCase().trim();
      document.querySelectorAll('.server-card').forEach(function(card) {
        var name = card.getAttribute('data-name') || '';
        card.style.display = (!term || name.includes(term)) ? '' : 'none';
      });
    });
  }

  window.powerAction = function(uuid, action) {
    var label = action.charAt(0).toUpperCase() + action.slice(1);
    var isDanger = action === 'kill' || action === 'stop';
    window.modal.confirm({
      title: label + ' server?',
      body: 'This will ' + label.toLowerCase() + ' the server. Continue?',
      danger: isDanger,
      confirmLabel: label,
      onConfirm: function() {
        fetch('/server/' + uuid + '/power/' + action, { method: 'POST' })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (data.error) {
              window.modal.confirm({ title: 'Error', body: data.error, danger: true, confirmLabel: 'OK', onConfirm: function() {} });
            } else {
              window.modal.confirm({ title: 'Done', body: label + ' signal sent.', danger: false, confirmLabel: 'OK', onConfirm: function() { window.location.reload(); } });
            }
          })
          .catch(function() {
            window.modal.confirm({ title: 'Error', body: 'Network error. Try again.', danger: true, confirmLabel: 'OK', onConfirm: function() {} });
          });
      }
    });
  };

  window.closeSheet = function(id) {
    document.getElementById(id).classList.add('hidden');
  };

  window.openUpgradeModal = function(uuid, name, ram, cpu, disk) {
    document.getElementById('upgradeUUID').value = uuid;
    document.getElementById('upgradeServerName').textContent = name;
    document.getElementById('upgradeRam').value = ram;
    document.getElementById('upgradeCpu').value = cpu;
    document.getElementById('upgradeDisk').value = disk;
    document.getElementById('upgradeSheet').classList.remove('hidden');
  };

  window.submitUpgrade = function() {
    var uuid = document.getElementById('upgradeUUID').value;
    var ram = document.getElementById('upgradeRam').value;
    var cpu = document.getElementById('upgradeCpu').value;
    var disk = document.getElementById('upgradeDisk').value;

    window.modal.confirm({
      title: 'Confirm Upgrade',
      body: 'Upgrade RAM to ' + ram + 'MB, CPU to ' + cpu + '%, Disk to ' + disk + 'GB?',
      danger: false,
      confirmLabel: 'Upgrade',
      onConfirm: function() {
        fetch('/server/' + uuid + '/upgrade', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ Memory: ram, Cpu: cpu, Storage: disk })
        }).then(function(r) { return r.json(); }).then(function(data) {
          if (data.error) {
            window.modal.confirm({ title: 'Error', body: data.error, danger: true, confirmLabel: 'OK', onConfirm: function() {} });
          } else {
            window.modal.confirm({ title: 'Upgraded!', body: 'Server resources updated.', danger: false, confirmLabel: 'OK', onConfirm: function() { window.location.reload(); } });
          }
        }).catch(function() {
          window.modal.confirm({ title: 'Error', body: 'Network error.', danger: true, confirmLabel: 'OK', onConfirm: function() {} });
        });
      }
    };
  };

  window.openDowngradeModal = function(uuid, name, ram, cpu, disk) {
    document.getElementById('downgradeUUID').value = uuid;
    document.getElementById('downgradeServerName').textContent = name;
    document.getElementById('downgradeRam').value = ram;
    document.getElementById('downgradeCpu').value = cpu;
    document.getElementById('downgradeDisk').value = disk;
    document.getElementById('downgradeSheet').classList.remove('hidden');
  };

  window.submitDowngrade = function() {
    var uuid = document.getElementById('downgradeUUID').value;
    var ram = document.getElementById('downgradeRam').value;
    var cpu = document.getElementById('downgradeCpu').value;
    var disk = document.getElementById('downgradeDisk').value;

    window.modal.confirm({
      title: 'Confirm Downgrade',
      body: 'Downgrade RAM to ' + ram + 'MB, CPU to ' + cpu + '%, Disk to ' + disk + 'GB?',
      danger: false,
      confirmLabel: 'Downgrade',
      onConfirm: function() {
        fetch('/server/' + uuid + '/downgrade', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ Memory: ram, Cpu: cpu, Storage: disk })
        }).then(function(r) { return r.json(); }).then(function(data) {
          if (data.error) {
            window.modal.confirm({ title: 'Error', body: data.error, danger: true, confirmLabel: 'OK', onConfirm: function() {} });
          } else {
            window.modal.confirm({ title: 'Downgraded!', body: 'Server resources updated.', danger: false, confirmLabel: 'OK', onConfirm: function() { window.location.reload(); } });
          }
        }).catch(function() {
          window.modal.confirm({ title: 'Error', body: 'Network error.', danger: true, confirmLabel: 'OK', onConfirm: function() {} });
        });
      }
    };
  };

  var selectedRenewDays = 0;

  window.openRenewModal = function(uuid, name) {
    document.getElementById('renewUUID').value = uuid;
    document.getElementById('renewServerName').textContent = name;
    selectedRenewDays = 0;
    document.getElementById('renewSummary').classList.add('hidden');
    document.getElementById('renewSubmitBtn').disabled = true;
    document.querySelectorAll('.renew-day-btn').forEach(function(b) {
      b.classList.remove('bg-amber-500', 'text-white', 'border-amber-500/30');
      b.classList.add('bg-neutral-100', 'dark:bg-neutral-700/30', 'text-neutral-400');
    });
    document.getElementById('renewSheet').classList.remove('hidden');
  };

  window.selectRenewDays = function(days, el) {
    selectedRenewDays = days;
    document.querySelectorAll('.renew-day-btn').forEach(function(b) {
      b.classList.remove('bg-amber-500', 'text-white', 'border-amber-500/30');
      b.classList.add('bg-neutral-100', 'dark:bg-neutral-700/30', 'text-neutral-400');
    });
    el.classList.add('bg-amber-500', 'text-white', 'border-amber-500/30');
    el.classList.remove('bg-neutral-100', 'dark:bg-neutral-700/30', 'text-neutral-400');

    var now = new Date();
    var newExpiry = new Date(now.getTime() + days * 86400000);

    document.getElementById('renewDurationText').textContent = days + ' days';
    document.getElementById('renewNewExpiry').textContent = newExpiry.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
    document.getElementById('renewSummary').classList.remove('hidden');
    document.getElementById('renewSubmitBtn').disabled = false;
  };

  window.submitRenew = function() {
    var uuid = document.getElementById('renewUUID').value;
    if (!uuid || !selectedRenewDays) return;

    window.modal.confirm({
      title: 'Confirm Renewal',
      body: 'Renew for ' + selectedRenewDays + ' days?',
      danger: false,
      confirmLabel: 'Renew',
      onConfirm: function() {
        fetch('/server/' + uuid + '/renew', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ days: selectedRenewDays })
        }).then(function(r) { return r.json(); }).then(function(data) {
          if (data.error) {
            window.modal.confirm({ title: 'Error', body: data.error, danger: true, confirmLabel: 'OK', onConfirm: function() {} });
          } else {
            window.modal.confirm({ title: 'Renewed!', body: 'Server renewed for ' + selectedRenewDays + ' days.', danger: false, confirmLabel: 'OK', onConfirm: function() { window.location.reload(); } });
          }
        }).catch(function() {
          window.modal.confirm({ title: 'Error', body: 'Network error.', danger: true, confirmLabel: 'OK', onConfirm: function() {} });
        });
      }
    };
  };
})();
</script>

