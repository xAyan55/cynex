<%- include('../components/header', { title: 'Purchases' }) %>

<main id="page-content" class="relative z-10">
  <%- include('../components/template') %>

  <div class="px-4 pt-5 pb-24 space-y-5">

    <div>
      <h1 class="text-base font-medium text-neutral-800 dark:text-white">Purchases</h1>
      <p class="text-xs text-neutral-500 mt-0.5">Your purchase history and receipts.</p>
    </div>

    <% if (!purchases || purchases.length === 0) { %>
      <div class="flex flex-col items-center justify-center py-24 text-center">
        <%- icon('shopping-bag', { class: 'h-16 w-16 text-neutral-300 dark:text-neutral-600 mb-4' }) %>
        <h2 class="text-base font-medium text-neutral-800 dark:text-white">No purchases yet</h2>
        <p class="text-sm text-neutral-500 mt-1">Items you buy will appear here.</p>
      </div>
    <% } else { %>

      <div class="space-y-2">
        <% purchases.forEach(function(purchase) { %>
          <div class="bg-white dark:bg-neutral-800/20 rounded-xl border border-neutral-200 dark:border-white/5 overflow-hidden">
            <div class="px-4 py-3">
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0 flex-1">
                  <p class="text-sm font-medium text-neutral-800 dark:text-white truncate"><%= purchase.productName || purchase.name || 'Purchase' %></p>
                  <% if (purchase.description) { %>
                    <p class="text-[11px] text-neutral-500 dark:text-neutral-400 mt-0.5 truncate"><%= purchase.description %></p>
                  <% } %>
                </div>
                <div class="shrink-0 text-right">
                  <p class="text-sm font-bold text-neutral-800 dark:text-white"><%= (purchase.price || 0).toLocaleString() %> coins</p>
                </div>
              </div>

              <div class="flex items-center gap-3 mt-2">
                <span class="flex items-center gap-1 text-[10px] text-neutral-400">
                  <%- icon('calendar', { class: 'w-3 h-3' }) %>
                  <%= new Date(purchase.createdAt || purchase.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                </span>
                <% if (purchase.status) { %>
                  <% if (purchase.status === 'completed' || purchase.status === 'success') { %>
                    <span class="text-[10px] font-medium px-1.5 py-0.5 rounded bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-500/20"><%= purchase.status %></span>
                  <% } else if (purchase.status === 'pending') { %>
                    <span class="text-[10px] font-medium px-1.5 py-0.5 rounded bg-amber-50 dark:bg-amber-500/10 text-amber-600 dark:text-amber-400 border border-amber-200 dark:border-amber-500/20"><%= purchase.status %></span>
                  <% } else if (purchase.status === 'failed' || purchase.status === 'refunded') { %>
                    <span class="text-[10px] font-medium px-1.5 py-0.5 rounded bg-red-50 dark:bg-red-500/10 text-red-600 dark:text-red-400 border border-red-200 dark:border-red-500/20"><%= purchase.status %></span>
                  <% } else { %>
                    <span class="text-[10px] font-medium px-1.5 py-0.5 rounded bg-neutral-100 dark:bg-neutral-700/30 text-neutral-500 dark:text-neutral-400"><%= purchase.status %></span>
                  <% } %>
                <% } %>
              </div>
            </div>

            <% if (purchase.receiptUrl || purchase.receipt) { %>
              <a href="<%= purchase.receiptUrl || '#receipt-' + (purchase.id || '') %>"
                class="flex items-center justify-center gap-1.5 py-2.5 text-xs font-medium text-neutral-500 dark:text-neutral-400 border-t border-neutral-200 dark:border-white/5 transition active:bg-neutral-50 dark:active:bg-white/5">
                <%- icon('file-text', { class: 'w-3.5 h-3.5' }) %>
                View receipt
              </a>
            <% } %>
          </div>
        <% }); %>
      </div>

    <% } %>

    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
      <div class="flex items-center justify-center gap-3 pt-2">
        <% if (page > 1) { %>
          <a href="/purchases?page=<%= page - 1 %>" class="px-4 py-2 text-xs font-medium text-neutral-600 dark:text-neutral-400 bg-neutral-100 dark:bg-neutral-800/40 border border-neutral-200 dark:border-white/5 rounded-xl transition active:scale-95">Prev</a>
        <% } %>
        <span class="text-xs text-neutral-500"><%= page %> / <%= totalPages %></span>
        <% if (page < totalPages) { %>
          <a href="/purchases?page=<%= page + 1 %>" class="px-4 py-2 text-xs font-medium text-white bg-neutral-900 dark:bg-white dark:text-neutral-900 rounded-xl transition active:scale-95">Next</a>
        <% } %>
      </div>
    <% } %>

  </div>
</main>

<%- include('../components/footer') %>