<%- include('../components/header', { title: 'Store' }) %>
<main id="page-content" class="relative z-10">
  <%- include('../components/template') %>
  <div class="px-4 pt-5 pb-24 space-y-7">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-base font-medium text-white">Store</h1>
        <p class="text-xs text-neutral-400 mt-0.5">Purchase resources with coins.</p>
      </div>
      <div class="flex items-center gap-1.5 bg-white/5 border border-white/10 rounded-xl px-3 py-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-amber-400" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1.41 16.09V20h-2.67v-1.93c-1.71-.36-3.16-1.46-3.27-3.4h1.96c.1 1.05.82 1.87 2.65 1.87 1.96 0 2.4-.98 2.4-1.59 0-.83-.44-1.61-2.67-2.14-2.48-.6-4.18-1.62-4.18-3.67 0-1.72 1.39-2.84 3.11-3.21V4h2.67v1.95c1.86.45 2.79 1.86 2.85 3.39H14.3c-.05-1.11-.64-1.87-2.22-1.87-1.5 0-2.4.68-2.4 1.64 0 .84.65 1.39 2.67 1.91s4.18 1.39 4.18 3.91c-.01 1.83-1.38 2.83-3.12 3.16z"/></svg>
        <span class="text-xs font-bold text-white"><%= balance.toLocaleString() %></span>
      </div>
    </div>

    <% if (!products || products.length === 0) { %>
      <div class="flex flex-col items-center justify-center py-16 text-center">
        <div class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-12 0v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-6 0h18M3 9l9-6 9 6"/></svg>
        </div>
        <p class="text-sm font-medium text-white">No products yet</p>
      </div>
    <% } else { %>
      <div class="space-y-3">
        <% products.forEach(function(product) { %>
          <div class="rounded-xl bg-white/5 border border-white/5 p-4 space-y-3">
            <div class="flex items-start justify-between">
              <div class="flex items-center gap-2.5">
                <div class="p-2 rounded-lg bg-brand-green/10 border border-brand-green/20 text-brand-green">
                  <%- icon(product.icon || 'package', { class: 'w-4 h-4' }) %>
                </div>
                <div>
                  <p class="text-sm font-medium text-white"><%= product.name %></p>
                  <% if (product.description) { %><p class="text-xs text-neutral-400"><%= product.description %></p><% } %>
                </div>
              </div>
              <% if (product.featured) { %><span class="text-xs text-amber-400">Featured</span><% } %>
            </div>
            <div class="flex items-center justify-between pt-2 border-t border-white/5">
              <span class="text-sm font-bold text-white"><%= product.price.toLocaleString() %> coins</span>
              <button onclick="purchase(<%= product.id %>)" class="px-3 py-1.5 rounded-lg text-xs font-bold bg-brand-green text-black">Buy</button>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</main>
<script nonce="<%- nonce %>">
function purchase(productId) {
  if (!confirm('Confirm purchase?')) return;
  fetch('/store/buy/' + productId, { method: 'POST' })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        alert('Purchased!');
        window.location.reload();
      } else {
        alert(data.error || 'Purchase failed.');
      }
    })
    .catch(function() { alert('Network error.'); });
}
</script>
<%- include('../components/footer') %>