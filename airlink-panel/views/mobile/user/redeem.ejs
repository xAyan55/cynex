<%- include('../components/header', { title: 'Redeem' }) %>
<main id="page-content" class="relative z-10">
  <%- include('../components/template') %>
  <div class="px-4 pt-5 pb-24 space-y-7">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-base font-medium text-white">Redeem Coupon</h1>
        <p class="text-xs text-neutral-400 mt-0.5">Enter a code to claim rewards.</p>
      </div>
      <div class="flex items-center gap-1.5 bg-white/5 border border-white/10 rounded-xl px-3 py-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-amber-400" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1.41 16.09V20h-2.67v-1.93c-1.71-.36-3.16-1.46-3.27-3.4h1.96c.1 1.05.82 1.87 2.65 1.87 1.96 0 2.4-.98 2.4-1.59 0-.83-.44-1.61-2.67-2.14-2.48-.6-4.18-1.62-4.18-3.67 0-1.72 1.39-2.84 3.11-3.21V4h2.67v1.95c1.86.45 2.79 1.86 2.85 3.39H14.3c-.05-1.11-.64-1.87-2.22-1.87-1.5 0-2.4.68-2.4 1.64 0 .84.65 1.39 2.67 1.91s4.18 1.39 4.18 3.91c-.01 1.83-1.38 2.83-3.12 3.16z"/></svg>
        <span class="text-xs font-bold text-white"><%= balance.toLocaleString() %></span>
      </div>
    </div>

    <% if (error) { %>
      <div class="rounded-xl bg-red-500/10 border border-red-500/20 px-4 py-3">
        <p class="text-xs font-semibold text-red-400"><%= error %></p>
      </div>
    <% } %>

    <% if (success) { %>
      <div class="rounded-xl bg-brand-green/10 border border-brand-green/20 px-4 py-3">
        <p class="text-xs font-semibold text-brand-green">Redeemed!</p>
        <p class="text-xs text-neutral-400 mt-0.5">Received <%= success.rewardAmount %> of <%= success.rewardType %>.</p>
      </div>
    <% } %>

    <div class="rounded-xl bg-white/5 border border-white/5 p-6">
      <form method="POST" action="/redeem" class="space-y-4">
        <div>
          <label class="text-xs font-medium text-white block mb-1.5">Coupon Code</label>
          <input type="text" name="code" placeholder="ENTER CODE" required
            class="w-full border border-white/10 rounded-xl bg-white/5 px-3 py-2.5 text-sm text-white outline-none focus:border-brand-green/30 placeholder:text-neutral-500 font-mono uppercase tracking-widest box-border">
        </div>
        <button type="submit" class="w-full py-2.5 rounded-xl text-sm font-bold bg-brand-green text-black">Redeem</button>
      </form>
    </div>
  </div>
</main>
<%- include('../components/footer') %>