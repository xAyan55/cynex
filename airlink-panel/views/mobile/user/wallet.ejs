<%- include('../components/header', { title: 'Wallet' }) %>

<main id="page-content" class="relative z-10">
  <%- include('../components/template') %>

  <div class="px-4 pt-5 pb-24 space-y-5">

    <div>
      <h1 class="text-base font-medium text-neutral-800 dark:text-white">Wallet</h1>
      <p class="text-xs text-neutral-500 mt-0.5">Your coin balance and transaction history.</p>
    </div>

    <div class="rounded-2xl bg-gradient-to-br from-amber-500/10 via-amber-400/5 to-transparent border border-amber-200/30 dark:border-amber-500/15 p-5 text-center">
      <div class="flex items-center justify-center gap-2 mb-2">
        <%- icon('coins', { class: 'w-5 h-5 text-amber-500' }) %>
        <span class="text-xs font-semibold uppercase tracking-wider text-amber-600 dark:text-amber-400">Balance</span>
      </div>
      <p id="balanceDisplay" class="text-3xl font-bold text-neutral-900 dark:text-white"><%= balance.toLocaleString() %></p>
      <p class="text-xs text-neutral-500 mt-1">coins available</p>
    </div>

    <div>
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 dark:text-neutral-400">Transactions</h2>
        <% if (transactions && transactions.length > 0) { %>
          <span class="text-[10px] text-neutral-400"><%= transactions.length %> total</span>
        <% } %>
      </div>

      <% if (!transactions || transactions.length === 0) { %>
        <div class="flex flex-col items-center justify-center py-16 text-center">
          <%- icon('receipt', { class: 'h-12 w-12 text-neutral-300 dark:text-neutral-600 mb-3' }) %>
          <p class="text-sm font-medium text-neutral-800 dark:text-white">No transactions yet</p>
          <p class="text-xs text-neutral-500 mt-1">Your purchase history will appear here.</p>
        </div>
      <% } else { %>
        <div class="space-y-2">
          <% transactions.forEach(function(tx) { %>
            <div class="bg-white dark:bg-neutral-800/20 rounded-xl border border-neutral-200 dark:border-white/5 px-4 py-3">
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0 flex-1">
                  <p class="text-sm font-medium text-neutral-800 dark:text-white truncate"><%= tx.reason || 'Transaction' %></p>
                  <p class="text-[10px] text-neutral-400 mt-0.5"><%= new Date(tx.createdAt || tx.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
                </div>
                <div class="shrink-0 text-right">
                  <% if (tx.type === 'credit' || tx.type === 'deposit' || tx.type === 'refund' || tx.amount > 0) { %>
                    <span class="inline-flex items-center px-2 py-0.5 text-[11px] font-semibold rounded-md bg-emerald-50 dark:bg-emerald-500/15 text-emerald-600 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-500/20">
                      +<%= Math.abs(tx.amount).toLocaleString() %>
                    </span>
                  <% } else { %>
                    <span class="inline-flex items-center px-2 py-0.5 text-[11px] font-semibold rounded-md bg-red-50 dark:bg-red-500/10 text-red-600 dark:text-red-400 border border-red-200 dark:border-red-500/20">
                      -<%= Math.abs(tx.amount).toLocaleString() %>
                    </span>
                  <% } %>
                </div>
              </div>
              <% if (tx.type) { %>
                <div class="mt-1.5">
                  <% if (tx.type === 'credit' || tx.type === 'deposit') { %>
                    <span class="text-[10px] font-medium px-1.5 py-0.5 rounded bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400"><%= tx.type %></span>
                  <% } else if (tx.type === 'purchase' || tx.type === 'deduction') { %>
                    <span class="text-[10px] font-medium px-1.5 py-0.5 rounded bg-red-50 dark:bg-red-500/10 text-red-600 dark:text-red-400"><%= tx.type %></span>
                  <% } else if (tx.type === 'refund') { %>
                    <span class="text-[10px] font-medium px-1.5 py-0.5 rounded bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400"><%= tx.type %></span>
                  <% } else { %>
                    <span class="text-[10px] font-medium px-1.5 py-0.5 rounded bg-neutral-100 dark:bg-neutral-700/30 text-neutral-500 dark:text-neutral-400"><%= tx.type %></span>
                  <% } %>
                </div>
              <% } %>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>

    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
      <div class="flex items-center justify-center gap-3 pt-2">
        <% if (page > 1) { %>
          <a href="/wallet?page=<%= page - 1 %>" class="px-4 py-2 text-xs font-medium text-neutral-600 dark:text-neutral-400 bg-neutral-100 dark:bg-neutral-800/40 border border-neutral-200 dark:border-white/5 rounded-xl transition active:scale-95">Prev</a>
        <% } %>
        <span class="text-xs text-neutral-500"><%= page %> / <%= totalPages %></span>
        <% if (page < totalPages) { %>
          <a href="/wallet?page=<%= page + 1 %>" class="px-4 py-2 text-xs font-medium text-white bg-neutral-900 dark:bg-white dark:text-neutral-900 rounded-xl transition active:scale-95">Next</a>
        <% } %>
      </div>
    <% } %>

  </div>
</main>

<%- include('../components/footer') %>