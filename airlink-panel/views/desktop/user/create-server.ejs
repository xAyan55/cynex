<%- include('../components/header', { title: 'Create Server' }) %>

<style>
  ::-webkit-scrollbar { display: none; }

  /* ── Custom select design overloads for dark theme ───────── */
  .custom-select { position: relative; user-select: none; }
  .cs-trigger {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; padding: 12px 16px; border-radius: 12px; cursor: pointer;
    font-size: 14px; border: 1px solid rgba(255, 255, 255, 0.05);
    background: rgba(255, 255, 255, 0.02); color: #e5e5e5;
    transition: all 0.2s ease;
  }
  .cs-trigger:hover { background: rgba(255, 255, 255, 0.06); border-color: rgba(34, 197, 94, 0.2); }
  .cs-trigger.open { border-color: rgba(34, 197, 94, 0.3); box-shadow: 0 0 12px rgba(34, 197, 94, 0.1); }
  .cs-trigger svg { width: 14px; height: 14px; opacity: 0.45; transition: transform 0.2s; flex-shrink: 0; }
  .cs-trigger.open svg { transform: rotate(180deg); }
  .cs-placeholder { opacity: 0.45; }
  .cs-dropdown {
    position: absolute; top: calc(100% + 5px); left: 0; right: 0; z-index: 9999;
    background: #0c0c14; border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 12px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5); overflow: hidden;
    max-height: 200px; overflow-y: auto;
  }
  .cs-option { padding: 10px 16px; font-size: 13px; cursor: pointer; color: #d4d4d4; transition: background 0.1s; }
  .cs-option:hover { background: rgba(255, 255, 255, 0.05); color: white; }
  .cs-option.selected { background: rgba(34, 197, 94, 0.1); color: #22c55e; font-weight: 600; }
  .cs-option.disabled { opacity: 0.3; cursor: default; pointer-events: none; }

  /* ── Input styling ────────────────────────────────────────── */
  .form-input {
    width: 100%; padding: 12px 16px; border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.05); background: rgba(255, 255, 255, 0.02);
    font-size: 14px; color: white; outline: none;
    transition: all 0.2s ease;
    box-sizing: border-box; font-family: inherit;
  }
  .form-input:focus { border-color: rgba(34, 197, 94, 0.3); box-shadow: 0 0 12px rgba(34, 197, 94, 0.1); }
  .form-input::placeholder { color: #52525b; }
  .form-label { display: block; font-size: 12px; font-weight: 700; uppercase: true; tracking: 0.05em; color: #a1a1aa; margin-bottom: 8px; }

  /* ── Resource steppers ────────────────────────────────────── */
  .stepper { display: flex; align-items: center; border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 12px; overflow: hidden; background: rgba(255, 255, 255, 0.02); }
  .stepper-btn {
    padding: 10px 16px; background: none; border: none; cursor: pointer;
    font-size: 16px; color: #a1a1aa; transition: background 0.2s;
    flex-shrink: 0; line-height: 1;
  }
  .stepper-btn:hover { background: rgba(255, 255, 255, 0.06); color: white; }
  .stepper-input {
    flex: 1; text-align: center; border: none; background: none; outline: none;
    font-size: 14px; font-weight: 600; color: white; padding: 10px 4px;
    font-family: inherit; min-width: 0;
  }

  /* ── Select Unit overloads ────────────────────────── */
  .select-unit {
    border-radius: 0 12px 12px 0; font-size: 12px; font-weight: 600; padding: 0 12px;
    background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(255, 255, 255, 0.05);
    border-left: none; color: white; cursor: pointer; outline: none;
  }
  .select-unit:focus { border-color: rgba(34, 197, 94, 0.2); }

  /* ── Confirmation overlay ────────────────────────────────── */
  .confirm-overlay {
    position: fixed; inset: 0; z-index: 150;
    background: rgba(0, 0, 0, 0.7); backdrop-filter: blur(8px);
    display: flex; align-items: center; justify-content: center; padding: 16px;
    opacity: 0; pointer-events: none; transition: opacity 0.25s ease;
  }
  .confirm-overlay.open { opacity: 1; pointer-events: auto; }
  .confirm-box {
    background: #0c0c14; border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 16px;
    width: 100%; max-w: 440px; padding: 24px; shadow: 2xl;
    transform: scale(0.96); opacity: 0;
    transition: transform 0.25s cubic-bezier(0.16,1,0.3,1), opacity 0.25s;
  }
  .confirm-overlay.open .confirm-box { transform: scale(1); opacity: 1; }
</style>

<main class="h-screen m-auto bg-mono-bg text-white">
  <div class="flex h-screen">
    <div class="w-60 h-full"><%- include('../components/template') %></div>

    <div id="page-content" class="flex-1 overflow-y-auto pt-16">
      <div class="px-12 pt-8 pb-12 max-w-4xl space-y-8">

        <!-- Wizard header -->
        <div class="flex justify-between items-center border-b border-white/5 pb-5">
          <div>
            <h1 class="text-xl font-bold tracking-tight text-white">Configure Server Setup</h1>
            <p class="text-sm text-neutral-400 mt-1"><%= currentCount %> of <%= serverLimit %> active server slots used</p>
          </div>
          <a href="/dashboard" class="text-xs font-semibold text-neutral-400 hover:text-white transition">Cancel Setup</a>
        </div>

        <!-- Wizard Step Indicators -->
        <div id="wizard-steps-container">
          <%- include('../components/ui/WizardStep', { active: 1 }) %>
        </div>

        <!-- WIZARD STEP 1: SOFTWARE & VERSION -->
        <div class="wizard-pane space-y-6" data-step="1">
          <%- include('../components/ui/Card', { hover: false, class: 'p-6 border border-white/5 space-y-6' }) %>
            <div>
              <h2 class="text-base font-bold text-white">Choose Instance Type & Software</h2>
              <p class="text-xs text-neutral-400 mt-0.5">Select the environment type and runtime template for your new deployment.</p>
            </div>

            <!-- Instance Type Toggle Buttons -->
            <input type="hidden" id="instanceType" name="instanceType" value="MINECRAFT">
            <div class="flex gap-4">
              <button type="button" id="btnMinecraft" onclick="setInstanceType('MINECRAFT')"
                class="flex-1 flex items-center justify-center gap-2 px-4 py-3 rounded-xl border-2 border-brand-green bg-brand-green/10 text-brand-green font-bold text-sm transition-all duration-200 cursor-pointer">
                <%- icon('gamepad-2', { class: 'w-4 h-4 shrink-0' }) %>
                Minecraft Server
              </button>
              <button type="button" id="btnLXC" onclick="setInstanceType('LXC')"
                class="flex-1 flex items-center justify-center gap-2 px-4 py-3 rounded-xl border border-white/10 bg-white/5 text-neutral-400 font-bold text-sm transition-all duration-200 cursor-pointer hover:border-white/20 hover:text-white">
                <%- icon('monitor', { class: 'w-4 h-4 shrink-0' }) %>
                VPS LXC Container
              </button>
            </div>
            
            <!-- Minecraft Specific Software Fields -->
            <div id="minecraftFields" class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-2">
              <div class="space-y-2">
                <label class="form-label">Software Image</label>
                <select id="imageId" class="hidden">
                  <option value="" disabled selected>Select software type</option>
                  <% images.forEach(image => { %>
                    <option value="<%= image.id %>" data-docker="<%= image.dockerImages %>" data-port-requirements='<%= image.portRequirements || "[]" %>'><%= image.name %></option>
                  <% }); %>
                </select>
                <div class="custom-select" data-for="imageId"></div>
              </div>

              <div class="space-y-2">
                <label class="form-label">Version / Docker Image</label>
                <select id="dockerImage" class="hidden">
                  <option value="" disabled selected>Select software first</option>
                </select>
                <div class="custom-select" data-for="dockerImage"></div>
              </div>
            </div>

            <!-- LXC Specific VPS Fields -->
            <div id="lxcFields" class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-2 hidden">
              <div class="space-y-2">
                <label class="form-label">OS Template</label>
                <select id="osTemplate" class="hidden">
                  <option value="ubuntu/24.04" selected>Ubuntu 24.04</option>
                  <option value="ubuntu/22.04">Ubuntu 22.04</option>
                  <option value="debian/12">Debian 12</option>
                  <option value="debian/11">Debian 11</option>
                  <option value="almalinux/9">AlmaLinux 9</option>
                  <option value="rockylinux/9">Rocky Linux 9</option>
                  <option value="fedora/40">Fedora 40</option>
                  <option value="archlinux/current">Arch Linux</option>
                  <option value="alpine/3.20">Alpine 3.20</option>
                </select>
                <div class="custom-select" data-for="osTemplate"></div>
              </div>

              <div class="space-y-2">
                <label class="form-label">Root Password</label>
                <input id="rootPassword" type="password" placeholder="Leave empty for auto-generated" class="form-input">
              </div>
            </div>

            <div class="pt-4 border-t border-white/5 flex justify-end">
              <button onclick="nextStep(2)" class="px-5 py-2.5 rounded-xl bg-brand-green text-black hover:bg-brand-green-hover text-xs font-bold transition cursor-pointer">
                Continue to Location
              </button>
            </div>
          </div>
        </div>

        <!-- WIZARD STEP 2: LOCATION & RESOURCES -->
        <div class="wizard-pane space-y-6 hidden" data-step="2">
          <%- include('../components/ui/Card', { hover: false, class: 'p-6 border border-white/5 space-y-6' }) %>
            <div>
              <h2 class="text-base font-bold text-white">Choose Deploy Region</h2>
              <p class="text-xs text-neutral-400 mt-0.5">Select the closest geographic zone for minimal latency.</p>
            </div>

            <div class="space-y-2 max-w-sm">
              <label class="form-label">Server Node Address</label>
              <select id="nodeId" class="hidden">
                <option value="" disabled selected>Select geographic node</option>
                <% nodes.forEach(node => { %>
                  <option value="<%= node.id %>"><%= node.name %> — <%= node.address %></option>
                <% }); %>
              </select>
              <div class="custom-select" data-for="nodeId"></div>
            </div>

            <div class="pt-4 border-t border-white/5 flex justify-between">
              <button onclick="prevStep(1)" class="px-5 py-2.5 rounded-xl bg-white/5 border border-white/10 text-neutral-300 hover:bg-white/10 text-xs font-bold transition cursor-pointer">Back</button>
              <button onclick="nextStep(3)" class="px-5 py-2.5 rounded-xl bg-brand-green text-black hover:bg-brand-green-hover text-xs font-bold transition cursor-pointer">Continue to Resources</button>
            </div>
          </div>
        </div>

        <!-- WIZARD STEP 3: RESOURCES -->
        <div class="wizard-pane space-y-6 hidden" data-step="3">
          <%- include('../components/ui/Card', { hover: false, class: 'p-6 border border-white/5 space-y-6' }) %>
            <div>
              <h2 class="text-base font-bold text-white">Adjust Resource Cappings</h2>
              <p class="text-xs text-neutral-400 mt-0.5">Configure hardware memory bounds, CPU allocations, and storage size limits.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 pt-2">
              <!-- Memory (RAM) -->
              <div class="space-y-2">
                <label class="form-label flex items-center gap-1.5 text-neutral-300">
                  <%- icon('server', { width: 14, height: 14 }) %>
                  RAM (Memory)
                </label>
                <input type="hidden" id="Memory" value="1024">
                <div class="flex items-stretch">
                  <button type="button" class="stepper-btn border border-r-0 border-white/10 rounded-l-xl bg-white/5" data-action="dec" data-target="MemoryDisplay" data-step="128" data-min="128">−</button>
                  <input id="MemoryDisplay" type="number" value="1024" min="128" class="stepper-input border-y border-white/10">
                  <button type="button" class="stepper-btn border-y border-white/10 bg-white/5" data-action="inc" data-target="MemoryDisplay" data-step="128">+</button>
                  <select id="MemoryUnit" class="select-unit">
                    <option value="1" selected>MB</option>
                    <option value="1024">GB</option>
                  </select>
                </div>
                <p id="max-ram-label" class="text-[10px] text-neutral-500 font-semibold">Max Allocation: <%= resourceLimits.maxMemory %> MB</p>
              </div>

              <!-- CPU -->
              <div class="space-y-2">
                <label class="form-label flex items-center gap-1.5 text-neutral-300">
                  <%- icon('cpu', { width: 14, height: 14 }) %>
                  CPU Cores (%)
                </label>
                <div class="stepper">
                  <button type="button" class="stepper-btn" data-action="dec" data-target="Cpu" data-step="50" data-min="50">−</button>
                  <input id="Cpu" type="number" value="100" min="50" max="<%= resourceLimits.maxCpu %>" class="stepper-input">
                  <button type="button" class="stepper-btn" data-action="inc" data-target="Cpu" data-step="50" data-max="100">+</button>
                </div>
                <p id="max-cpu-label" class="text-[10px] text-neutral-500 font-semibold">Max Allocation: <%= resourceLimits.maxCpu %>%</p>
              </div>

              <!-- Storage -->
              <div class="space-y-2">
                <label class="form-label flex items-center gap-1.5 text-neutral-300">
                  <%- icon('hard-drive', { width: 14, height: 14 }) %>
                  Disk Space (Storage)
                </label>
                <input type="hidden" id="Storage" value="5120">
                <div class="flex items-stretch">
                  <button type="button" class="stepper-btn border border-r-0 border-white/10 rounded-l-xl bg-white/5" data-action="dec" data-target="StorageDisplay" data-step="1" data-min="1">−</button>
                  <input id="StorageDisplay" type="number" value="5" min="1" class="stepper-input border-y border-white/10">
                  <button type="button" class="stepper-btn border-y border-white/10 bg-white/5" data-action="inc" data-target="StorageDisplay" data-step="1">+</button>
                  <select id="StorageUnit" class="select-unit">
                    <option value="1">MB</option>
                    <option value="1024" selected>GB</option>
                  </select>
                </div>
                <p id="max-disk-label" class="text-[10px] text-neutral-500 font-semibold">Max Allocation: <%= Math.round(resourceLimits.maxStorage / 1024) %> GB</p>
              </div>
            </div>

            <!-- Custom Port requirements indicator -->
            <div id="portRequirementsContainer" class="pt-2">
              <label class="form-label">Port Requirements</label>
              <button type="button" id="assignPortsBtn" class="cs-trigger bg-white/5 border border-white/10 hover:bg-white/10">
                <span id="assignPortsLabel">Inspect required ports</span>
              </button>
            </div>

            <div class="pt-4 border-t border-white/5 flex justify-between">
              <button onclick="prevStep(2)" class="px-5 py-2.5 rounded-xl bg-white/5 border border-white/10 text-neutral-300 hover:bg-white/10 text-xs font-bold transition cursor-pointer">Back</button>
              <button onclick="nextStep(4)" class="px-5 py-2.5 rounded-xl bg-brand-green text-black hover:bg-brand-green-hover text-xs font-bold transition cursor-pointer">Continue to Summary</button>
            </div>
          </div>
        </div>

        <!-- WIZARD STEP 4: SUMMARY & LAUNCH -->
        <div class="wizard-pane space-y-6 hidden" data-step="4">
          <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
            
            <!-- Details fields -->
            <div class="md:col-span-7 space-y-6">
              <%- include('../components/ui/Card', { hover: false, class: 'p-6 border border-white/5 space-y-4' }) %>
                <div>
                  <h2 class="text-sm font-bold text-white">General Server Settings</h2>
                  <p class="text-xs text-neutral-400 mt-0.5">Label your server so you can identify it in the panel dashboard.</p>
                </div>
                
                <div class="space-y-4">
                  <div class="space-y-1">
                    <label class="form-label" for="serverName">Server Name</label>
                    <input id="serverName" type="text" placeholder="My Minecraft World" maxlength="64" class="form-input">
                  </div>
                  <div class="space-y-1">
                    <label class="form-label" for="serverDescription">Description <span class="text-neutral-500">(optional)</span></label>
                    <input id="serverDescription" type="text" placeholder="Play with friends!" maxlength="128" class="form-input">
                  </div>
                </div>
              </div>
            </div>

            <!-- Summary panel -->
            <div class="md:col-span-5">
              <%- include('../components/ui/Card', { hover: false, class: 'p-6 border border-brand-green/20 shadow-[0_0_20px_rgba(255,255,255,0.02)] space-y-6' }) %>
                <div>
                  <h3 class="text-xs font-bold uppercase tracking-widest text-brand-green">Launch Summary</h3>
                  <h2 class="text-xl font-bold text-white mt-1">Ready for Deploy</h2>
                </div>

                <div class="space-y-3.5 text-xs text-neutral-300">
                  <div class="flex justify-between">
                    <span class="text-neutral-500">Node Location</span>
                    <span class="text-white font-bold" id="summaryNode">Not Chosen</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-neutral-500">Memory Limit</span>
                    <span class="text-white font-bold" id="summaryRAM">1024 MB</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-neutral-500">CPU Allocation</span>
                    <span class="text-white font-bold" id="summaryCPU">100%</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-neutral-500">Deploy Duration</span>
                    <span class="text-brand-green font-bold" id="summaryDeployTime">queued for install</span>
                  </div>
                </div>

                <!-- Submit trigger -->
                <button type="button" id="createBtn"
                  class="w-full inline-flex items-center justify-center gap-2 rounded-xl bg-brand-green px-4 py-2.5 text-sm font-bold text-black hover:bg-brand-green-hover hover:scale-[1.02] hover:shadow-[0_0_20px_var(--color-mono-focus)] active:scale-95 transition-all duration-200 cursor-pointer">
                  <span id="createBtnText">Launch Server</span>
                  <span id="createBtnSpinner" class="hidden w-4 h-4 border-2 border-black/30 border-t-black rounded-full animate-spin"></span>
                </button>
              </div>
            </div>
          </div>

          <!-- Error Banner -->
          <div id="errorMsg" class="hidden rounded-xl bg-red-500/10 border border-red-500/20 px-5 py-4">
            <p class="text-sm font-semibold text-red-400" id="errorText"></p>
          </div>

          <!-- Back button -->
          <div class="flex">
            <button onclick="prevStep(3)" class="px-5 py-2.5 rounded-xl bg-white/5 border border-white/10 text-neutral-300 hover:bg-white/10 text-xs font-bold transition cursor-pointer">Back</button>
          </div>
        </div>

      </div>
    </div>
  </div>
</main>

<!-- Ports Inspection Modal -->
<div class="confirm-overlay" id="portsOverlay">
  <div class="confirm-box">
    <div class="flex justify-between items-center pb-3 border-b border-white/5 mb-4">
      <h3 class="text-sm font-bold text-white">Required Connection Ports</h3>
      <button class="text-neutral-400 hover:text-white" onclick="document.getElementById('portsOverlay').classList.remove('open')">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <div id="requiredPortsList" class="space-y-2"></div>
    <div class="flex justify-end mt-6">
      <button id="portsOk" class="px-4 py-2 rounded-xl text-xs font-bold bg-white/5 border border-white/10 text-white hover:bg-white/10 transition cursor-pointer">Dismiss</button>
    </div>
  </div>
</div>

<!-- Custom confirmation Modal -->
<div class="confirm-overlay" id="confirmOverlay">
  <div class="confirm-box">
    <h3 class="text-sm font-bold text-white mb-2" id="confirmTitle">Confirm</h3>
    <p class="text-xs text-neutral-400 leading-relaxed mb-6" id="confirmBody"></p>
    <div class="flex gap-2.5 justify-end">
      <button id="confirmCancel" class="px-4 py-2 rounded-xl text-xs font-bold bg-transparent text-neutral-400 border border-white/10 hover:bg-white/5 cursor-pointer">Cancel</button>
      <button id="confirmOk" class="px-4 py-2 rounded-xl text-xs font-bold bg-brand-green text-black hover:bg-brand-green-hover cursor-pointer">Confirm</button>
    </div>
  </div>
</div>

<%- include('../components/toast') %>
<%- include('../components/loadingPopup') %>

<script nonce="<%- nonce %>">
  let activeWizardStep = 1;

  window.setInstanceType = function(type) {
    document.getElementById('instanceType').value = type;
    const btnMinecraft = document.getElementById('btnMinecraft');
    const btnLXC = document.getElementById('btnLXC');
    const minecraftFields = document.getElementById('minecraftFields');
    const lxcFields = document.getElementById('lxcFields');
    const portRequirementsContainer = document.getElementById('portRequirementsContainer');

    if (type === 'MINECRAFT') {
      btnMinecraft.className = "flex-1 flex items-center justify-center gap-2 px-4 py-3 rounded-xl border-2 border-brand-green bg-brand-green/10 text-brand-green font-bold text-sm transition-all duration-200 cursor-pointer";
      btnLXC.className = "flex-1 flex items-center justify-center gap-2 px-4 py-3 rounded-xl border border-white/10 bg-white/5 text-neutral-400 font-bold text-sm transition-all duration-200 cursor-pointer hover:border-white/20 hover:text-white";
      minecraftFields.classList.remove('hidden');
      lxcFields.classList.add('hidden');
      if (portRequirementsContainer) portRequirementsContainer.classList.remove('hidden');
    } else {
      btnMinecraft.className = "flex-1 flex items-center justify-center gap-2 px-4 py-3 rounded-xl border border-white/10 bg-white/5 text-neutral-400 font-bold text-sm transition-all duration-200 cursor-pointer hover:border-white/20 hover:text-white";
      btnLXC.className = "flex-1 flex items-center justify-center gap-2 px-4 py-3 rounded-xl border-2 border-brand-green bg-brand-green/10 text-brand-green font-bold text-sm transition-all duration-200 cursor-pointer";
      minecraftFields.classList.add('hidden');
      lxcFields.classList.remove('hidden');
      if (portRequirementsContainer) portRequirementsContainer.classList.add('hidden');
    }
  };

  function nextStep(step) {
    // Basic validation before shifting step
    if (step === 2) {
      const type = document.getElementById('instanceType').value;
      if (type === 'MINECRAFT') {
        const img = document.getElementById('imageId').value;
        const variant = document.getElementById('dockerImage').value;
        if (!img || !variant) {
          if (typeof showToast === 'function') {
            showToast('Please select software image and version first.', 'error');
          }
          return;
        }
      } else {
        const os = document.getElementById('osTemplate').value;
        if (!os) {
          if (typeof showToast === 'function') {
            showToast('Please select OS Template first.', 'error');
          }
          return;
        }
      }
    }
    
    if (step === 3) {
      const node = document.getElementById('nodeId').value;
      if (!node) {
        if (typeof showToast === 'function') {
          showToast('Please choose a node location for deployment.', 'error');
        }
        return;
      }
    }

    if (step === 4) {
      // Compile final launch summary
      const nodeSelect = document.getElementById('nodeId');
      const nodeName = nodeSelect.options[nodeSelect.selectedIndex]?.text || 'Not chosen';
      const ramVal = document.getElementById('Memory').value + ' MB';
      const cpuVal = document.getElementById('Cpu').value + '%';

      document.getElementById('summaryNode').textContent = nodeName;
      document.getElementById('summaryRAM').textContent = ramVal;
      document.getElementById('summaryCPU').textContent = cpuVal;
    }

    // Hide all panes
    document.querySelectorAll('.wizard-pane').forEach(p => p.classList.add('hidden'));
    
    // Show target step
    document.querySelector('.wizard-pane[data-step="' + step + '"]').classList.remove('hidden');
    
    // Update WizardStep indicators
    updateWizardStepsUI(step);
      
    activeWizardStep = step;
  }

  function prevStep(step) {
    document.querySelectorAll('.wizard-pane').forEach(p => p.classList.add('hidden'));
    document.querySelector('.wizard-pane[data-step="' + step + '"]').classList.remove('hidden');
    
    // Update WizardStep indicators
    updateWizardStepsUI(step);

    activeWizardStep = step;
  }

  function updateWizardStepsUI(step) {
    const stepNumbers = [1, 2, 3, 4];
    stepNumbers.forEach(num => {
      const el = document.querySelector('[data-step-indicator="' + num + '"]');
      const text = document.querySelector('[data-step-text="' + num + '"]');
      const line = document.querySelector('[data-step-line="' + num + '"]');
      
      if (!el) return;

      if (step === num) {
        el.className = "w-8 h-8 rounded-full flex items-center justify-center font-bold text-xs bg-brand-green text-black shadow-[0_0_15px_var(--color-mono-focus)] transition-all duration-300";
        if(text) text.className = "text-xs font-semibold uppercase tracking-wider text-white transition-all duration-300";
      } else if (step > num) {
        el.className = "w-8 h-8 rounded-full flex items-center justify-center font-bold text-xs bg-brand-green/20 text-brand-green border border-brand-green/30 transition-all duration-300";
        if(text) text.className = "text-xs font-semibold uppercase tracking-wider text-neutral-500 transition-all duration-300";
      } else {
        el.className = "w-8 h-8 rounded-full flex items-center justify-center font-bold text-xs bg-white/5 text-neutral-500 border border-white/5 transition-all duration-300";
        if(text) text.className = "text-xs font-semibold uppercase tracking-wider text-neutral-500 transition-all duration-300";
      }

      if (line) {
        if (step > num) {
          line.className = "flex-1 h-[1px] mx-4 bg-brand-green/20 transition-all duration-300";
        } else {
          line.className = "flex-1 h-[1px] mx-4 bg-white/5 transition-all duration-300";
        }
      }
    });
  }
</script>

