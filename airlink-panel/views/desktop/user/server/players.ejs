<%- include('../../components/header', { title: 'Players' }) %>

<main class="h-screen m-auto text-neutral-800 dark:text-white">
  <div class="flex h-screen">
    <!-- Sidebar -->
    <aside class="w-60 h-full">
      <%- include('../../components/template') %>
    </aside>

    <!-- Main Content -->
    <section id="page-content" class="flex-1 p-6 overflow-y-auto pt-16">
      <!-- Page Header -->
      <header class="sm:flex sm:items-center px-8 pt-4">
        <%- include('../../components/serverHeader') %>
      </header>

      <%- include('../../components/installHeader') %>
            <!-- Error Message -->
      <% if (errorMessage && errorMessage.message) { %>
          <div class="bg-neutral-100 dark:bg-neutral-500/20 border border-neutral-200 dark:border-transparent p-4 ml-8 mr-8 mt-4 rounded-xl flex items-start space-x-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="size-6 mt-2 ml-1 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg> 
      <div>
        <p class="text-neutral-800 dark:text-white"><%= req.translations.connectionError || 'Error' %></p>
        <p class="text-sm text-neutral-600 dark:text-neutral-400"><%= errorMessage.message %></p>
      </div>
    </div>
      <% } %>

      <!-- Daemon down message removed as requested -->

      <!-- Server Template -->
      <%- include('../../components/serverTemplate', { features: ['players', 'worlds'] }) %>

      <%- include('../../components/toast') %>

      <div id="server-page-body">

      <!-- Players Section -->
      <div class="px-6">
        <!-- Server Info Card -->
        <div class="bg-neutral-100 dark:bg-neutral-800/50 rounded-xl p-6 mb-6 shadow-lg">
          <div class="flex flex-col md:flex-row justify-between items-center mb-4">
            <div>
              <h2 class="text-xl font-semibold text-neutral-800 dark:text-white mb-1"><%= req.translations.players || 'Players' %></h2>
              <p class="text-neutral-600 dark:text-neutral-400 text-sm">
                <% if (typeof serverInfo !== 'undefined') { %>
                  <span class="font-medium"><%= serverInfo.onlinePlayers || 0 %></span> / <span><%= serverInfo.maxPlayers || 0 %></span> players online
                  <% if (serverInfo.version) { %>
                    • <span class="text-neutral-500">Version: <%= serverInfo.version %></span>
                  <% } %>
                <% } else { %>
                  Manage your server's player list
                <% } %>
              </p>
            </div>
          </div>

          <!-- Auto-refresh notice -->
          <div class="text-xs text-neutral-500 mb-4 flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            <span>
              Refreshing in <span id="refresh-countdown">30</span> seconds
              <button onclick="window.location.reload()" class="ml-2 text-blue-400 hover:text-blue-300 transition-colors duration-200 inline-flex items-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                Refresh now
              </button>
            </span>
          </div>
        </div>

        <!-- Players Grid -->
        <% if (players && players.length > 0) { %>
        <div id="PlayersGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
          <% players.forEach(player => { %>
            <div class="relative p-4 bg-neutral-100 dark:bg-neutral-800 rounded-xl shadow-lg group hover:bg-neutral-200/60 dark:hover:bg-neutral-700/50 transition-all duration-200 cursor-pointer"
                 data-uuid="<%= player.uuid %>"
                 data-name="<%= player.name %>"
                 onclick="openPlayerDetail('<%= player.uuid %>')">
              <div class="flex items-center">
                <img
                  src="https://crafatar.com/avatars/<%= player.uuid %>?size=64&overlay"
                  alt="<%= player.name %>'s Avatar"
                  class="rounded-lg border border-neutral-700 mr-4"
                  width="64"
                  height="64"
                />
                <div>
                  <p class="text-lg font-bold text-neutral-800 dark:text-white"><%= player.name %></p>
                  <div class="flex items-center mt-1">
                    <span class="inline-flex h-2 w-2 rounded-full bg-green-500 mr-2"></span>
                    <span class="text-xs text-neutral-500 dark:text-neutral-400"><%= req.translations.online || 'Online' %></span>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
        <% } else { %>
          <div id="no-players-message" class="bg-neutral-100 dark:bg-neutral-800/30 rounded-xl p-8 text-center">
            <% if (!serverIsOnline && errorMessage && errorMessage.message) { %>
              <!-- Server Offline Message -->
              <div class="flex justify-center mb-6">
                <div class="w-16 h-16 rounded-full bg-neutral-200 dark:bg-neutral-700/50 flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m3 3 8.735 8.735m0 0a.374.374 0 1 1 .53.53m-.53-.53.53.53m0 0L21 21M14.652 9.348a3.75 3.75 0 0 1 0 5.304m2.121-7.425a6.75 6.75 0 0 1 0 9.546m2.121-11.667c3.808 3.807 3.808 9.98 0 13.788m-9.546-4.242a3.733 3.733 0 0 1-1.06-2.122m-1.061 4.243a6.75 6.75 0 0 1-1.625-6.929m-.496 9.05c-3.068-3.067-3.664-7.67-1.79-11.334M12 12h.008v.008H12V12Z" />
                  </svg>
                </div>
              </div>
              <h2 class="text-xl font-semibold text-neutral-700 dark:text-neutral-300"><%= req.translations.serverOffline || 'Server Offline' %></h2>
              <p class="mt-2 text-sm text-neutral-500 max-w-md mx-auto">
                The server appears to be offline. Start your server to see online players.
              </p>
              <div class="mt-6">
                <button onclick="window.location.reload()" class="px-4 py-2 bg-neutral-800 dark:bg-neutral-700 text-white rounded-lg shadow hover:bg-neutral-600 transition-all duration-200 inline-flex items-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                  </svg>
                  Refresh
                </button>
              </div>
            <% } else if (serverIsOnline) { %>
              <!-- Server Online but No Players Message -->
              <div class="flex justify-center mb-6">
                <div class="w-16 h-16 rounded-full bg-green-700/20 flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h.01M12 12h.01M19 12h.01M6 12a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0z" />
                  </svg>
                </div>
              </div>
              <h2 class="text-xl font-semibold text-neutral-700 dark:text-neutral-300"><%= req.translations.serverOnline || 'Server is online' %></h2>
              <p class="mt-2 text-sm text-neutral-500 max-w-md mx-auto">
                Your server is running but no players are currently connected. Players will appear here when they join.
              </p>
              <div class="mt-4 text-sm text-neutral-600 dark:text-neutral-400">
                <div class="flex items-center justify-center gap-4">
                  <div>
                    <span class="font-semibold">Version:</span> <%= serverInfo.version %>
                  </div>
                  <div>
                    <span class="font-semibold">Capacity:</span> <%= serverInfo.onlinePlayers %>/<%= serverInfo.maxPlayers %>
                  </div>
                </div>
              </div>
            <% } else { %>
              <!-- Unknown Status Message -->
              <div class="flex justify-center mb-6">
                <div class="w-16 h-16 rounded-full bg-yellow-700/20 flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
              </div>
              <h2 class="text-xl font-semibold text-neutral-700 dark:text-neutral-300"><%= req.translations.statusUnknown || 'Status Unknown' %></h2>
              <p class="mt-2 text-sm text-neutral-500 max-w-md mx-auto">
                We couldn't determine if your server is online. It may be starting up or in an unusual state.
              </p>
            <% } %>
          </div>
        <% } %>
      </div>

      <!-- Player detail modal -->
      <div id="playerModal" class="fixed inset-0 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-200" aria-hidden="true">
        <div class="absolute inset-0 bg-black/60" id="playerModalBackdrop"></div>
        <div id="playerModalPanel" role="dialog" aria-modal="true" class="relative bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-700/60 rounded-2xl shadow-2xl w-full max-w-2xl mx-4 transform scale-95 transition-transform duration-200 max-h-[90vh] overflow-y-auto">
          <div class="flex flex-col md:flex-row p-5 gap-5">
            <!-- Skin canvas -->
            <div class="flex-shrink-0 flex flex-col items-center">
              <canvas id="skinCanvas" width="300" height="400" class="rounded-xl bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/60"></canvas>
              <img id="skinFallback" class="hidden rounded-xl border border-neutral-200 dark:border-neutral-700/60" width="100" height="100" />
            </div>

            <!-- Player info + actions -->
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between mb-4">
                <div>
                  <h3 id="playerModalName" class="text-lg font-bold text-neutral-800 dark:text-white"></h3>
                  <p id="playerModalUuid" class="text-xs text-neutral-500 dark:text-neutral-400 font-mono mt-0.5"></p>
                  <p id="playerModalStatus" class="text-xs mt-1"></p>
                </div>
                <button onclick="closePlayerModal()" class="text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-300 transition">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
              </div>

              <div class="flex flex-wrap gap-2 mb-4">
                <button id="actionOp" class="px-4 py-2 text-xs font-medium rounded-xl bg-amber-500/20 text-amber-700 dark:text-amber-400 hover:bg-amber-500/30 transition"><%= req.translations.playerMakeOp || 'Make OP' %></button>
                <button id="actionBan" class="px-4 py-2 text-xs font-medium rounded-xl bg-red-500/20 text-red-700 dark:text-red-400 hover:bg-red-500/30 transition"><%= req.translations.playerBan || 'Ban' %></button>
                <button id="actionIpBan" class="px-4 py-2 text-xs font-medium rounded-xl bg-red-500/20 text-red-700 dark:text-red-400 hover:bg-red-500/30 transition"><%= req.translations.playerIpBan || 'IP Ban' %></button>
                <button id="actionKill" class="px-4 py-2 text-xs font-medium rounded-xl bg-orange-500/20 text-orange-700 dark:text-orange-400 hover:bg-orange-500/30 transition"><%= req.translations.playerKill || 'Kill' %></button>
              </div>

              <!-- Typed confirm sub-dialog -->
              <div id="typedConfirm" class="hidden bg-neutral-50 dark:bg-neutral-800/50 rounded-xl p-4 border border-neutral-200 dark:border-neutral-700/60">
                <p id="typedConfirmBody" class="text-sm text-neutral-700 dark:text-neutral-300 mb-3"></p>
                <input type="text" id="typedConfirmInput" placeholder="Type player name..." class="w-full px-3 py-2 text-sm rounded-lg border border-neutral-300 dark:border-neutral-600 bg-white dark:bg-neutral-800 text-neutral-800 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 mb-2" />
                <textarea id="typedConfirmReason" placeholder="<%= req.translations.playerReasonLabel || 'Reason (optional)' %>" rows="2" class="w-full px-3 py-2 text-sm rounded-lg border border-neutral-300 dark:border-neutral-600 bg-white dark:bg-neutral-800 text-neutral-800 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 mb-3"></textarea>
                <div class="flex gap-2 justify-end">
                  <button id="typedConfirmCancel" class="px-4 py-2 text-xs font-medium rounded-xl bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition"><%= req.translations.playerCancelLabel || 'Cancel' %></button>
                  <button id="typedConfirmSubmit" disabled class="px-4 py-2 text-xs font-medium rounded-xl bg-red-600 hover:bg-red-500 text-white transition"><%= req.translations.playerConfirmLabel || 'Confirm' %></button>
                </div>
              </div>

              <!-- Result toast area -->
              <div id="playerActionResult" class="hidden text-sm mt-3"></div>
            </div>
          </div>
        </div>
      </div>

      <script src="https://cdn.jsdelivr.net/npm/skinview3d@latest/dist/skinview3d.bundle.js"></script>

      <!-- Player data -->
      <script nonce="<%- nonce %>">
        var PLAYERS = <%- JSON.stringify(players) %>;
        var CSRF_TOKEN = '<%= csrfToken %>';
        var SERVER_ID = '<%= server.UUID %>';
        var TRANSLATIONS = {
          online: '<%= req.translations.playerOnline || "Online" %>',
          offline: '<%= req.translations.playerOffline || "Offline" %>',
          confirmOp: '<%= req.translations.playerConfirmOp || "Make {player} a server operator?" %>',
          confirmKill: '<%= req.translations.playerKill || "Kill {player}? They will be kicked from the server." %>',
          confirmBanTitle: '<%= req.translations.playerConfirmBanTitle || "Ban Player" %>',
          confirmBanBody: '<%= req.translations.playerConfirmBanBody || "Type the player name to confirm the ban" %>',
          confirmIpBanTitle: '<%= req.translations.playerConfirmIpBanTitle || "IP Ban Player" %>',
          confirmIpBanBody: '<%= req.translations.playerConfirmIpBanBody || "Player is online. Type their name to confirm the IP ban" %>',
          actionSuccess: '<%= req.translations.playerActionSuccess || "Action sent to server" %>',
          actionError: '<%= req.translations.playerActionError || "Failed to execute action" %>',
          ipBanOffline: '<%= req.translations.playerIpBanDisabled || "Player must be online to IP ban" %>',
          skinError: '<%= req.translations.playerSkinError || "Could not load skin preview" %>',
        };
      </script>

      <!-- Player interaction JS -->
      <script nonce="<%- nonce %>">
        var playerViewer = null;
        var currentPlayer = null;
        var pendingAction = null;

        function getPlayerByUuid(uuid) {
          for (var i = 0; i < PLAYERS.length; i++) {
            if (PLAYERS[i].uuid === uuid) return PLAYERS[i];
          }
          return null;
        }

        function openPlayerDetail(uuid) {
          currentPlayer = uuid;
          var player = getPlayerByUuid(uuid);
          if (!player) return;

          document.getElementById('playerModalName').textContent = player.name;
          document.getElementById('playerModalUuid').textContent = player.uuid;
          var statusEl = document.getElementById('playerModalStatus');
          statusEl.innerHTML = '<span class="inline-flex h-2 w-2 rounded-full bg-green-500 mr-1"></span> ' + TRANSLATIONS.online;

          // Enable/disable IP ban button
          var ipBanBtn = document.getElementById('actionIpBan');
          ipBanBtn.disabled = false;
          ipBanBtn.title = '';

          // Reset typed confirm
          hideTypedConfirm();

          var overlay = document.getElementById('playerModal');
          var panel = document.getElementById('playerModalPanel');
          overlay.setAttribute('aria-hidden', 'false');
          overlay.classList.remove('opacity-0', 'pointer-events-none');
          panel.classList.remove('scale-95');
          panel.classList.add('scale-100');

          initSkinViewer(player.uuid);
        }

        function closePlayerModal() {
          var overlay = document.getElementById('playerModal');
          var panel = document.getElementById('playerModalPanel');
          overlay.setAttribute('aria-hidden', 'true');
          overlay.classList.add('opacity-0', 'pointer-events-none');
          panel.classList.remove('scale-100');
          panel.classList.add('scale-95');
          disposeSkinViewer();
          hideTypedConfirm();
          currentPlayer = null;
          pendingAction = null;
        }

        function initSkinViewer(uuid) {
          var canvas = document.getElementById('skinCanvas');
          var fallback = document.getElementById('skinFallback');
          canvas.classList.remove('hidden');
          fallback.classList.add('hidden');

          if (typeof skinview3d === 'undefined') {
            showSkinFallback(uuid);
            return;
          }

          var url = 'https://crafatar.com/skins/' + uuid;

          try {
            playerViewer = new skinview3d.SkinViewer({
              canvas: canvas,
              width: 300,
              height: 400,
              skin: url,
            });
            playerViewer.controls.enableRotate = true;
            playerViewer.controls.enableZoom = false;
          } catch (e) {
            showSkinFallback(uuid);
          }
        }

        function showSkinFallback(uuid) {
          var canvas = document.getElementById('skinCanvas');
          var fallback = document.getElementById('skinFallback');
          canvas.classList.add('hidden');
          fallback.src = 'https://crafatar.com/avatars/' + uuid + '?size=100&overlay';
          fallback.classList.remove('hidden');
        }

        function disposeSkinViewer() {
          if (playerViewer) {
            try { playerViewer.dispose(); } catch (e) { /* ignore */ }
            playerViewer = null;
          }
        }

        function hideTypedConfirm() {
          document.getElementById('typedConfirm').classList.add('hidden');
          document.getElementById('typedConfirmInput').value = '';
          document.getElementById('typedConfirmReason').value = '';
          document.getElementById('typedConfirmSubmit').disabled = true;
          document.getElementById('typedConfirmSubmit').onclick = null;
          pendingAction = null;
        }

        function showTypedConfirm(title, body, action, reasonRequired) {
          pendingAction = action;
          document.getElementById('typedConfirmBody').textContent = body;
          document.getElementById('typedConfirm').classList.remove('hidden');
          var input = document.getElementById('typedConfirmInput');
          var submitBtn = document.getElementById('typedConfirmSubmit');
          input.value = '';
          submitBtn.disabled = true;

          input.oninput = function() {
            var player = getPlayerByUuid(currentPlayer);
            submitBtn.disabled = (input.value.trim() !== (player ? player.name : ''));
          };

          submitBtn.onclick = function() {
            var reason = document.getElementById('typedConfirmReason').value.trim() || undefined;
            executeAction(currentPlayer, action, reason);
            hideTypedConfirm();
          };

          setTimeout(function() { input.focus(); }, 100);
        }

        function executeAction(uuid, action, reason) {
          var player = getPlayerByUuid(uuid);
          if (!player) return;

          var body = { uuid: uuid, action: action, playerName: player.name };
          if (reason) body.reason = reason;

          fetch('/server/' + SERVER_ID + '/players/api/action', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'x-csrf-token': CSRF_TOKEN },
            body: JSON.stringify(body),
          })
          .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
          .then(function(res) {
            if (res.ok) {
              showToast(TRANSLATIONS.actionSuccess, 'success');
              setTimeout(closePlayerModal, 1500);
            } else {
              showToast(res.data.error || TRANSLATIONS.actionError, 'error');
            }
          })
          .catch(function() {
            showToast(TRANSLATIONS.actionError, 'error');
          });
        }

        // Event listeners
        document.addEventListener('DOMContentLoaded', function() {
          document.getElementById('playerModalBackdrop').addEventListener('click', closePlayerModal);
          document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closePlayerModal();
          });

          document.getElementById('typedConfirmCancel').addEventListener('click', hideTypedConfirm);

          document.getElementById('actionOp').addEventListener('click', function() {
            var player = getPlayerByUuid(currentPlayer);
            if (!player) return;
            if (window.modal && typeof window.modal.confirm === 'function') {
              window.modal.confirm({
                title: TRANSLATIONS.confirmOp,
                body: '',
                danger: false,
                confirmLabel: '<%= req.translations.playerMakeOp || "Make OP" %>',
                onConfirm: function() { executeAction(currentPlayer, 'op'); }
              });
            } else {
              executeAction(currentPlayer, 'op');
            }
          });

          document.getElementById('actionKill').addEventListener('click', function() {
            var player = getPlayerByUuid(currentPlayer);
            if (!player) return;
            if (window.modal && typeof window.modal.confirm === 'function') {
              window.modal.confirm({
                title: TRANSLATIONS.confirmKill.replace('{player}', player.name),
                body: '',
                danger: true,
                confirmLabel: '<%= req.translations.playerKill || "Kill" %>',
                onConfirm: function() { executeAction(currentPlayer, 'kill'); }
              });
            } else {
              executeAction(currentPlayer, 'kill');
            }
          });

          document.getElementById('actionBan').addEventListener('click', function() {
            var player = getPlayerByUuid(currentPlayer);
            if (!player) return;
            showTypedConfirm(
              TRANSLATIONS.confirmBanTitle,
              TRANSLATIONS.confirmBanBody,
              'ban',
              false
            );
          });

          document.getElementById('actionIpBan').addEventListener('click', function() {
            var player = getPlayerByUuid(currentPlayer);
            if (!player) return;
            showTypedConfirm(
              TRANSLATIONS.confirmIpBanTitle,
              TRANSLATIONS.confirmIpBanBody,
              'ipban',
              false
            );
          });
        });
      </script>

      <!-- Auto-refresh script -->
      <script nonce="<%- nonce %>">
        (function() {
          const hasError = <%= errorMessage && errorMessage.message ? 'true' : 'false' %>;
          const refreshInterval = hasError ? 60000 : 30000;

          if (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1') {
            console.log('Player list will refresh in ' + (refreshInterval/1000) + ' seconds');
          }

          setTimeout(function() {
            window.location.reload();
          }, refreshInterval);

          var startTime = Date.now();
          var timerElement = document.getElementById('refresh-countdown');

          if (timerElement) {
            (function updateTimer() {
              var elapsed = Date.now() - startTime;
              var remaining = Math.max(0, Math.floor((refreshInterval - elapsed) / 1000));
              timerElement.textContent = remaining;
              if (remaining > 0) {
                requestAnimationFrame(updateTimer);
              }
            })();
          }
        })();
      </script>
    </section>
  
      </div><!-- /server-page-body -->

      </div>
</main>

<%- include('../../components/footer') %>
