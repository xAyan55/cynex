<%- include('../components/header', { title: 'Dashboard' }) %>

<style>
  ::-webkit-scrollbar { display: none; }
  @keyframes al-view-in { from { opacity:0; transform:translateY(4px); } to { opacity:1; transform:translateY(0); } }
  .vt-active { background: rgba(255, 255, 255, 0.08) !important; color: white !important; }
  .fc-fc-drag-over { border-color: #22c55e !important; background: rgba(34, 197, 94, 0.08) !important; box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.2) !important; }
  .sc-dragging { opacity: 0.45; transform: scale(0.97); box-shadow: none !important; }
  .ov-open { opacity: 1 !important; pointer-events: auto !important; }
</style>

<main class="h-screen m-auto bg-[#07070a] text-white">
  <div class="flex h-screen">
    <div class="w-60 h-full"><%- include('../components/template') %></div>

    <div id="page-content" class="flex-1 overflow-y-auto pt-16">
      <div class="px-12 pt-8 pb-12 space-y-8">

        <!-- Top Overview Stats Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <% 
            const totalCount = servers.length;
            const onlineCount = servers.filter(s => s.status === 'running').length;
            const totalMemoryAllocated = servers.reduce((sum, s) => sum + s.Memory, 0);
            const ramText = totalMemoryAllocated >= 1024 ? `${(totalMemoryAllocated/1024).toFixed(1)} GB` : `${totalMemoryAllocated} MB`;
          %>
          <%- include('../components/ui/StatCard', { title: 'Total Servers', value: totalCount, icon: 'server', color: 'green' }) %>
          <%- include('../components/ui/StatCard', { title: 'Online Servers', value: onlineCount, icon: 'activity', color: 'purple' }) %>
          <%- include('../components/ui/StatCard', { title: 'Memory Allocated', value: ramText, icon: 'cpu', color: 'blue' }) %>
        </div>

        <!-- Header Controls Row -->
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 bg-white/[0.01] border border-white/5 p-6 rounded-2xl">
          <div>
            <h1 class="text-xl font-bold tracking-tight text-white"><%= req.translations.userDashboardTitle || "My Servers" %></h1>
            <p class="text-sm text-neutral-400 mt-1"><%= req.translations.userDashboardText || "Provision, access, and manage your servers." %></p>
          </div>
          
          <div class="flex items-center gap-3 w-full sm:w-auto">
            <% if (canCreateServer) { %>
              <%- include('../components/ui/Button', { variant: 'primary', label: '<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg> Create Server', href: '/create-server' }) %>
            <% } %>
            
            <button id="newFolderBtn" class="inline-flex items-center gap-2 rounded-xl bg-white/5 border border-white/10 hover:bg-white/10 hover:text-white px-4 py-2.5 text-sm font-semibold transition-all cursor-pointer">
              <svg class="w-4 h-4 text-neutral-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 13h6m-3-3v6m-9 1V4a2 2 0 012-2h6l2 2h7a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
              New Folder
            </button>

            <% if (servers && servers.length > 0) { %>
              <div class="flex items-center gap-1 bg-white/5 p-1 rounded-xl border border-white/5">
                <button id="gridViewBtn" class="vt-active p-1.5 rounded-lg text-neutral-400 hover:text-white transition duration-200 cursor-pointer" title="Grid View">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                </button>
                <button id="listViewBtn" class="p-1.5 rounded-lg text-neutral-400 hover:text-white transition duration-200 cursor-pointer" title="List View">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
                </button>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Alert notifications -->
        <% if (req.query.err === 'NOTACTIVEYET') { %>
          <div class="rounded-xl bg-amber-500/10 border border-amber-500/20 px-5 py-4">
            <p class="text-sm font-semibold text-amber-400">Server is currently deploying.</p>
            <p class="text-xs text-neutral-400 mt-1">This server is pulling the Docker configuration. It will be online shortly.</p>
          </div>
        <% } %>
        <% if (req.query.err === 'SERVER_LIMIT_REACHED') { %>
          <div class="rounded-xl bg-red-500/10 border border-red-500/20 px-5 py-4">
            <p class="text-sm font-semibold text-red-400">Server Limit Reached.</p>
            <p class="text-xs text-neutral-400 mt-1">You have reached the server creation slots allowed for this plan tier. Upgrade to gain more slots.</p>
          </div>
        <% } %>
        <% if (typeof daemonOffline !== 'undefined' && daemonOffline) { %>
          <div class="rounded-xl bg-red-500/10 border border-red-500/20 px-5 py-4 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
            <div>
              <p class="text-sm font-semibold text-red-400">Node Connectivity Warning</p>
              <p class="text-xs text-neutral-400 mt-1">One or more of the server nodes are unreachable. Some metrics may temporarily fail to load.</p>
            </div>
            <button onclick="window.location.reload()" class="px-4 py-2 bg-red-500 hover:bg-red-600 text-black text-xs font-bold rounded-xl transition cursor-pointer">Retry Connection</button>
          </div>
        <% } %>

        <% if (servers.length === 0 && (!folders || folders.length === 0)) { %>
          <div class="flex flex-col items-center justify-center py-20 text-center cynex-glass rounded-2xl border border-white/5">
            <div class="w-16 h-16 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center mb-6">
              <%- icon('server', { class: 'h-8 w-8 text-neutral-400' }) %>
            </div>
            <h2 class="text-base font-bold text-white">No Minecraft Servers Found</h2>
            <p class="text-sm text-neutral-400 mt-2 max-w-sm">
              Deploy your first free server slot instantly or ask your panel administrator to allocate one for you.
            </p>
            <% if (canCreateServer) { %>
              <%- include('../components/ui/Button', { variant: 'primary', label: 'Create a Server Now', href: '/create-server', class: 'mt-6' }) %>
            <% } %>
          </div>
        <% } else { %>

          <!-- Folders list -->
          <% if (folders && folders.length > 0) { %>
            <div class="space-y-4">
              <p class="text-xs font-bold uppercase tracking-wider text-neutral-500">Folders</p>
              <div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 gap-4" id="folderGrid">
                <% let folderIdx = 0; folders.forEach(folder => { %>
                  <div class="flex items-center gap-4 cynex-glass border border-white/5 rounded-2xl px-5 py-4 cursor-pointer relative transition duration-300 hover:border-white/15 select-none group"
                    role="button"
                    tabindex="0"
                    aria-label="Open folder <%= folder.name %>"
                    style="--i:<%= folderIdx++ %>"
                    data-folder-id="<%= folder.id %>"
                    data-folder-name="<%= folder.name %>"
                    data-folder-members='<%= JSON.stringify(folder.members.map(m => m.serverUUID)) %>'>
                    <div class="p-2.5 rounded-xl bg-amber-500/10 border border-amber-500/20 text-amber-400 shrink-0">
                      <%- icon('folder', { class: 'h-5 w-5 shrink-0', fill: 'currentColor' }) %>
                    </div>
                    <div class="min-w-0 flex-1">
                      <p class="text-sm font-bold text-white truncate"><%= folder.name %></p>
                      <p class="text-xs text-neutral-400 mt-0.5"><%= folder.members.length %> Server<%= folder.members.length !== 1 ? 's' : '' %></p>
                    </div>
                  </div>
                <% }); %>
              </div>
              <p class="text-xs text-neutral-500">Tip: Drag and drop a server card onto a folder to organize your workspaces.</p>
            </div>
          <% } %>

          <!-- Servers Grid view -->
          <div class="space-y-4">
            <p class="text-xs font-bold uppercase tracking-wider text-neutral-500">Servers</p>
            
            <div id="gridView" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6">
              <% let serverIdx = 0; servers.forEach(server => { %>
                <%
                  const inFolder = folders && folders.some(f => f.members.some(m => m.serverUUID === server.UUID));
                  if (inFolder) return;
                %>
                <!-- Render EJS server card component -->
                <div class="cursor-grab active:cursor-grabbing"
                  data-server-uuid="<%= server.UUID %>"
                  data-server-name="<%= server.name %>"
                  style="--i:<%= serverIdx++ %>"
                  draggable="true">
                  <%- include('../components/ui/ServerCard', { server }) %>
                </div>
              <% }); %>
            </div>

            <!-- List view -->
            <div id="listView" class="cynex-glass rounded-2xl border border-white/5 overflow-hidden shadow-2xl hidden">
              <table class="min-w-full divide-y divide-white/5">
                <thead class="bg-white/[0.02]">
                  <tr>
                    <th class="py-4 pl-6 pr-3 text-left text-xs font-bold text-neutral-400 uppercase tracking-wider">Server</th>
                    <th class="px-3 py-4 text-left text-xs font-bold text-neutral-400 uppercase tracking-wider">Status</th>
                    <th class="px-3 py-4 text-left text-xs font-bold text-neutral-400 uppercase tracking-wider">Owner</th>
                    <th class="px-3 py-4 text-left text-xs font-bold text-neutral-400 uppercase tracking-wider">RAM Usage</th>
                    <th class="px-3 py-4 text-left text-xs font-bold text-neutral-400 uppercase tracking-wider">CPU Allocation</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                  <% let listIdx = 0; servers.forEach(server => { %>
                    <% const inFolderL = folders && folders.some(f => f.members.some(m => m.serverUUID === server.UUID)); if (inFolderL) return; %>
                    <tr style="--i:<%= listIdx++ %>" data-href="../server/<%= server.UUID %>" role="link" tabindex="0" class="hover:bg-white/[0.02] cursor-pointer transition-colors">
                      <td class="py-4 pl-6 pr-3 flex items-center gap-3">
                        <div class="p-2 bg-brand-green/10 rounded-lg text-brand-green">
                          <%- icon('terminal', { class: 'w-4 h-4' }) %>
                        </div>
                        <div>
                          <p class="text-sm font-bold text-white truncate"><%= server.name %></p>
                          <% if (server.description) { %><p class="text-xs text-neutral-400 truncate max-w-xs"><%= server.description %></p><% } %>
                        </div>
                      </td>
                      <td class="px-3 py-4">
                        <%- include('../components/ui/Badge', { status: server.status, label: server.status === 'running' ? 'Online' : 'Offline' }) %>
                      </td>
                      <td class="px-3 py-4 text-sm font-medium text-neutral-300"><%= server.owner ? server.owner.username : 'Unknown' %></td>
                      <td class="px-3 py-4 text-sm font-medium text-neutral-300"><%= Math.round(Number(server.ramUsage || 0)) %>%</td>
                      <td class="px-3 py-4 text-sm font-medium text-neutral-300"><%= Math.round(Number(server.cpuUsage || 0)) %>%</td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>

            <!-- Pagination -->
            <% if (totalPages > 1) { %>
              <div class="flex items-center justify-center gap-4 mt-8">
                <% if (currentPage > 1) { %>
                  <a href="/dashboard?page=<%= currentPage - 1 %>" class="px-4 py-2 text-xs font-bold text-neutral-300 bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 transition-all">Prev</a>
                <% } %>
                <span class="text-xs font-semibold text-neutral-400"><%= currentPage %> / <%= totalPages %></span>
                <% if (currentPage < totalPages) { %>
                  <a href="/dashboard?page=<%= currentPage + 1 %>" class="px-4 py-2 text-xs font-bold text-neutral-300 bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 transition-all">Next</a>
                <% } %>
              </div>
            <% } %>

          </div>
        <% } %>
      </div>
    </div>
  </div>
</main>

<!-- Drag ghost element -->
<div id="drag-ghost" class="fixed z-[70] pointer-events-none bg-[#0c0c14] border border-white/10 rounded-xl px-4 py-3 text-xs font-bold text-white shadow-2xl flex items-center gap-2.5 opacity-90 max-w-[200px]" style="display:none; transform:rotate(2deg)">
  <%- icon('folder', { class: 'w-4 h-4 text-amber-500 shrink-0', fill: 'currentColor' }) %>
  <span id="drag-ghost-name"></span>
</div>

<!-- Folder popup -->
<div class="fixed inset-0 z-[80] bg-black/70 backdrop-blur-md flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity data-[open]:opacity-100 data-[open]:pointer-events-auto" id="folderPopupOverlay">
  <div class="cynex-glass rounded-2xl w-full max-w-[480px] max-h-[75vh] flex flex-col scale-[0.96] opacity-0 transition-[transform,opacity] duration-200 overflow-hidden [[data-open]>&]:scale-100 [[data-open]>&]:opacity-100 border border-white/10 shadow-2xl" role="dialog" aria-modal="true" aria-labelledby="folderPopupTitle">
    <div class="flex items-center justify-between px-6 py-4 border-b border-white/5 flex-shrink-0 bg-white/[0.01]">
      <h2 class="text-sm font-bold text-white" id="folderPopupTitle"></h2>
      <div class="flex items-center gap-1.5">
        <button id="deleteFolderBtn" class="w-9 h-9 flex items-center justify-center rounded-lg hover:bg-red-500/10 text-red-400 transition cursor-pointer" title="Delete Folder">
          <%- icon('trash-2', { class: 'w-4 h-4', strokeWidth: 1.5 }) %>
        </button>
        <button id="closeFolderPopup" class="w-9 h-9 flex items-center justify-center rounded-lg hover:bg-white/5 text-neutral-400 transition cursor-pointer">
          <%- icon('x', { class: 'w-4 h-4' }) %>
        </button>
      </div>
    </div>
    <div class="flex-1 overflow-y-auto p-5">
      <div id="folderPopupContent" class="grid grid-cols-1 gap-2.5"></div>
    </div>
  </div>
</div>

<!-- New folder dialog -->
<div class="fixed inset-0 z-[90] bg-black/70 backdrop-blur-md flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity data-[open]:opacity-100 data-[open]:pointer-events-auto" id="newFolderOverlay">
  <div class="cynex-glass rounded-2xl w-full max-w-[400px] p-6 border border-white/10 scale-[0.96] opacity-0 transition-[transform,opacity] duration-200 shadow-2xl" role="dialog" aria-modal="true" aria-labelledby="newFolderTitle">
    <p id="newFolderTitle" class="text-base font-bold text-white mb-1">New Folder</p>
    <p class="text-xs text-neutral-400 mb-5">Give your folder a name. Drag server cards onto it to group workspaces.</p>
    <input id="newFolderName" type="text" class="w-full border border-white/10 rounded-xl bg-white/5 px-4 py-2.5 text-sm text-white outline-none font-[inherit] transition focus:border-brand-green/20 placeholder:text-neutral-500 box-border mb-6" placeholder="e.g. My Modded Servers">
    <div class="flex gap-2.5 justify-end">
      <button id="cancelNewFolder" class="px-4 py-2 rounded-xl text-xs font-bold bg-transparent text-neutral-400 border border-white/10 hover:bg-white/5 cursor-pointer transition">Cancel</button>
      <button id="confirmNewFolder" class="px-4 py-2 rounded-xl text-xs font-bold bg-brand-green text-black hover:bg-brand-green-hover cursor-pointer transition">Create</button>
    </div>
  </div>
</div>

<!-- Delete folder confirm dialog -->
<div class="fixed inset-0 z-[90] bg-black/70 backdrop-blur-md flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity data-[open]:opacity-100 data-[open]:pointer-events-auto" id="deleteFolderOverlay">
  <div class="cynex-glass rounded-2xl w-full max-w-[400px] p-6 border border-white/10 scale-[0.96] opacity-0 transition-[transform,opacity] duration-200 shadow-2xl" role="dialog" aria-modal="true" aria-labelledby="deleteFolderTitle">
    <p id="deleteFolderTitle" class="text-base font-bold text-white mb-1">Delete Folder?</p>
    <p class="text-xs text-neutral-400 mb-5">Servers inside will remain safe. They will just be returned to the main server view list.</p>
    <div class="flex gap-2.5 justify-end">
      <button id="cancelDeleteFolder" class="px-4 py-2 rounded-xl text-xs font-bold bg-transparent text-neutral-400 border border-white/10 hover:bg-white/5 cursor-pointer transition">Cancel</button>
      <button id="confirmDeleteFolder" class="px-4 py-2 rounded-xl text-xs font-bold bg-red-600 hover:bg-red-700 text-white cursor-pointer transition">Delete Folder</button>
    </div>
  </div>
</div>

<%- include('../components/toast') %>

<div id="dashboard-data" class="hidden"></div>
<script nonce="<%- nonce %>">
  document.getElementById('dashboard-data').dataset.folders = '<%- JSON.stringify(folders || []).replace(/'/g, "\\'") %>';
  document.getElementById('dashboard-data').dataset.servers = '<%- JSON.stringify((allServers || []).map(s => ({ UUID: s.UUID, name: s.name, status: s.status, ramUsage: s.ramUsage, cpuUsage: s.cpuUsage }))).replace(/'/g, "\\'") %>';
</script>

<script nonce="<%- nonce %>">
  // Quick power actions handler
  function handleQuickPower(event, uuid, action) {
    if (event) {
      event.preventDefault();
      event.stopPropagation();
    }
    
    if (typeof showToast === 'function') {
      showToast('Sending action: ' + action.toUpperCase() + '...', 'info');
    }

    fetch('/server/' + uuid + '/power/' + action, {
      method: 'POST'
    })
    .then(function(res) { return res.json(); })
    .then(function(data) {
      if (data.success || !data.error) {
        if (typeof showToast === 'function') {
          showToast('Power command ' + action.toUpperCase() + ' sent successfully!', 'success');
        }
        setTimeout(function() { window.location.reload(); }, 1200);
      } else {
        if (typeof showToast === 'function') {
          showToast(data.error || 'Power request failed', 'error');
        }
      }
    })
    .catch(function(err) {
      if (typeof showToast === 'function') {
        showToast('Network error triggering power action.', 'error');
      }
    });
  }
</script>

<script nonce="<%- nonce %>" src="/javascript/dashboard.js"></script>

<%- include('../components/footer') %>
