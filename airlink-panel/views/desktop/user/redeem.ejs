<%- include('../components/header', { title: 'Redeem' }) %>
<main class="h-screen m-auto bg-mono-bg text-white">
  <div class="flex h-screen">
    <div class="w-60 h-full"><%- include('../components/template') %></div>
    <div id="page-content" class="flex-1 overflow-y-auto pt-16">
      <div class="px-12 pt-8 pb-12 space-y-8 max-w-2xl">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-xl font-bold tracking-tight text-white">Redeem Coupon</h1>
            <p class="text-sm text-neutral-400 mt-1">Enter a coupon code to claim rewards.</p>
          </div>
          <div class="flex items-center gap-2 bg-white/5 border border-white/10 rounded-xl px-4 py-2.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-amber-400" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1.41 16.09V20h-2.67v-1.93c-1.71-.36-3.16-1.46-3.27-3.4h1.96c.1 1.05.82 1.87 2.65 1.87 1.96 0 2.4-.98 2.4-1.59 0-.83-.44-1.61-2.67-2.14-2.48-.6-4.18-1.62-4.18-3.67 0-1.72 1.39-2.84 3.11-3.21V4h2.67v1.95c1.86.45 2.79 1.86 2.85 3.39H14.3c-.05-1.11-.64-1.87-2.22-1.87-1.5 0-2.4.68-2.4 1.64 0 .84.65 1.39 2.67 1.91s4.18 1.39 4.18 3.91c-.01 1.83-1.38 2.83-3.12 3.16z"/></svg>
            <span class="text-sm font-bold text-white"><%= balance.toLocaleString() %> coins</span>
          </div>
        </div>

        <%- renderPlacement('redeemTop') %>

        <% if (error) { %>
          <div class="rounded-xl bg-red-500/10 border border-red-500/20 px-5 py-4 animate-shake">
            <p class="text-sm font-semibold text-red-400"><%= error %></p>
          </div>
        <% } %>

        <% if (success) { %>
          <div class="rounded-xl bg-brand-green/10 border border-brand-green/20 px-5 py-4 animate-bounce">
            <p class="text-sm font-semibold text-brand-green">Coupon redeemed successfully!</p>
            <p class="text-xs text-neutral-400 mt-1 font-medium">You received <%= success.rewardAmount %> of <%= success.rewardType %>.</p>
          </div>
        <% } %>

        <%- renderPlacement('redeemMiddle') %>

        <!-- Ticket Shape Card -->
        <div class="cynex-glass rounded-3xl border border-white/5 p-8 relative overflow-hidden shadow-2xl hover:border-white/10 transition-all duration-300 group">
          <!-- Ticket Side Cutouts -->
          <div class="absolute -left-3 top-1/2 -translate-y-1/2 w-6 h-6 rounded-full bg-mono-bg border border-white/5 z-20"></div>
          <div class="absolute -right-3 top-1/2 -translate-y-1/2 w-6 h-6 rounded-full bg-mono-bg border border-white/5 z-20"></div>

          <!-- Ambient blur bg -->
          <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-purple-500/5 rounded-full blur-3xl"></div>

          <form id="redeemForm" method="POST" action="/redeem" class="space-y-6 relative z-10">
            <div class="text-center pb-4 border-b border-dashed border-white/10">
              <h2 class="text-base font-bold text-white uppercase tracking-wider">Voucher Ticket</h2>
              <p class="text-xs text-neutral-500 mt-1">Claim your bonus coins or subscription keys</p>
            </div>
            
            <div>
              <label class="text-xs font-bold text-neutral-400 block mb-2 uppercase tracking-wider">Coupon Code</label>
              <input type="text" name="code" placeholder="ENTER CODE HERE" required
                class="w-full border border-white/10 rounded-xl bg-white/5 px-4 py-3.5 text-sm text-white text-center outline-none focus:border-brand-green/30 placeholder:text-neutral-500 font-mono uppercase tracking-widest box-border">
            </div>
            
            <button type="submit" id="redeemBtn" class="w-full px-4 py-3.5 rounded-xl text-sm font-bold bg-brand-green text-black hover:bg-brand-green-hover transition duration-300 cursor-pointer">
              Redeem Code
            </button>
          </form>
        </div>

        <%- renderPlacement('redeemBelow') %>
      </div>
    </div>
  </div>
</main>
<script nonce="<%- nonce %>">
  document.getElementById('redeemForm')?.addEventListener('submit', function() {
    const btn = document.getElementById('redeemBtn');
    if (btn) {
      btn.disabled = true;
      btn.textContent = 'VALIDATING TICKET...';
      btn.className = 'w-full px-4 py-3.5 rounded-xl text-sm font-bold bg-white/5 border border-white/10 text-neutral-400 cursor-not-allowed';
    }
  });
</script>
<%- include('../components/footer') %>