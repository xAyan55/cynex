<%- include('../components/header', { title: 'Billing & Upgrades' }) %>

<main class="h-screen m-auto bg-[#07070a] text-white">
  <div class="flex h-screen">
    <div class="w-60 h-full shrink-0"><%- include('../components/template') %></div>
    
    <div id="page-content" class="flex-1 overflow-y-auto pt-16 pb-12">
      <div class="px-12 pt-8 pb-12 space-y-8 max-w-6xl">
        
        <!-- Header Title -->
        <div>
          <h1 class="text-xl font-bold tracking-tight text-white">Billing & Plan Tiers</h1>
          <p class="text-sm text-neutral-400 mt-1">Upgrade your server capacity, dedicated RAM, and remove active queues.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 items-start">
          
          <!-- Current Active Plan Summary Card -->
          <div class="md:col-span-1">
            <%- include('../components/ui/Card', { hover: false, class: 'space-y-6 border border-brand-green/20 shadow-[0_0_20px_rgba(34,197,94,0.05)]' }) %>
              <div>
                <h3 class="text-xs font-bold uppercase tracking-widest text-brand-green">Active Subscription</h3>
                <h2 class="text-2xl font-bold text-white mt-1.5"><%= currentPlan.name %></h2>
                <p class="text-xs text-neutral-400 mt-0.5">Renewed monthly</p>
              </div>

              <!-- Resource Capping Bars -->
              <div class="space-y-4 pt-2">
                <div class="space-y-1">
                  <div class="flex justify-between text-xs font-semibold text-neutral-400">
                    <span>Server Slots</span>
                    <span class="text-white"><%= user.serverLimit %> Slots</span>
                  </div>
                  <%- include('../components/ui/Progress', { value: (user.serverLimit / 6) * 100, color: 'green' }) %>
                </div>
                <div class="space-y-1">
                  <div class="flex justify-between text-xs font-semibold text-neutral-400">
                    <span>RAM Capacity</span>
                    <span class="text-white"><%= (user.maxMemory >= 1024) ? (user.maxMemory/1024).toFixed(0)+'GB' : user.maxMemory+'MB' %></span>
                  </div>
                  <%- include('../components/ui/Progress', { value: (user.maxMemory / 8192) * 100, color: 'purple' }) %>
                </div>
                <div class="space-y-1">
                  <div class="flex justify-between text-xs font-semibold text-neutral-400">
                    <span>Storage limit</span>
                    <span class="text-white"><%= (user.maxStorage >= 1024) ? (user.maxStorage/1024).toFixed(0)+'GB' : user.maxStorage+'MB' %></span>
                  </div>
                  <%- include('../components/ui/Progress', { value: (user.maxStorage / 30720) * 100, color: 'blue' }) %>
                </div>
              </div>

              <!-- Included Features checklist -->
              <div class="space-y-3 pt-4 border-t border-white/5 text-xs text-neutral-400">
                <p class="font-bold text-neutral-300 uppercase tracking-wide">Included Features</p>
                <% currentPlan.features.forEach(f => { %>
                  <div class="flex items-center gap-2">
                    <%- icon('check', { class: 'w-3.5 h-3.5 text-brand-green shrink-0' }) %>
                    <span><%= f %></span>
                  </div>
                <% }); %>
              </div>
            </div>
          </div>

          <!-- Upgrade Options Grid -->
          <div class="md:col-span-2 space-y-6">
            <h2 class="text-sm font-bold uppercase tracking-wider text-neutral-500">Available Upgrades</h2>

            <div class="grid sm:grid-cols-2 gap-6">
              <% Object.keys(plans).forEach(planKey => { 
                const plan = plans[planKey];
                // Hide free plan from upgrades list if they already have something else
                if (planKey === 'free') return;
                const isActive = currentPlan.name === plan.name;
              %>
                <%- include('../components/ui/Card', { hover: true, glow: planKey === 'starter' ? 'green' : 'purple', class: isActive ? 'border-brand-green/20' : '' }) %>
                  <div class="flex flex-col justify-between h-full space-y-6">
                    <div class="space-y-4">
                      <div class="flex justify-between items-start">
                        <div>
                          <h3 class="font-bold text-white text-lg"><%= plan.name %></h3>
                          <p class="text-xs text-neutral-400 mt-0.5"><%= planKey === 'starter' ? 'Casual server play' : 'Large communities & mods' %></p>
                        </div>
                        <% if (isActive) { %>
                          <%- include('../components/ui/Badge', { status: 'online', label: 'Active' }) %>
                        <% } %>
                      </div>

                      <div class="flex items-baseline gap-1">
                        <span class="text-4xl font-extrabold text-white">$<%= plan.priceMonthly %></span>
                        <span class="text-neutral-500 text-xs">/ month</span>
                      </div>

                      <ul class="space-y-2.5 text-xs text-neutral-400 pt-2 border-t border-white/5">
                        <% plan.features.forEach(f => { %>
                          <li class="flex items-center gap-2">
                            <%- icon('check', { class: 'w-3.5 h-3.5 text-brand-green shrink-0' }) %>
                            <span><%= f %></span>
                          </li>
                        <% }); %>
                      </ul>
                    </div>

                    <% if (isActive) { %>
                      <button disabled class="w-full py-2 bg-white/5 border border-white/5 rounded-xl text-xs font-bold text-neutral-500 cursor-not-allowed">
                        Currently Subscribed
                      </button>
                    <% } else { %>
                      <button onclick="confirmUpgrade('<%= planKey %>', '<%= plan.name %>')" class="w-full py-2.5 bg-brand-green text-black hover:bg-brand-green-hover text-xs font-bold rounded-xl transition duration-200 cursor-pointer">
                        Upgrade to <%= plan.name %>
                      </button>
                    <% } %>
                  </div>
                </div>
              <% }); %>
            </div>
          </div>

        </div>

      </div>
    </div>
  </div>
</main>

<!-- Purchase Confirmation Modal -->
<%- include('../components/ui/Modal', { id: 'upgradeModal', title: 'Confirm Plan Upgrade' }) %>
  <div class="space-y-6 text-sm text-neutral-300">
    <p>You are about to upgrade your CynexGP subscription plan to <span id="targetPlanName" class="font-bold text-white"></span>.</p>
    
    <div class="cynex-glass bg-white/[0.01] border border-white/5 rounded-xl p-4 space-y-2 text-xs">
      <div class="flex justify-between">
        <span>Payment Method</span>
        <span class="text-white font-semibold flex items-center gap-1"><%- icon('credit-card', { class: 'w-3.5 h-3.5' }) %> Mock Checkout (Stripe Ready)</span>
      </div>
      <div class="flex justify-between border-t border-white/5 pt-2 mt-2">
        <span>Invoice Amount</span>
        <span class="text-brand-green font-bold" id="planInvoiceAmount">$0.00</span>
      </div>
    </div>

    <p class="text-xs text-neutral-500 leading-relaxed">By confirming, your account parameters will be updated in the database immediately, and server creation queue rate-limits will adjust accordingly.</p>
    
    <div class="flex gap-2.5 justify-end pt-2">
      <button class="px-4 py-2 rounded-xl text-xs font-bold bg-transparent text-neutral-400 border border-white/10 hover:bg-white/5 cursor-pointer" onclick="closeModal()">Cancel</button>
      <button id="confirmUpgradeBtn" class="px-5 py-2.5 rounded-xl text-xs font-bold bg-brand-green text-black hover:bg-brand-green-hover cursor-pointer" onclick="executeUpgrade()">Confirm & Update</button>
    </div>
  </div>
</div>

<%- include('../components/toast') %>

<script nonce="<%- nonce %>">
  let selectedPlanKey = '';

  function confirmUpgrade(planKey, planName) {
    selectedPlanKey = planKey;
    document.getElementById('targetPlanName').textContent = planName;
    document.getElementById('planInvoiceAmount').textContent = planKey === 'starter' ? '$3.99' : '$7.99';
    document.getElementById('upgradeModal').classList.remove('hidden');
  }

  function closeModal() {
    document.getElementById('upgradeModal').classList.add('hidden');
  }

  function executeUpgrade() {
    const btn = document.getElementById('confirmUpgradeBtn');
    btn.disabled = true;
    btn.textContent = 'Processing...';

    if (typeof showToast === 'function') {
      showToast('Processing mock subscription...', 'info');
    }

    fetch('/billing/upgrade', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({ planKey: selectedPlanKey })
    })
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        if (typeof showToast === 'function') {
          showToast('Upgrade successful!', 'success');
        }
        setTimeout(() => {
          window.location.reload();
        }, 1200);
      } else {
        if (typeof showToast === 'function') {
          showToast(data.error || 'Failed to process upgrade.', 'error');
        }
        btn.disabled = false;
        btn.textContent = 'Confirm & Update';
      }
    })
    .catch(() => {
      if (typeof showToast === 'function') {
        showToast('Network error during checkout check.', 'error');
      }
      btn.disabled = false;
      btn.textContent = 'Confirm & Update';
    });
  }
</script>

<%- include('../components/footer') %>
