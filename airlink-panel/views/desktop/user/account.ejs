<%- include('../components/header', { title: req.translations.userAccountTitle || 'Account' }) %>

<style>
</style>

<main class="h-screen m-auto bg-mono-bg text-white">
  <div class="flex h-screen">
    <div class="w-60 h-full shrink-0">
      <%- include('../components/template') %>
    </div>
    
    <div id="page-content" class="flex-1 overflow-y-auto pt-16 pb-12">
      <div class="px-12 pt-8 pb-12 space-y-8 max-w-5xl">
        
        <!-- Header / Profile picture row -->
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6 bg-white/[0.01] border border-white/5 p-6 rounded-2xl">
          <div class="flex items-center gap-5">
            <!-- Avatar -->
            <div class="relative shrink-0">
              <img id="avatar-preview"
                src="<%= user.avatar ? user.avatar : 'https://api.dicebear.com/9.x/thumbs/svg?seed=' + encodeURIComponent(user.username) %>"
                alt="Avatar"
                class="h-14 w-14 rounded-2xl border border-white/5 object-cover">
              <!-- Upload button -->
              <label for="avatar-input" title="Upload photo"
                class="absolute -bottom-1.5 -right-1.5 w-6 h-6 flex items-center justify-center rounded-full bg-brand-green text-black border-2 border-mono-bg cursor-pointer hover:bg-brand-green-hover transition shadow-lg">
                <%- icon('upload', { class: 'w-3 h-3 text-black', strokeWidth: 2.5 }) %>
              </label>
              <input id="avatar-input" type="file" accept="image/*" class="hidden">
              <!-- Delete button — only when avatar set -->
              <% if (user.avatar) { %>
              <button id="remove-avatar-btn" type="button" title="Remove photo"
                class="absolute -top-1.5 -right-1.5 w-6 h-6 flex items-center justify-center rounded-full bg-red-600 hover:bg-red-500 border-2 border-mono-bg transition cursor-pointer shadow-lg">
                <%- icon('x', { class: 'w-3 h-3 text-white', strokeWidth: 2.5 }) %>
              </button>
              <% } %>
            </div>
            
            <div class="min-w-0 flex-1">
              <h1 class="text-xl font-bold tracking-tight text-white"><%= req.translations.userAccountTitle || 'Account Settings' %></h1>
              <p class="text-sm text-neutral-400 mt-1"><%= req.translations.userAccountText || 'Update your profile information and account preferences.' %></p>
            </div>
          </div>
          
          <a href="/credits" class="inline-flex items-center gap-2 rounded-xl bg-white/5 border border-white/10 hover:bg-white/10 hover:text-white px-4 py-2.5 text-xs font-semibold text-neutral-300 transition-all shrink-0">
            <%- icon('circle-alert', { class: 'w-3.5 h-3.5' }) %>
            Credits
          </a>
        </div>

        <!-- Account Settings Card Grid -->
        <%- include('../components/ui/Card', { hover: false, class: 'p-8 border border-white/5' }) %>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            
            <!-- Username -->
            <form id="change-username-form" action="/change-username" method="POST" class="space-y-2">
              <%- include('../components/csrf') %>
              <label class="flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-neutral-400"><%- icon('user', { class: 'w-3.5 h-3.5 text-neutral-400' }) %> Username</label>
              <div class="flex gap-2">
                <input id="username" type="text" name="username" placeholder="<%= user.username %>"
                  class="w-full border border-white/10 rounded-xl bg-white/5 px-4 py-2 text-sm text-white outline-none focus:border-brand-green/20 transition-all">
                <button type="submit" id="change-username-btn" disabled
                  class="px-4 py-2 rounded-xl text-xs font-bold bg-brand-green text-black hover:bg-brand-green-hover disabled:opacity-40 disabled:cursor-not-allowed shrink-0 transition-all cursor-pointer">
                  Save
                </button>
              </div>
              <span id="username-feedback" class="text-[11px] text-neutral-500 font-semibold"><%= req.translations.checking || 'Checking...' %></span>
            </form>

            <!-- Email -->
            <form id="change-email-form" class="space-y-2">
              <%- include('../components/csrf') %>
              <label class="flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-neutral-400"><%- icon('mail', { class: 'w-3.5 h-3.5 text-neutral-400' }) %> Email Address</label>
              <div class="flex gap-2">
                <input id="email" type="email" name="email" placeholder="<%= user.email %>"
                  class="w-full border border-white/10 rounded-xl bg-white/5 px-4 py-2 text-sm text-white outline-none focus:border-brand-green/20 transition-all">
                <button type="submit"
                  class="px-4 py-2 rounded-xl text-xs font-bold bg-brand-green text-black hover:bg-brand-green-hover shrink-0 transition-all cursor-pointer">
                  Save
                </button>
              </div>
            </form>

            <!-- Change Password -->
            <form id="change-password-form" class="col-span-1 md:col-span-2 space-y-3">
              <%- include('../components/csrf') %>
              <label class="flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-neutral-400"><%- icon('lock', { class: 'w-3.5 h-3.5 text-neutral-400' }) %> Change Password</label>
              
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <span id="current-password-feedback" class="text-[11px] text-neutral-500 font-semibold block mb-1"><%= req.translations.checking || 'Current security code check' %></span>
                  <input id="currentPassword" type="password" name="currentPassword" placeholder="Current Password"
                    class="w-full border border-white/10 rounded-xl bg-white/5 px-4 py-2 text-sm text-white outline-none focus:border-brand-green/20 transition-all">
                </div>
                <div>
                  <span class="text-[11px] text-transparent block mb-1">.</span>
                  <input id="newPassword" type="password" name="newPassword" placeholder="New Password" disabled
                    class="w-full border border-white/10 rounded-xl bg-white/5 px-4 py-2 text-sm text-white outline-none focus:border-brand-green/20 transition-all disabled:opacity-40">
                </div>
              </div>
              
              <button type="submit" class="px-5 py-2.5 rounded-xl text-xs font-bold bg-brand-green text-black hover:bg-brand-green-hover transition cursor-pointer">
                <%= req.translations.update_password || 'Update Password' %>
              </button>
            </form>

            <!-- Description -->
            <form id="change-description-form" class="col-span-1 md:col-span-2 space-y-2">
              <%- include('../components/csrf') %>
              <label class="flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-neutral-400"><%- icon('file-text', { class: 'w-3.5 h-3.5 text-neutral-400' }) %> About Me / Description</label>
              <textarea id="description" name="description" rows="2"
                class="w-full border border-white/10 rounded-xl bg-white/5 px-4 py-2.5 text-sm text-white outline-none focus:border-brand-green/20 transition-all resize-none"
                placeholder="<%= user.description %>"><%= user.description %></textarea>
              <button type="submit" class="px-4 py-2.5 rounded-xl text-xs font-bold bg-brand-green text-black hover:bg-brand-green-hover transition cursor-pointer">
                Save
              </button>
            </form>

            <!-- Language preference -->
            <form id="language-preference-form" class="space-y-2">
              <%- include('../components/csrf') %>
              <label class="flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-neutral-400"><%- icon('globe', { class: 'w-3.5 h-3.5 text-neutral-400' }) %> Language Preference</label>
              <select id="language" name="language"
                class="w-full border border-white/10 rounded-xl bg-[#0c0c14] px-4 py-2 text-sm text-white outline-none focus:border-brand-green/20 transition-all mb-2">
                <option value="en"  <%= req.lang === 'en'  ? 'selected' : '' %>>English</option>
                <option value="fr"  <%= req.lang === 'fr'  ? 'selected' : '' %>>Français</option>
                <option value="de"  <%= req.lang === 'de'  ? 'selected' : '' %>>Deutsch</option>
                <option value="es"  <%= req.lang === 'es'  ? 'selected' : '' %>>Español</option>
                <option value="pt"  <%= req.lang === 'pt'  ? 'selected' : '' %>>Português</option>
                <option value="it"  <%= req.lang === 'it'  ? 'selected' : '' %>>Italiano</option>
                <option value="ru"  <%= req.lang === 'ru'  ? 'selected' : '' %>>Русский</option>
                <option value="zh"  <%= req.lang === 'zh'  ? 'selected' : '' %>>中文</option>
                <option value="ja"  <%= req.lang === 'ja'  ? 'selected' : '' %>>日本語</option>
                <option value="ta"  <%= req.lang === 'ta'  ? 'selected' : '' %>>தமிழ்</option>
              </select>
              <button type="submit"
                class="px-4 py-2 rounded-xl text-xs font-bold bg-brand-green text-black hover:bg-brand-green-hover transition cursor-pointer">
                Save
              </button>
            </form>

            <!-- Two-Factor Security -->
            <div class="space-y-2">
              <label class="flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-neutral-400"><%- icon('shield', { class: 'w-3.5 h-3.5 text-neutral-400' }) %> Two-Factor Authentication</label>
              <% if (user['2fa'] !== true) { %>
                <p class="text-xs text-neutral-500 font-semibold leading-relaxed">Securing your panel logins with authenticator apps. 2FA is currently setup ready for admin-enforce protocols.</p>
              <% } else { %>
                <form action="/disable-2fa" method="POST">
                  <%- include('../components/csrf') %>
                  <button class="px-4 py-2 rounded-xl text-xs font-bold bg-red-500/10 border border-red-500/20 text-red-400 hover:bg-red-500/20 transition cursor-pointer">
                    Disable Two-Factor Auth
                  </button>
                </form>
              <% } %>
            </div>

          </div>
        </div>

        <!-- Login History Activity Log -->
        <%- include('../components/ui/Card', { hover: false, class: 'p-6 border border-white/5' }) %>
          <h2 class="text-sm font-bold uppercase tracking-wider text-neutral-400 mb-4">Login history</h2>
          <div class="overflow-x-auto rounded-xl border border-white/5">
            <table class="min-w-full text-sm divide-y divide-white/5">
              <thead class="bg-white/[0.01]">
                <tr>
                  <th class="px-5 py-3 text-left text-xs font-bold text-neutral-400 uppercase tracking-wider">Date & Time</th>
                  <th class="px-5 py-3 text-left text-xs font-bold text-neutral-400 uppercase tracking-wider">IP Address</th>
                  <th class="px-5 py-3 text-left text-xs font-bold text-neutral-400 uppercase tracking-wider">Browser & Device</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/5">
                <% if (loginHistory && loginHistory.length > 0) { %>
                  <% let loginIdx = 0; loginHistory.forEach(login => { %>
                  <tr style="--i:<%= loginIdx++ %>" class="hover:bg-white/[0.01] transition-colors">
                    <td class="px-5 py-3.5 text-neutral-300 whitespace-nowrap text-xs font-medium"><%= new Date(login.timestamp).toLocaleString() %></td>
                    <td class="px-5 py-3.5 text-brand-green whitespace-nowrap font-mono text-xs"><%= login.ipAddress || 'Unknown' %></td>
                    <td class="px-5 py-3.5 text-neutral-400 text-xs truncate max-w-[260px]"><%= login.userAgent || 'Unknown' %></td>
                  </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="3" class="px-5 py-6 text-center text-xs font-semibold text-neutral-500">No login attempts recorded on this account.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </div>
  </div>
</main>

<%- include('../components/toast') %>

<script nonce="<%- nonce %>">
document.addEventListener('DOMContentLoaded', () => {
  const { showToast } = createToastSystem();
  const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');
  let submitting = false;

  async function post(url, data) {
    if (submitting) return;
    submitting = true;
    try {
      const res = await fetch(url, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'CSRF-Token': csrfToken,
        },
        body: JSON.stringify(data),
      });
      submitting = false;
      return res;
    } catch (e) {
      submitting = false;
      showToast('Network error, please try again.', 'error');
    }
  }

  // Username validation
  const usernameInput = document.getElementById('username');
  const usernameFeedback = document.getElementById('username-feedback');
  const usernameBtn = document.getElementById('change-username-btn');
  let checkTimeout;

  usernameFeedback.textContent = '';

  usernameInput?.addEventListener('input', () => {
    const username = usernameInput.value.trim();
    usernameBtn.disabled = true;
    clearTimeout(checkTimeout);

    if (!username) {
      usernameFeedback.textContent = '';
      return;
    }

    if (username.length < 3) {
      usernameFeedback.textContent = 'Username must be at least 3 characters.';
      usernameFeedback.className = 'mt-1 text-[11px] text-red-400 inline-block';
      return;
    }

    usernameFeedback.textContent = 'Checking availability...';
    usernameFeedback.className = 'mt-1 text-[11px] text-neutral-500 inline-block';

    checkTimeout = setTimeout(async () => {
      try {
        const res = await fetch(`/check-username?username=${encodeURIComponent(username)}`);
        const data = await res.json();
        if (data.available) {
          usernameFeedback.textContent = 'Username is available.';
          usernameFeedback.className = 'mt-1 text-[11px] text-brand-green inline-block';
          usernameBtn.disabled = false;
        } else {
          usernameFeedback.textContent = 'Username is already taken.';
          usernameFeedback.className = 'mt-1 text-[11px] text-red-400 inline-block';
        }
      } catch {
        usernameFeedback.textContent = 'Could not verify username.';
      }
    }, 500);
  });

  // Password validation
  const currentPassInput = document.getElementById('currentPassword');
  const newPassInput = document.getElementById('newPassword');
  const passFeedback = document.getElementById('current-password-feedback');
  let passTimeout;

  passFeedback.textContent = 'Confirm current password to activate new password field.';
  passFeedback.className = 'text-[11px] text-neutral-500 font-semibold block mb-1';

  currentPassInput?.addEventListener('input', () => {
    const password = currentPassInput.value;
    newPassInput.disabled = true;
    clearTimeout(passTimeout);

    if (!password) {
      passFeedback.textContent = 'Confirm current password to activate new password field.';
      passFeedback.className = 'text-[11px] text-neutral-500 font-semibold block mb-1';
      return;
    }

    passTimeout = setTimeout(async () => {
      try {
        const res = await fetch(`/check-password?password=${encodeURIComponent(password)}`);
        const data = await res.json();
        if (data.correct) {
          passFeedback.textContent = 'Current password verified.';
          passFeedback.className = 'text-[11px] text-brand-green font-semibold block mb-1';
          newPassInput.disabled = false;
        } else {
          passFeedback.textContent = 'Incorrect password.';
          passFeedback.className = 'text-[11px] text-red-400 font-semibold block mb-1';
        }
      } catch {
        passFeedback.textContent = 'Could not verify password.';
      }
    }, 500);
  });

  // Save actions
  document.getElementById('change-email-form')?.addEventListener('submit', async e => {
    e.preventDefault();
    const email = document.getElementById('email').value.trim();
    if (!email) return;
    const res = await post('/change-email', { email });
    if (res && res.ok) {
      showToast('Email address updated.', 'success');
      setTimeout(() => location.reload(), 1200);
    } else showToast('Failed to update email.', 'error');
  });

  document.getElementById('change-password-form')?.addEventListener('submit', async e => {
    e.preventDefault();
    const currentPassword = currentPassInput.value;
    const newPassword = newPassInput.value;
    if (!currentPassword || !newPassword) return;
    const res = await post('/change-password', { currentPassword, newPassword });
    if (res && res.ok) {
      showToast('Password changed successfully.', 'success');
      setTimeout(() => location.reload(), 1200);
    } else showToast('Failed to update password.', 'error');
  });

  document.getElementById('change-description-form')?.addEventListener('submit', async e => {
    e.preventDefault();
    const description = document.getElementById('description').value.trim();
    const res = await post('/change-description', { description });
    if (res && res.ok) {
      showToast('Description updated.', 'success');
      setTimeout(() => location.reload(), 1200);
    } else showToast('Failed to update description.', 'error');
  });

  document.getElementById('language-preference-form')?.addEventListener('submit', async e => {
    e.preventDefault();
    const lang = document.getElementById('language').value;
    const res = await post('/change-language', { language: lang });
    if (res && res.ok) {
      showToast('Language saved.', 'success');
      setTimeout(() => location.reload(), 1200);
    } else showToast('Something went wrong.', 'error');
  });

  // Avatar upload
  const avatarInput   = document.getElementById('avatar-input');
  const avatarPreview = document.getElementById('avatar-preview');

  avatarInput?.addEventListener('change', e => {
    const file = e.target.files[0];
    if (!file) return;
    if (file.size > 2 * 1024 * 1024) { showToast('Image must be under 2 MB', 'error'); return; }
    const reader = new FileReader();
    reader.onload = evt => openCropPopup(evt.target.result, csrfToken);
    reader.readAsDataURL(file);
    avatarInput.value = '';
  });

  document.getElementById('remove-avatar-btn')?.addEventListener('click', async () => {
    const res = await fetch('/remove-avatar', { method: 'POST', headers: { 'Content-Type': 'application/json', 'CSRF-Token': csrfToken } });
    if (res.ok) {
      avatarPreview.src = 'https://api.dicebear.com/9.x/thumbs/svg?seed=<%= encodeURIComponent(user.username) %>';
      showToast('Profile picture removed.', 'success');
      setTimeout(() => location.reload(), 1200);
    } else showToast('Something went wrong.', 'error');
  });

  function openCropPopup(dataUrl, csrf) {
    const overlay = document.createElement('div');
    overlay.className = 'fixed inset-0 z-[100] bg-black/70 flex items-center justify-center p-4 backdrop-blur-sm';
    overlay.innerHTML = `
      <div class="cynex-glass bg-[#0c0c14] rounded-2xl shadow-2xl border border-white/10 w-full max-w-lg overflow-hidden animate-scale">
        <div class="flex items-center justify-between px-6 py-4 border-b border-white/5 bg-white/[0.01]">
          <div>
            <p class="text-sm font-bold text-white">Position your photo</p>
            <p class="text-xs text-neutral-400 mt-0.5">Drag and resize the selection box.</p>
          </div>
          <button id="crop-cancel" class="w-7 h-7 flex items-center justify-center rounded-lg text-neutral-400 hover:text-white transition cursor-pointer">
            <%- icon('x', { class: 'w-4 h-4', strokeWidth: 2 }) %>
          </button>
        </div>
        <div class="relative bg-black select-none overflow-hidden" style="height:340px" id="crop-stage">
          <img id="crop-img" src="\${dataUrl}" draggable="false" style="position:absolute;top:0;left:0;user-select:none;max-width:none"/>
          <div id="crop-box" style="position:absolute;border:2px solid white;box-shadow:0 0 0 9999px rgba(0,0,0,0.65);cursor:move;box-sizing:border-box">
            <div class="crop-handle" data-dir="nw" style="position:absolute;top:-5px;left:-5px;width:10px;height:10px;background:white;border-radius:50%;cursor:nw-resize"></div>
            <div class="crop-handle" data-dir="ne" style="position:absolute;top:-5px;right:-5px;width:10px;height:10px;background:white;border-radius:50%;cursor:ne-resize"></div>
            <div class="crop-handle" data-dir="sw" style="position:absolute;bottom:-5px;left:-5px;width:10px;height:10px;background:white;border-radius:50%;cursor:sw-resize"></div>
            <div class="crop-handle" data-dir="se" style="position:absolute;bottom:-5px;right:-5px;width:10px;height:10px;background:white;border-radius:50%;cursor:se-resize"></div>
          </div>
        </div>
        <div class="flex gap-3 px-6 py-4 border-t border-white/5 bg-white/[0.01]">
          <button id="crop-cancel-btn" class="flex-1 rounded-xl border border-white/10 bg-white/5 py-2.5 text-xs font-bold text-neutral-300 hover:bg-white/10 transition cursor-pointer">Cancel</button>
          <button id="crop-save" class="flex-1 rounded-xl bg-brand-green py-2.5 text-xs font-bold text-black hover:bg-brand-green-hover transition cursor-pointer">Save Photo</button>
        </div>
      </div>`;
    document.body.appendChild(overlay);

    const stage = document.getElementById('crop-stage');
    const img   = document.getElementById('crop-img');
    const box   = document.getElementById('crop-box');
    const stageW = stage.offsetWidth, stageH = stage.offsetHeight;

    img.onload = () => {
      const scale = Math.min(stageW / img.naturalWidth, stageH / img.naturalHeight);
      const dw = img.naturalWidth * scale, dh = img.naturalHeight * scale;
      img.style.width = dw + 'px'; img.style.height = dh + 'px';
      img.style.left = ((stageW - dw) / 2) + 'px'; img.style.top = ((stageH - dh) / 2) + 'px';
      img._scale = scale; img._offX = (stageW - dw) / 2; img._offY = (stageH - dh) / 2;
      const bs = Math.min(dw, dh, 200);
      box.style.width = bs + 'px'; box.style.height = bs + 'px';
      box.style.left = ((stageW - bs) / 2) + 'px'; box.style.top = ((stageH - bs) / 2) + 'px';
    };
    if (img.complete) img.onload();

    let action = null, sx, sy, sb;
    const clamp = (v, a, b) => Math.max(a, Math.min(b, v));

    box.addEventListener('mousedown', e => {
      if (e.target.classList.contains('crop-handle')) return;
      e.preventDefault(); action = 'move'; sx = e.clientX; sy = e.clientY;
      sb = { l: parseInt(box.style.left), t: parseInt(box.style.top), w: box.offsetWidth, h: box.offsetHeight };
    });
    box.querySelectorAll('.crop-handle').forEach(h => h.addEventListener('mousedown', e => {
      e.preventDefault(); e.stopPropagation(); action = h.dataset.dir; sx = e.clientX; sy = e.clientY;
      sb = { l: parseInt(box.style.left), t: parseInt(box.style.top), w: box.offsetWidth, h: box.offsetHeight };
    }));

    const onUp = () => action = null;
    const onMove = e => {
      if (!action) return;
      const dx = e.clientX - sx, dy = e.clientY - sy, min = 60;
      if (action === 'move') {
        box.style.left = clamp(sb.l + dx, 0, stageW - sb.w) + 'px';
        box.style.top  = clamp(sb.t + dy, 0, stageH - sb.h) + 'px';
      } else {
        let l = sb.l, t = sb.t, w = sb.w, h = sb.h;
        if (action.includes('e')) w = Math.max(min, sb.w + dx);
        if (action.includes('s')) h = Math.max(min, sb.h + dy);
        if (action.includes('w')) { const nw = Math.max(min, sb.w - dx); l = sb.l + (sb.w - nw); w = nw; }
        if (action.includes('n')) { const nh = Math.max(min, sb.h - dy); t = sb.t + (sb.h - nh); h = nh; }
        l = clamp(l, 0, stageW - min); t = clamp(t, 0, stageH - min);
        w = Math.min(w, stageW - l); h = Math.min(h, stageH - t);
        box.style.left = l + 'px'; box.style.top = t + 'px';
        box.style.width = w + 'px'; box.style.height = h + 'px';
      }
    };

    document.addEventListener('mousemove', onMove);
    document.addEventListener('mouseup', onUp);

    const close = () => { document.removeEventListener('mousemove', onMove); document.removeEventListener('mouseup', onUp); overlay.remove(); };
    document.getElementById('crop-cancel').addEventListener('click', close);
    document.getElementById('crop-cancel-btn').addEventListener('click', close);

    document.getElementById('crop-save').addEventListener('click', () => {
      const scale = img._scale, offX = img._offX, offY = img._offY;
      const boxL = parseInt(box.style.left), boxT = parseInt(box.style.top);
      const canvas = document.createElement('canvas');
      canvas.width = 256; canvas.height = 256;
      canvas.getContext('2d').drawImage(img, (boxL - offX) / scale, (boxT - offY) / scale, box.offsetWidth / scale, box.offsetHeight / scale, 0, 0, 256, 256);
      canvas.toBlob(async blob => {
        const form = new FormData();
        form.append('avatar', blob, 'avatar.png');
        try {
          const res = await fetch('/upload-avatar', { method: 'POST', headers: { 'CSRF-Token': csrf }, body: form });
          if (res.ok) {
            const { avatar } = await res.json();
            avatarPreview.src = avatar + '?t=' + Date.now();
            showToast('Profile picture updated.', 'success');
            close();
          } else showToast('Failed to upload', 'error');
        } catch { showToast('Failed to upload', 'error'); }
      }, 'image/png');
    });
  }
});
</script>

