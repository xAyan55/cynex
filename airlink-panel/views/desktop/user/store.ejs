                  </thead>
                  <tbody>
                    <tr>
                      <td class="text-neutral-400 py-1.5 pr-4">Current</td>
                      <td id="upgradeCurrentRam" class="text-center text-white font-bold py-1.5"></td>
                      <td id="upgradeCurrentCpu" class="text-center text-white font-bold py-1.5"></td>
                      <td id="upgradeCurrentDisk" class="text-center text-white font-bold py-1.5"></td>
                    </tr>
                    <tr class="border-t border-white/5">
                      <td class="text-neutral-400 py-1.5 pr-4">Target</td>
                      <td id="upgradeTargetRam" class="text-center text-white font-bold py-1.5">-</td>
                      <td id="upgradeTargetCpu" class="text-center text-white font-bold py-1.5">-</td>
                      <td id="upgradeTargetDisk" class="text-center text-white font-bold py-1.5">-</td>
                    </tr>
                    <tr class="border-t border-white/5">
                      <td class="text-neutral-400 py-1.5 pr-4">Difference</td>
                      <td id="upgradeDiffRam" class="text-center text-brand-green font-bold py-1.5">0</td>
                      <td id="upgradeDiffCpu" class="text-center text-brand-green font-bold py-1.5">0</td>
                      <td id="upgradeDiffDisk" class="text-center text-brand-green font-bold py-1.5">0</td>
                    </tr>
                  </tbody>
                </table>
              </div>

              <div class="grid grid-cols-3 gap-4">
                <div>
                  <label class="text-xs text-neutral-400 block mb-1.5">New RAM (MB)</label>
                  <input type="number" id="upgradeRam" min="64" step="64" oninput="calcUpgradeCost()" class="w-full bg-white/5 border border-white/10 rounded-xl px-3 py-2.5 text-sm text-white outline-none focus:border-brand-green/30">
                  <p class="text-[10px] text-neutral-500 mt-1">Available: <span id="upgradeAvailRam" class="text-brand-green"></span> MB</p>
                </div>
                <div>
                  <label class="text-xs text-neutral-400 block mb-1.5">New CPU (%)</label>
                  <input type="number" id="upgradeCpu" min="10" step="10" oninput="calcUpgradeCost()" class="w-full bg-white/5 border border-white/10 rounded-xl px-3 py-2.5 text-sm text-white outline-none focus:border-brand-green/30">
                  <p class="text-[10px] text-neutral-500 mt-1">Available: <span id="upgradeAvailCpu" class="text-brand-green"></span>%</p>
                </div>
                <div>
                  <label class="text-xs text-neutral-400 block mb-1.5">New Disk (MB)</label>
                  <input type="number" id="upgradeDisk" min="512" step="512" oninput="calcUpgradeCost()" class="w-full bg-white/5 border border-white/10 rounded-xl px-3 py-2.5 text-sm text-white outline-none focus:border-brand-green/30">
                  <p class="text-[10px] text-neutral-500 mt-1">Available: <span id="upgradeAvailDisk" class="text-brand-green"></span> MB</p>
                </div>
              </div>

              <div class="bg-white/5 rounded-xl border border-white/5 p-4 space-y-2">
                <div class="flex justify-between text-xs"><span class="text-neutral-400">RAM Cost</span><span id="upgradeRamCost" class="text-sm font-bold text-white">0 coins</span></div>
                <div class="flex justify-between text-xs"><span class="text-neutral-400">CPU Cost</span><span id="upgradeCpuCost" class="text-sm font-bold text-white">0 coins</span></div>
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Disk Cost</span><span id="upgradeDiskCost" class="text-sm font-bold text-white">0 coins</span></div>
                <div class="border-t border-white/5 pt-2 flex justify-between text-xs"><span class="text-neutral-400">Total Cost</span><span id="upgradeTotalCost" class="text-sm font-bold text-white">0 coins</span></div>
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Balance after</span><span id="upgradeRemaining" class="text-sm font-bold text-brand-green"><%= balance.toLocaleString() %> coins</span></div>
