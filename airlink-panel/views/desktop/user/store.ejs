            </div>

            <div>
              <label class="text-xs text-neutral-400 block mb-2">Select Server</label>
              <select id="upgradeServer" onchange="loadServerUpgradeInfo()" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-2.5 text-sm text-white outline-none focus:border-brand-green/30 cursor-pointer appearance-none">
                <option value="">Choose a server...</option>
                <% servers.forEach(function(server) { %>
                <option value="<%= server.UUID %>" data-name="<%= server.name %>" data-memory="<%= server.Memory %>" data-cpu="<%= server.Cpu %>" data-disk="<%= server.Storage %>" data-suspended="<%= server.Suspended %>" data-installing="<%= server.Installing %>">
                  <%= server.name %> — <%= server.node ? server.node.name : 'Node' %> (<%= server.Memory %>MB / <%= server.Cpu %>% / <%= server.Storage %>MB)
