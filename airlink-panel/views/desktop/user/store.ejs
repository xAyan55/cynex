                    <tr class="text-neutral-500">
                      <th class="text-left font-medium pb-2"></th>
                      <th class="text-center font-medium pb-2">RAM (MB)</th>
                      <th class="text-center font-medium pb-2">CPU (%)</th>
                      <th class="text-center font-medium pb-2">Disk (MB)</th>
