              <button onclick="submitUpgrade()" id="upgradeBtn" class="w-full py-2.5 rounded-xl text-sm font-bold bg-brand-green text-black hover:bg-brand-green-hover transition cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed" disabled>Upgrade Server</button>
            </div>
          </div>
        </div>

        <!-- ============ SERVER RENEWAL ============ -->
        <div id="panel-renew" class="tab-panel hidden space-y-6">
          <div class="cynex-glass rounded-2xl border border-white/5 p-6 space-y-6">
            <div class="flex items-center gap-3">
              <div class="p-2.5 rounded-xl bg-amber-500/10 border border-amber-500/20 text-amber-400">
                <%- icon('refresh-cw', { class: 'w-5 h-5' }) %>
              </div>
              <div>
                <h2 class="text-sm font-bold text-white">Renew Server</h2>
                <p class="text-xs text-neutral-400">Extend your server's subscription period.</p>
              </div>
            </div>

            <div>
              <label class="text-xs text-neutral-400 block mb-2">Select Server</label>
              <select id="renewServer" onchange="loadServerRenewInfo()" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-2.5 text-sm text-white outline-none focus:border-brand-green/30 cursor-pointer appearance-none">
                <option value="">Choose a server...</option>
                <% servers.forEach(function(server) { %>
                <option value="<%= server.UUID %>" data-name="<%= server.name %>" data-expires="<%= server.expiresAt ? server.expiresAt.toISOString() : '' %>">
                  <%= server.name %> — <%= server.node ? server.node.name : 'Node' %>
                </option>
                <% }); %>
              </select>
            </div>

            <div id="renewInfo" class="hidden space-y-5">
              <div class="bg-white/5 rounded-xl p-4 border border-white/5">
                <p class="text-xs text-neutral-400 mb-1">Current Expiry</p>
                <p id="renewCurrentExpiry" class="text-sm font-bold text-white"></p>
              </div>

              <div>
                <label class="text-xs text-neutral-400 block mb-3">Renewal Duration</label>
                <div class="grid grid-cols-5 gap-2">
                  <button onclick="selectRenewDays(7, this)" data-days="7" class="renew-day-btn px-3 py-2.5 rounded-xl text-xs font-bold border border-white/10 bg-white/5 text-neutral-400 hover:text-white hover:border-white/20 transition cursor-pointer">
                    <span>7</span><span class="block text-[10px] font-normal mt-0.5">days</span>
                  </button>
                  <button onclick="selectRenewDays(15, this)" data-days="15" class="renew-day-btn px-3 py-2.5 rounded-xl text-xs font-bold border border-white/10 bg-white/5 text-neutral-400 hover:text-white hover:border-white/20 transition cursor-pointer">
                    <span>15</span><span class="block text-[10px] font-normal mt-0.5">days</span>
                  </button>
                  <button onclick="selectRenewDays(30, this)" data-days="30" class="renew-day-btn px-3 py-2.5 rounded-xl text-xs font-bold border border-white/10 bg-white/5 text-neutral-400 hover:text-white hover:border-white/20 transition cursor-pointer">
                    <span>30</span><span class="block text-[10px] font-normal mt-0.5">days</span>
                  </button>
                  <button onclick="selectRenewDays(60, this)" data-days="60" class="renew-day-btn px-3 py-2.5 rounded-xl text-xs font-bold border border-white/10 bg-white/5 text-neutral-400 hover:text-white hover:border-white/20 transition cursor-pointer">
                    <span>60</span><span class="block text-[10px] font-normal mt-0.5">days</span>
                  </button>
                  <button onclick="selectRenewDays(90, this)" data-days="90" class="renew-day-btn px-3 py-2.5 rounded-xl text-xs font-bold border border-white/10 bg-white/5 text-neutral-400 hover:text-white hover:border-white/20 transition cursor-pointer">
                    <span>90</span><span class="block text-[10px] font-normal mt-0.5">days</span>
                  </button>
                </div>
              </div>

              <div class="bg-white/5 rounded-xl border border-white/5 p-4 space-y-2">
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Duration</span><span id="renewDuration" class="text-sm font-bold text-white">-</span></div>
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Current Expiry</span><span id="renewExpiryCurrent" class="text-sm font-bold text-white">-</span></div>
                <div class="flex justify-between text-xs"><span class="text-neutral-400">New Expiry</span><span id="renewExpiryNew" class="text-sm font-bold text-brand-green">-</span></div>
                <div class="border-t border-white/5 pt-2 flex justify-between text-xs"><span class="text-neutral-400">Cost</span><span id="renewCost" class="text-sm font-bold text-white">0 coins</span></div>
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Balance after</span><span id="renewRemaining" class="text-sm font-bold text-brand-green"><%= balance.toLocaleString() %> coins</span></div>
              </div>

              <button onclick="submitRenew()" id="renewBtn" class="w-full py-2.5 rounded-xl text-sm font-bold bg-brand-green text-black hover:bg-brand-green-hover transition cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed" disabled>Renew Server</button>
            </div>
          </div>
        </div>

        <%- renderPlacement('storeBottom') %>
      </div>
    </div>
  </div>

  <!-- Floating Balance tracker pinned to screen -->
  <div class="fixed bottom-6 right-6 z-50 pointer-events-auto">
    <div class="cynex-glass border border-white/10 rounded-2xl px-4 py-3 flex items-center gap-2.5 shadow-2xl hover:scale-105 transition-all duration-300">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-amber-400 animate-spin" style="animation-duration: 4s" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1.41 16.09V20h-2.67v-1.93c-1.71-.36-3.16-1.46-3.27-3.4h1.96c.1 1.05.82 1.87 2.65 1.87 1.96 0 2.4-.98 2.4-1.59 0-.83-.44-1.61-2.67-2.14-2.48-.6-4.18-1.62-4.18-3.67 0-1.72 1.39-2.84 3.11-3.21V4h2.67v1.95c1.86.45 2.79 1.86 2.85 3.39H14.3c-.05-1.11-.64-1.87-2.22-1.87-1.5 0-2.4.68-2.4 1.64 0 .84.65 1.39 2.67 1.91s4.18 1.39 4.18 3.91c-.01 1.83-1.38 2.83-3.12 3.16z"/></svg>
      <div class="text-right">
        <p class="text-[9px] font-bold text-neutral-500 uppercase tracking-wider leading-none">Your Balance</p>
        <p id="floatingBalance" class="text-sm font-black text-white leading-none mt-1"><%= balance.toLocaleString() %> <span class="text-neutral-400 font-bold text-[10px]">coins</span></p>
      </div>
    </div>
  </div>

  </div>
</main>

<%- include('../components/modal') %>
<%- include('../components/toast') %>

<script nonce="<%- nonce %>">
var CURRENT_BALANCE = <%= balance %>;
var STORE_CONFIG = {
  ramPricePerMb: <%= storeConfig.ramPricePerMb %>,
  cpuPricePerPercent: <%= storeConfig.cpuPricePerPercent %>,
  diskPricePerMb: <%= storeConfig.diskPricePerMb %>,
  backupSlotPrice: <%= storeConfig.backupSlotPrice %>,
  databaseSlotPrice: <%= storeConfig.databaseSlotPrice %>,
  portPrice: <%= storeConfig.portPrice %>
};
var RENEWAL_CONFIG = {
  7: <%= renewalsConfig.renew7DaysCost %>,
  15: <%= renewalsConfig.renew15DaysCost %>,
  30: <%= renewalsConfig.renew30DaysCost %>,
  60: <%= renewalsConfig.renew60DaysCost %>,
  90: <%= renewalsConfig.renew90DaysCost %>
};
var RAM = <%- JSON.stringify(ram) %>;
var CPU = <%- JSON.stringify(cpu) %>;
var DISK = <%- JSON.stringify(disk) %>;
var selectedRenewDays = 0;

function updateBalanceDisplay(newBal) {
  CURRENT_BALANCE = newBal;
  const str = newBal.toLocaleString() + ' coins';
  const el = document.getElementById('balanceDisplay');
  if (el) el.textContent = str;
  const floatEl = document.getElementById('floatingBalance');
  if (floatEl) floatEl.innerHTML = newBal.toLocaleString() + ' <span class="text-neutral-400 font-bold text-[10px]">coins</span>';
}

function switchTab(tab) {
  document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.add('hidden'); });
  document.querySelectorAll('.tab-btn').forEach(function(b) {
    b.classList.remove('bg-white', 'text-black');
    b.classList.add('text-neutral-400', 'hover:text-white');
  });
  document.getElementById('panel-' + tab).classList.remove('hidden');
  var btn = document.getElementById('tab-' + tab);
  btn.classList.add('bg-white', 'text-black');
  btn.classList.remove('text-neutral-400', 'hover:text-white');
}

function stepper(inputId, delta) {
  var input = document.getElementById(inputId);
  var val = parseInt(input.value, 10) || 1;
  val = Math.max(parseInt(input.min, 10) || 1, val + delta);
  input.value = val;
  updateResourceCard(input);
}

function updateResourceCard(el) {
  var price = parseInt(el.dataset.price, 10);
  var amount = parseInt(el.value, 10) || 0;
  if (amount < 1) amount = 1;
  var total = amount * price;
  var remaining = CURRENT_BALANCE - total;
  var card = el.closest('.cynex-glass');
  card.querySelector('.resource-total').textContent = total.toLocaleString();
  var remEl = card.querySelector('.resource-remaining');
  remEl.textContent = remaining.toLocaleString();
  if (remaining < 0) {
    remEl.classList.remove('text-brand-green');
    remEl.classList.add('text-red-400');
  } else {
    remEl.classList.remove('text-red-400');
    remEl.classList.add('text-brand-green');
  }
}

function buyResource(type, btnEl) {
  var card = btnEl.closest('.cynex-glass');
  var input = card.querySelector('.resource-input');
  var amount = parseInt(input.value, 10);
  if (!amount || amount <= 0) { alert('Enter a valid amount.'); return; }
  var price = parseInt(input.dataset.price, 10);
  var total = amount * price;
  if (total > CURRENT_BALANCE) { alert('Insufficient balance.'); return; }
  var label = type.replace(/_/g, ' ').toLowerCase();

  window.modal.confirm({
    title: 'Confirm Purchase',
    body: 'Buy ' + amount + ' ' + label + ' for ' + total.toLocaleString() + ' coins? Your balance will be ' + (CURRENT_BALANCE - total).toLocaleString() + ' coins.',
    danger: false,
    confirmLabel: 'Buy',
    onConfirm: function() {
      btnEl.disabled = true;
      btnEl.textContent = '...';
      fetch('/store/buy-resource', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type: type, amount: amount })
      }).then(function(r) { return r.json(); }).then(function(data) {
        btnEl.disabled = false;
        btnEl.textContent = 'Buy';
        if (data.success) {
          updateBalanceDisplay(data.newBalance);
          window.modal.confirm({
            title: 'Purchase Successful',
            body: 'Purchased ' + amount + ' ' + label + ' for ' + total.toLocaleString() + ' coins.',
            danger: false,
            confirmLabel: 'OK',
            onConfirm: function() { window.location.reload(); }
          });
        } else {
          alert(data.error || 'Purchase failed. You may have insufficient balance.');
        }
      }).catch(function() {
        btnEl.disabled = false;
        btnEl.textContent = 'Buy';
        alert('Network error.');
      });
    }
  });
}

function purchaseProduct(id, name, price) {
  if (price > CURRENT_BALANCE) { alert('Insufficient balance.'); return; }
  window.modal.confirm({
    title: 'Confirm Purchase',
    body: 'Buy ' + name + ' for ' + price.toLocaleString() + ' coins? Your balance will be ' + (CURRENT_BALANCE - price).toLocaleString() + ' coins.',
    danger: false,
    confirmLabel: 'Buy',
    onConfirm: function() {
      fetch('/store/buy/' + id, { method: 'POST' }).then(function(r) { return r.json(); }).then(function(data) {
        if (data.success) {
          updateBalanceDisplay(CURRENT_BALANCE - price);
          window.modal.confirm({
            title: 'Purchase Successful',
            body: 'Purchased ' + name + ' for ' + price.toLocaleString() + ' coins.',
            danger: false,
            confirmLabel: 'OK',
            onConfirm: function() { window.location.reload(); }
          });
        } else {
          alert(data.error || 'Purchase failed.');
        }
      }).catch(function() { alert('Network error.'); });
    }
  });
}

function loadServerUpgradeInfo() {
  var sel = document.getElementById('upgradeServer');
  var opt = sel.options[sel.selectedIndex];
  var info = document.getElementById('upgradeInfo');
  if (!sel.value) { info.classList.add('hidden'); return; }

  var mem = parseInt(opt.dataset.memory, 10);
  var cpu = parseInt(opt.dataset.cpu, 10);
  var disk = parseInt(opt.dataset.disk, 10);

  document.getElementById('upgradeCurrentRam').textContent = mem.toLocaleString() + ' MB';
  document.getElementById('upgradeCurrentCpu').textContent = cpu + '%';
  document.getElementById('upgradeCurrentDisk').textContent = disk.toLocaleString() + ' MB';

  document.getElementById('upgradeRam').value = mem;
  document.getElementById('upgradeCpu').value = cpu;
  document.getElementById('upgradeDisk').value = disk;

  document.getElementById('upgradeAvailRam').textContent = RAM.available.toLocaleString();
  document.getElementById('upgradeAvailCpu').textContent = CPU.available;
  document.getElementById('upgradeAvailDisk').textContent = DISK.available.toLocaleString();

  document.getElementById('upgradeRemaining').textContent = CURRENT_BALANCE.toLocaleString() + ' coins';

  info.classList.remove('hidden');
  calcUpgradeCost();
}

function calcUpgradeCost() {
  var sel = document.getElementById('upgradeServer');
  var opt = sel.options[sel.selectedIndex];
  if (!sel.value) return;

  var curMem = parseInt(opt.dataset.memory, 10);
  var curCpu = parseInt(opt.dataset.cpu, 10);
  var curDisk = parseInt(opt.dataset.disk, 10);

  var newMem = parseInt(document.getElementById('upgradeRam').value, 10) || curMem;
  var newCpu = parseInt(document.getElementById('upgradeCpu').value, 10) || curCpu;
  var newDisk = parseInt(document.getElementById('upgradeDisk').value, 10) || curDisk;

  var memDiff = Math.max(0, newMem - curMem);
  var cpuDiff = Math.max(0, newCpu - curCpu);
  var diskDiff = Math.max(0, newDisk - curDisk);

  var memCost = memDiff * STORE_CONFIG.ramPricePerMb;
  var cpuCost = cpuDiff * STORE_CONFIG.cpuPricePerPercent;
  var diskCost = diskDiff * STORE_CONFIG.diskPricePerMb;
  var total = memCost + cpuCost + diskCost;
  var remaining = CURRENT_BALANCE - total;

  document.getElementById('upgradeTargetRam').textContent = newMem.toLocaleString() + ' MB';
  document.getElementById('upgradeTargetCpu').textContent = newCpu + '%';
  document.getElementById('upgradeTargetDisk').textContent = newDisk.toLocaleString() + ' MB';

  document.getElementById('upgradeDiffRam').textContent = (memDiff > 0 ? '+' : '') + memDiff.toLocaleString();
  document.getElementById('upgradeDiffCpu').textContent = (cpuDiff > 0 ? '+' : '') + cpuDiff;
  document.getElementById('upgradeDiffDisk').textContent = (diskDiff > 0 ? '+' : '') + diskDiff.toLocaleString();

  document.getElementById('upgradeRamCost').textContent = memCost.toLocaleString() + ' coins';
  document.getElementById('upgradeCpuCost').textContent = cpuCost.toLocaleString() + ' coins';
  document.getElementById('upgradeDiskCost').textContent = diskCost.toLocaleString() + ' coins';
  document.getElementById('upgradeTotalCost').textContent = total.toLocaleString() + ' coins';

  var remEl = document.getElementById('upgradeRemaining');
  remEl.textContent = remaining.toLocaleString() + ' coins';
  remEl.classList.remove('text-brand-green', 'text-red-400');
  remEl.classList.add(remaining < 0 ? 'text-red-400' : 'text-brand-green');

  var btn = document.getElementById('upgradeBtn');
  btn.disabled = total === 0 || remaining < 0;
}

function submitUpgrade() {
  var sel = document.getElementById('upgradeServer');
  var serverId = sel.value;
  if (!serverId) return;

  var mem = document.getElementById('upgradeRam').value;
  var cpu = document.getElementById('upgradeCpu').value;
  var disk = document.getElementById('upgradeDisk').value;
  var totalCost = document.getElementById('upgradeTotalCost').textContent;

  window.modal.confirm({
    title: 'Confirm Upgrade',
    body: 'Upgrade this server for ' + totalCost + '?',
    danger: false,
    confirmLabel: 'Upgrade',
    onConfirm: function() {
      var btn = document.getElementById('upgradeBtn');
      btn.disabled = true;
      btn.textContent = 'Upgrading...';
      fetch('/store/upgrade', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ serverId: serverId, memory: mem, cpu: cpu, disk: disk })
      }).then(function(r) { return r.json(); }).then(function(data) {
        btn.disabled = false;
        btn.textContent = 'Upgrade Server';
        if (data.success) {
          updateBalanceDisplay(data.newBalance);
          window.modal.confirm({
            title: 'Upgrade Successful',
            body: 'Server upgraded for ' + data.coinCost + ' coins.',
            danger: false,
            confirmLabel: 'OK',
            onConfirm: function() { window.location.reload(); }
          });
        } else {
          alert(data.error || 'Upgrade failed.');
        }
      }).catch(function() {
        btn.disabled = false;
        btn.textContent = 'Upgrade Server';
        alert('Network error.');
      });
    }
  });
}

function loadServerRenewInfo() {
  var sel = document.getElementById('renewServer');
  var opt = sel.options[sel.selectedIndex];
  var info = document.getElementById('renewInfo');
  if (!sel.value) { info.classList.add('hidden'); return; }

  var expiresStr = opt.dataset.expires;
  var expiryDate = expiresStr ? new Date(expiresStr) : null;
  var now = new Date();
  var currentExpiry = expiryDate && expiryDate > now ? expiryDate : now;

  document.getElementById('renewCurrentExpiry').textContent = formatDate(currentExpiry);
  document.getElementById('renewRemaining').textContent = CURRENT_BALANCE.toLocaleString() + ' coins';
  selectedRenewDays = 0;
  document.querySelectorAll('.renew-day-btn').forEach(function(b) {
    b.classList.remove('bg-brand-green', 'text-black', 'border-brand-green/30');
    b.classList.add('bg-white/5', 'text-neutral-400', 'border-white/10');
  });
  document.getElementById('renewDuration').textContent = '-';
  document.getElementById('renewExpiryCurrent').textContent = '-';
  document.getElementById('renewExpiryNew').textContent = '-';
  document.getElementById('renewCost').textContent = '0 coins';
  document.getElementById('renewBtn').disabled = true;

  info.classList.remove('hidden');
}

function selectRenewDays(days, el) {
  selectedRenewDays = days;
  document.querySelectorAll('.renew-day-btn').forEach(function(b) {
    b.classList.remove('bg-brand-green', 'text-black', 'border-brand-green/30');
    b.classList.add('bg-white/5', 'text-neutral-400', 'border-white/10');
  });
  el.classList.add('bg-brand-green', 'text-black', 'border-brand-green/30');
  el.classList.remove('bg-white/5', 'text-neutral-400', 'border-white/10');

  var sel = document.getElementById('renewServer');
  var opt = sel.options[sel.selectedIndex];
  var expiresStr = opt.dataset.expires;
  var expiryDate = expiresStr ? new Date(expiresStr) : null;
  var now = new Date();
  var currentExpiry = expiryDate && expiryDate > now ? expiryDate : now;
  var newExpiry = new Date(currentExpiry.getTime() + days * 86400000);
  var cost = RENEWAL_CONFIG[days] || 0;
  var remaining = CURRENT_BALANCE - cost;

  document.getElementById('renewDuration').textContent = days + ' days';
  document.getElementById('renewExpiryCurrent').textContent = formatDate(currentExpiry);
  document.getElementById('renewExpiryNew').textContent = formatDate(newExpiry);
  document.getElementById('renewCost').textContent = cost.toLocaleString() + ' coins';

  var remEl = document.getElementById('renewRemaining');
  remEl.textContent = remaining.toLocaleString() + ' coins';
  remEl.classList.remove('text-brand-green', 'text-red-400');
  remEl.classList.add(remaining < 0 ? 'text-red-400' : 'text-brand-green');

  document.getElementById('renewBtn').disabled = remaining < 0;
}

function submitRenew() {
  var sel = document.getElementById('renewServer');
  var serverId = sel.value;
  if (!serverId || !selectedRenewDays) return;

  var cost = RENEWAL_CONFIG[selectedRenewDays] || 0;
  window.modal.confirm({
    title: 'Confirm Renewal',
    body: 'Renew for ' + selectedRenewDays + ' days for ' + cost.toLocaleString() + ' coins?',
    danger: false,
    confirmLabel: 'Renew',
    onConfirm: function() {
      var btn = document.getElementById('renewBtn');
      btn.disabled = true;
      btn.textContent = 'Renewing...';
      fetch('/store/renew', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ serverId: serverId, days: selectedRenewDays })
      }).then(function(r) { return r.json(); }).then(function(data) {
        btn.disabled = false;
        btn.textContent = 'Renew Server';
        if (data.success) {
          updateBalanceDisplay(data.newBalance);
          window.modal.confirm({
            title: 'Renewal Successful',
            body: 'Server renewed for ' + data.coinCost + ' coins. New expiry: ' + formatDate(new Date(data.expiresAt)) + '.',
            danger: false,
            confirmLabel: 'OK',
            onConfirm: function() { window.location.reload(); }
          });
        } else {
          alert(data.error || 'Renewal failed.');
        }
      }).catch(function() {
        btn.disabled = false;
        btn.textContent = 'Renew Server';
        alert('Network error.');
      });
    }
  });
}

function formatDate(d) {
  if (!d || isNaN(d.getTime())) return 'No expiry';
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
}
</script>
