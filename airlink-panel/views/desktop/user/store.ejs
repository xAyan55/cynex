                  <span class="text-sm font-bold text-white"><%= product.price.toLocaleString() %> <span class="text-xs text-neutral-400 font-normal">coins</span></span>
                  <button onclick="purchaseProduct(<%= product.id %>, '<%= product.name.replace(/'/g, "\\'") %>', <%= product.price %>)" class="px-3 py-1.5 rounded-xl text-xs font-bold bg-brand-green text-black hover:bg-brand-green-hover transition cursor-pointer">Buy</button>
                </div>
              </div>
              <% }); %>
            </div>
          </div>
          <% } %>
