<%- include('../components/header', { title: 'Store' }) %>
<main class="h-screen m-auto bg-mono-bg text-white">
  <div class="flex h-screen">
    <div class="w-60 h-full"><%- include('../components/template') %></div>
    <div id="page-content" class="flex-1 overflow-y-auto pt-16">
      <div class="px-12 pt-8 pb-12 space-y-10">

        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-xl font-bold tracking-tight">Store</h1>
            <p class="text-sm text-neutral-400 mt-1">Purchase resources, upgrade servers, or renew subscriptions.</p>
          </div>
          <div class="flex items-center gap-2 bg-white/5 border border-white/10 rounded-xl px-4 py-2.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-amber-400" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1.41 16.09V20h-2.67v-1.93c-1.71-.36-3.16-1.46-3.27-3.4h1.96c.1 1.05.82 1.87 2.65 1.87 1.96 0 2.4-.98 2.4-1.59 0-.83-.44-1.61-2.67-2.14-2.48-.6-4.18-1.62-4.18-3.67 0-1.72 1.39-2.84 3.11-3.21V4h2.67v1.95c1.86.45 2.79 1.86 2.85 3.39H14.3c-.05-1.11-.64-1.87-2.22-1.87-1.5 0-2.4.68-2.4 1.64 0 .84.65 1.39 2.67 1.91s4.18 1.39 4.18 3.91c-.01 1.83-1.38 2.83-3.12 3.16z"/></svg>
            <span id="balanceDisplay" class="text-sm font-bold text-white"><%= balance.toLocaleString() %> coins</span>
          </div>
        </div>

        <!-- Store Navigation tabs -->
        <div class="flex gap-1.5 p-1.5 bg-white/[0.02] border border-white/5 rounded-2xl w-fit">
          <button onclick="switchTab('resources')" id="tab-resources" class="tab-btn px-5 py-2.5 rounded-xl text-xs font-bold transition-all duration-300 cursor-pointer bg-white text-black">Resource Store</button>
          <button onclick="switchTab('upgrade')" id="tab-upgrade" class="tab-btn px-5 py-2.5 rounded-xl text-xs font-bold transition-all duration-300 cursor-pointer text-neutral-400 hover:text-white">Server Upgrade</button>
          <button onclick="switchTab('renew')" id="tab-renew" class="tab-btn px-5 py-2.5 rounded-xl text-xs font-bold transition-all duration-300 cursor-pointer text-neutral-400 hover:text-white">Server Renewal</button>
        </div>

        <%- renderPlacement('storeTop') %>

        <!-- ============ RESOURCE STORE ============ -->
        <div id="panel-resources" class="tab-panel space-y-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6">

            <!-- RAM -->
            <div class="cynex-glass rounded-2xl border border-white/5 p-6 space-y-4 hover:shadow-[0_0_20px_rgba(59,130,246,0.06)] hover:border-blue-500/20 transition-all duration-300 relative overflow-hidden group">
              <div class="absolute -right-6 -bottom-6 w-20 h-20 bg-blue-500/5 rounded-full blur-2xl group-hover:scale-125 transition-transform duration-500"></div>
              <div class="flex items-center gap-3 relative z-10">
                <div class="p-2.5 rounded-xl bg-white/5 border border-white/10 text-white">
                  <%- icon('cpu', { class: 'w-5 h-5' }) %>
                </div>
                <div>
                  <h3 class="text-sm font-bold text-white">RAM</h3>
                  <p class="text-xs text-neutral-400">Memory allocation</p>
                </div>
              </div>
              <div class="space-y-1.5 relative z-10">
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Allocated</span><span class="text-sm font-bold text-white"><%= ram.allocated.toLocaleString() %> MB</span></div>
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Used</span><span class="text-sm font-bold text-white"><%= ram.used.toLocaleString() %> MB</span></div>
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Available</span><span class="text-sm font-bold text-brand-green"><%= ram.available.toLocaleString() %> MB</span></div>
              </div>
              <div class="border-t border-white/5 pt-3 space-y-3 relative z-10">
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Price per MB</span><span class="text-sm font-bold text-white"><%= storeConfig.ramPricePerMb %> coins</span></div>
                <div class="flex items-center gap-2">
                  <button onclick="stepper('ram-amount', -1)" class="shrink-0 w-8 h-8 rounded-lg bg-white/5 border border-white/10 text-white flex items-center justify-center hover:bg-white/10 transition cursor-pointer text-sm font-bold">−</button>
                  <input type="number" id="ram-amount" min="1" value="1" data-price="<%= storeConfig.ramPricePerMb %>" data-key="ram" class="resource-input flex-1 bg-white/5 border border-white/10 rounded-xl px-3 py-2 text-sm text-white text-center outline-none focus:border-brand-green/30 animate-none" oninput="updateResourceCard(this)">
                  <button onclick="stepper('ram-amount', 1)" class="shrink-0 w-8 h-8 rounded-lg bg-white/5 border border-white/10 text-white flex items-center justify-center hover:bg-white/10 transition cursor-pointer text-sm font-bold">+</button>
                  <span class="text-xs text-neutral-400 shrink-0">MB</span>
                </div>
                <div class="flex items-center justify-between">
                  <div class="text-xs text-neutral-400 space-y-0.5">
                    <div>Total: <span class="text-white font-bold resource-total"><%= storeConfig.ramPricePerMb %></span> coins</div>
                    <div>Balance after: <span class="text-brand-green font-bold resource-remaining"><%= (balance - storeConfig.ramPricePerMb).toLocaleString() %></span> coins</div>
                  </div>
                  <button onclick="buyResource('RAM', this)" class="px-4 py-2 rounded-xl text-xs font-bold bg-brand-green text-black hover:bg-brand-green-hover transition cursor-pointer">Buy</button>
                </div>
              </div>
            </div>

            <!-- CPU -->
            <div class="cynex-glass rounded-2xl border border-white/5 p-6 space-y-4 hover:shadow-[0_0_20px_rgba(168,85,247,0.06)] hover:border-purple-500/20 transition-all duration-300 relative overflow-hidden group">
              <div class="absolute -right-6 -bottom-6 w-20 h-20 bg-purple-500/5 rounded-full blur-2xl group-hover:scale-125 transition-transform duration-500"></div>
              <div class="flex items-center gap-3 relative z-10">
                <div class="p-2.5 rounded-xl bg-white/5 border border-white/10 text-white">
                  <%- icon('zap', { class: 'w-5 h-5' }) %>
                </div>
                <div>
                  <h3 class="text-sm font-bold text-white">CPU</h3>
                  <p class="text-xs text-neutral-400">Processor allocation</p>
                </div>
              </div>
              <div class="space-y-1.5 relative z-10">
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Allocated</span><span class="text-sm font-bold text-white"><%= cpu.allocated %>%</span></div>
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Used</span><span class="text-sm font-bold text-white"><%= cpu.used %>%</span></div>
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Available</span><span class="text-sm font-bold text-brand-green"><%= cpu.available %>%</span></div>
              </div>
              <div class="border-t border-white/5 pt-3 space-y-3 relative z-10">
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Price per %</span><span class="text-sm font-bold text-white"><%= storeConfig.cpuPricePerPercent %> coins</span></div>
                <div class="flex items-center gap-2">
                  <button onclick="stepper('cpu-amount', -1)" class="shrink-0 w-8 h-8 rounded-lg bg-white/5 border border-white/10 text-white flex items-center justify-center hover:bg-white/10 transition cursor-pointer text-sm font-bold">−</button>
                  <input type="number" id="cpu-amount" min="1" value="1" data-price="<%= storeConfig.cpuPricePerPercent %>" data-key="cpu" class="resource-input flex-1 bg-white/5 border border-white/10 rounded-xl px-3 py-2 text-sm text-white text-center outline-none focus:border-brand-green/30" oninput="updateResourceCard(this)">
                  <button onclick="stepper('cpu-amount', 1)" class="shrink-0 w-8 h-8 rounded-lg bg-white/5 border border-white/10 text-white flex items-center justify-center hover:bg-white/10 transition cursor-pointer text-sm font-bold">+</button>
                  <span class="text-xs text-neutral-400 shrink-0">%</span>
                </div>
                <div class="flex items-center justify-between">
                  <div class="text-xs text-neutral-400 space-y-0.5">
                    <div>Total: <span class="text-white font-bold resource-total"><%= storeConfig.cpuPricePerPercent %></span> coins</div>
                    <div>Balance after: <span class="text-brand-green font-bold resource-remaining"><%= (balance - storeConfig.cpuPricePerPercent).toLocaleString() %></span> coins</div>
                  </div>
                  <button onclick="buyResource('CPU', this)" class="px-4 py-2 rounded-xl text-xs font-bold bg-brand-green text-black hover:bg-brand-green-hover transition cursor-pointer">Buy</button>
                </div>
              </div>
            </div>

            <!-- Disk -->
            <div class="cynex-glass rounded-2xl border border-white/5 p-6 space-y-4 hover:shadow-[0_0_20px_rgba(16,185,129,0.06)] hover:border-emerald-500/20 transition-all duration-300 relative overflow-hidden group">
              <div class="absolute -right-6 -bottom-6 w-20 h-20 bg-emerald-500/5 rounded-full blur-2xl group-hover:scale-125 transition-transform duration-500"></div>
              <div class="flex items-center gap-3 relative z-10">
                <div class="p-2.5 rounded-xl bg-white/5 border border-white/10 text-white">
                  <%- icon('hard-drive', { class: 'w-5 h-5' }) %>
                </div>
                <div>
                  <h3 class="text-sm font-bold text-white">Disk</h3>
                  <p class="text-xs text-neutral-400">Storage allocation</p>
                </div>
              </div>
              <div class="space-y-1.5 relative z-10">
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Allocated</span><span class="text-sm font-bold text-white"><%= disk.allocated.toLocaleString() %> MB</span></div>
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Used</span><span class="text-sm font-bold text-white"><%= disk.used.toLocaleString() %> MB</span></div>
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Available</span><span class="text-sm font-bold text-brand-green"><%= disk.available.toLocaleString() %> MB</span></div>
              </div>
              <div class="border-t border-white/5 pt-3 space-y-3 relative z-10">
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Price per MB</span><span class="text-sm font-bold text-white"><%= storeConfig.diskPricePerMb %> coins</span></div>
                <div class="flex items-center gap-2">
                  <button onclick="stepper('disk-amount', -1)" class="shrink-0 w-8 h-8 rounded-lg bg-white/5 border border-white/10 text-white flex items-center justify-center hover:bg-white/10 transition cursor-pointer text-sm font-bold">−</button>
                  <input type="number" id="disk-amount" min="1" value="1" data-price="<%= storeConfig.diskPricePerMb %>" data-key="disk" class="resource-input flex-1 bg-white/5 border border-white/10 rounded-xl px-3 py-2 text-sm text-white text-center outline-none focus:border-brand-green/30" oninput="updateResourceCard(this)">
                  <button onclick="stepper('disk-amount', 1)" class="shrink-0 w-8 h-8 rounded-lg bg-white/5 border border-white/10 text-white flex items-center justify-center hover:bg-white/10 transition cursor-pointer text-sm font-bold">+</button>
                  <span class="text-xs text-neutral-400 shrink-0">MB</span>
                </div>
                <div class="flex items-center justify-between">
                  <div class="text-xs text-neutral-400 space-y-0.5">
                    <div>Total: <span class="text-white font-bold resource-total"><%= storeConfig.diskPricePerMb %></span> coins</div>
                    <div>Balance after: <span class="text-brand-green font-bold resource-remaining"><%= (balance - storeConfig.diskPricePerMb).toLocaleString() %></span> coins</div>
                  </div>
                  <button onclick="buyResource('DISK', this)" class="px-4 py-2 rounded-xl text-xs font-bold bg-brand-green text-black hover:bg-brand-green-hover transition cursor-pointer">Buy</button>
                </div>
              </div>
            </div>

            <!-- Backup Slots -->
            <div class="cynex-glass rounded-2xl border border-white/5 p-6 space-y-4 hover:shadow-[0_0_20px_rgba(245,158,11,0.06)] hover:border-amber-500/20 transition-all duration-300 relative overflow-hidden group">
              <div class="absolute -right-6 -bottom-6 w-20 h-20 bg-amber-500/5 rounded-full blur-2xl group-hover:scale-125 transition-transform duration-500"></div>
              <div class="flex items-center gap-3 relative z-10">
                <div class="p-2.5 rounded-xl bg-white/5 border border-white/10 text-white">
                  <%- icon('archive', { class: 'w-5 h-5' }) %>
                </div>
                <div>
                  <h3 class="text-sm font-bold text-white">Backup Slots</h3>
                  <p class="text-xs text-neutral-400">Backup capacity</p>
                </div>
              </div>
              <div class="space-y-1.5 relative z-10">
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Allocated</span><span class="text-sm font-bold text-white"><%= typeof backupSlots !== 'undefined' ? backupSlots : 0 %> slot(s)</span></div>
              </div>
              <div class="border-t border-white/5 pt-3 space-y-3 relative z-10">
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Price per slot</span><span class="text-sm font-bold text-white"><%= storeConfig.backupSlotPrice %> coins</span></div>
                <div class="flex items-center gap-2">
                  <button onclick="stepper('backup-amount', -1)" class="shrink-0 w-8 h-8 rounded-lg bg-white/5 border border-white/10 text-white flex items-center justify-center hover:bg-white/10 transition cursor-pointer text-sm font-bold">−</button>
                  <input type="number" id="backup-amount" min="1" value="1" data-price="<%= storeConfig.backupSlotPrice %>" data-key="backup" class="resource-input flex-1 bg-white/5 border border-white/10 rounded-xl px-3 py-2 text-sm text-white text-center outline-none focus:border-brand-green/30" oninput="updateResourceCard(this)">
                  <button onclick="stepper('backup-amount', 1)" class="shrink-0 w-8 h-8 rounded-lg bg-white/5 border border-white/10 text-white flex items-center justify-center hover:bg-white/10 transition cursor-pointer text-sm font-bold">+</button>
                  <span class="text-xs text-neutral-400 shrink-0">slot(s)</span>
                </div>
                <div class="flex items-center justify-between">
                  <div class="text-xs text-neutral-400 space-y-0.5">
                    <div>Total: <span class="text-white font-bold resource-total"><%= storeConfig.backupSlotPrice %></span> coins</div>
                    <div>Balance after: <span class="text-brand-green font-bold resource-remaining"><%= (balance - storeConfig.backupSlotPrice).toLocaleString() %></span> coins</div>
                  </div>
                  <button onclick="buyResource('BACKUP_SLOTS', this)" class="px-4 py-2 rounded-xl text-xs font-bold bg-brand-green text-black hover:bg-brand-green-hover transition cursor-pointer">Buy</button>
                </div>
              </div>
            </div>

            <!-- Database Slots -->
            <div class="cynex-glass rounded-2xl border border-white/5 p-6 space-y-4 hover:shadow-[0_0_20px_rgba(6,182,212,0.06)] hover:border-cyan-500/20 transition-all duration-300 relative overflow-hidden group">
              <div class="absolute -right-6 -bottom-6 w-20 h-20 bg-cyan-500/5 rounded-full blur-2xl group-hover:scale-125 transition-transform duration-500"></div>
              <div class="flex items-center gap-3 relative z-10">
                <div class="p-2.5 rounded-xl bg-white/5 border border-white/10 text-white">
                  <%- icon('database', { class: 'w-5 h-5' }) %>
                </div>
                <div>
                  <h3 class="text-sm font-bold text-white">Database Slots</h3>
                  <p class="text-xs text-neutral-400">Database capacity</p>
                </div>
              </div>
              <div class="space-y-1.5 relative z-10">
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Allocated</span><span class="text-sm font-bold text-white"><%= typeof databaseSlots !== 'undefined' ? databaseSlots : 0 %> slot(s)</span></div>
              </div>
              <div class="border-t border-white/5 pt-3 space-y-3 relative z-10">
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Price per slot</span><span class="text-sm font-bold text-white"><%= storeConfig.databaseSlotPrice %> coins</span></div>
                <div class="flex items-center gap-2">
                  <button onclick="stepper('database-amount', -1)" class="shrink-0 w-8 h-8 rounded-lg bg-white/5 border border-white/10 text-white flex items-center justify-center hover:bg-white/10 transition cursor-pointer text-sm font-bold">−</button>
                  <input type="number" id="database-amount" min="1" value="1" data-price="<%= storeConfig.databaseSlotPrice %>" data-key="database" class="resource-input flex-1 bg-white/5 border border-white/10 rounded-xl px-3 py-2 text-sm text-white text-center outline-none focus:border-brand-green/30" oninput="updateResourceCard(this)">
                  <button onclick="stepper('database-amount', 1)" class="shrink-0 w-8 h-8 rounded-lg bg-white/5 border border-white/10 text-white flex items-center justify-center hover:bg-white/10 transition cursor-pointer text-sm font-bold">+</button>
                  <span class="text-xs text-neutral-400 shrink-0">slot(s)</span>
                </div>
                <div class="flex items-center justify-between">
                  <div class="text-xs text-neutral-400 space-y-0.5">
                    <div>Total: <span class="text-white font-bold resource-total"><%= storeConfig.databaseSlotPrice %></span> coins</div>
                    <div>Balance after: <span class="text-brand-green font-bold resource-remaining"><%= (balance - storeConfig.databaseSlotPrice).toLocaleString() %></span> coins</div>
                  </div>
                  <button onclick="buyResource('DATABASE_SLOTS', this)" class="px-4 py-2 rounded-xl text-xs font-bold bg-brand-green text-black hover:bg-brand-green-hover transition cursor-pointer">Buy</button>
                </div>
              </div>
            </div>

            <!-- Ports -->
            <div class="cynex-glass rounded-2xl border border-white/5 p-6 space-y-4 hover:shadow-[0_0_20px_rgba(244,63,94,0.06)] hover:border-rose-500/20 transition-all duration-300 relative overflow-hidden group">
              <div class="absolute -right-6 -bottom-6 w-20 h-20 bg-rose-500/5 rounded-full blur-2xl group-hover:scale-125 transition-transform duration-500"></div>
              <div class="flex items-center gap-3 relative z-10">
                <div class="p-2.5 rounded-xl bg-white/5 border border-white/10 text-white">
                  <%- icon('plug', { class: 'w-5 h-5' }) %>
                </div>
                <div>
                  <h3 class="text-sm font-bold text-white">Ports</h3>
                  <p class="text-xs text-neutral-400">Network ports</p>
                </div>
              </div>
              <div class="space-y-1.5 relative z-10">
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Allocated</span><span class="text-sm font-bold text-white"><%= typeof ports !== 'undefined' ? ports : 0 %> port(s)</span></div>
              </div>
              <div class="border-t border-white/5 pt-3 space-y-3 relative z-10">
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Price per port</span><span class="text-sm font-bold text-white"><%= storeConfig.portPrice %> coins</span></div>
                <div class="flex items-center gap-2">
                  <button onclick="stepper('port-amount', -1)" class="shrink-0 w-8 h-8 rounded-lg bg-white/5 border border-white/10 text-white flex items-center justify-center hover:bg-white/10 transition cursor-pointer text-sm font-bold">−</button>
                  <input type="number" id="port-amount" min="1" value="1" data-price="<%= storeConfig.portPrice %>" data-key="port" class="resource-input flex-1 bg-white/5 border border-white/10 rounded-xl px-3 py-2 text-sm text-white text-center outline-none focus:border-brand-green/30" oninput="updateResourceCard(this)">
                  <button onclick="stepper('port-amount', 1)" class="shrink-0 w-8 h-8 rounded-lg bg-white/5 border border-white/10 text-white flex items-center justify-center hover:bg-white/10 transition cursor-pointer text-sm font-bold">+</button>
                  <span class="text-xs text-neutral-400 shrink-0">port(s)</span>
                </div>
                <div class="flex items-center justify-between">
                  <div class="text-xs text-neutral-400 space-y-0.5">
                    <div>Total: <span class="text-white font-bold resource-total"><%= storeConfig.portPrice %></span> coins</div>
                    <div>Balance after: <span class="text-brand-green font-bold resource-remaining"><%= (balance - storeConfig.portPrice).toLocaleString() %></span> coins</div>
                  </div>
                  <button onclick="buyResource('PORTS', this)" class="px-4 py-2 rounded-xl text-xs font-bold bg-brand-green text-black hover:bg-brand-green-hover transition cursor-pointer">Buy</button>
                </div>
              </div>
            </div>

            <!-- Server Slots -->
            <div class="cynex-glass rounded-2xl border border-white/5 p-6 space-y-4 hover:shadow-[0_0_20px_rgba(99,102,241,0.06)] hover:border-indigo-500/20 transition-all duration-300 relative overflow-hidden group">
              <div class="absolute -right-6 -bottom-6 w-20 h-20 bg-indigo-500/5 rounded-full blur-2xl group-hover:scale-125 transition-transform duration-500"></div>
              <div class="flex items-center gap-3 relative z-10">
                <div class="p-2.5 rounded-xl bg-white/5 border border-white/10 text-white">
                  <%- icon('server', { class: 'w-5 h-5' }) %>
                </div>
                <div>
                  <h3 class="text-sm font-bold text-white">Server Slots</h3>
                  <p class="text-xs text-neutral-400">Server capacity</p>
                </div>
              </div>
              <div class="space-y-1.5 relative z-10">
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Allocated</span><span class="text-sm font-bold text-white"><%= typeof serverSlots !== 'undefined' ? serverSlots : 0 %> slot(s)</span></div>
              </div>
              <div class="border-t border-white/5 pt-3 space-y-3 relative z-10">
                <div class="flex justify-between text-xs"><span class="text-neutral-400">Price per slot</span><span class="text-sm font-bold text-white"><%= storeConfig.databaseSlotPrice %> coins</span></div>
                <div class="flex items-center gap-2">
                  <button onclick="stepper('server-amount', -1)" class="shrink-0 w-8 h-8 rounded-lg bg-white/5 border border-white/10 text-white flex items-center justify-center hover:bg-white/10 transition cursor-pointer text-sm font-bold">−</button>
                  <input type="number" id="server-amount" min="1" value="1" data-price="<%= storeConfig.databaseSlotPrice %>" data-key="server" class="resource-input flex-1 bg-white/5 border border-white/10 rounded-xl px-3 py-2 text-sm text-white text-center outline-none focus:border-brand-green/30" oninput="updateResourceCard(this)">
                  <button onclick="stepper('server-amount', 1)" class="shrink-0 w-8 h-8 rounded-lg bg-white/5 border border-white/10 text-white flex items-center justify-center hover:bg-white/10 transition cursor-pointer text-sm font-bold">+</button>
                  <span class="text-xs text-neutral-400 shrink-0">slot(s)</span>
                </div>
                <div class="flex items-center justify-between">
                  <div class="text-xs text-neutral-400 space-y-0.5">
                    <div>Total: <span class="text-white font-bold resource-total"><%= storeConfig.databaseSlotPrice %></span> coins</div>
                    <div>Balance after: <span class="text-brand-green font-bold resource-remaining"><%= (balance - storeConfig.databaseSlotPrice).toLocaleString() %></span> coins</div>
                  </div>
                  <button onclick="buyResource('SERVER_SLOTS', this)" class="px-4 py-2 rounded-xl text-xs font-bold bg-brand-green text-black hover:bg-brand-green-hover transition cursor-pointer">Buy</button>
                </div>
              </div>
            </div>

          </div>

          <% if (products && products.length > 0) { %>
          <div class="cynex-glass rounded-2xl border border-white/5 p-6 space-y-4">
            <h2 class="text-sm font-bold text-white">Featured Products</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
              <% products.forEach(function(product) { %>
              <div class="bg-white/5 rounded-xl border border-white/5 p-4 space-y-3 hover:border-white/15 transition-all">
                <div class="flex items-start justify-between">
                  <div class="flex items-center gap-2.5">
                    <div class="p-2 rounded-lg bg-white/5 border border-white/10 text-white shrink-0">
