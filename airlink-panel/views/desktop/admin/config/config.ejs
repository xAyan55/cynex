<!-- Log Details Modal -->
<div id="logDetailModal" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4 bg-black/70 backdrop-blur-md transition-all duration-300">
  <div class="bg-white dark:bg-neutral-900 rounded-2xl w-full max-w-lg overflow-hidden flex flex-col shadow-2xl border border-neutral-200 dark:border-white/10">
    <div class="flex justify-between items-center px-6 py-5 border-b border-neutral-200 dark:border-white/5">
      <h3 class="text-lg font-bold text-neutral-900 dark:text-white">Log Details</h3>
      <button type="button" class="text-neutral-400 hover:text-neutral-600 dark:hover:text-white transition-colors cursor-pointer" onclick="document.getElementById('logDetailModal').classList.add('hidden')">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </div>
    <div class="p-6 overflow-y-auto max-h-[75vh]">
      <div class="space-y-3">
        <div><span class="text-xs text-neutral-500 uppercase tracking-wider">ID</span><p class="text-sm text-neutral-900 dark:text-white font-mono" id="logDetailId"></p></div>
        <div><span class="text-xs text-neutral-500 uppercase tracking-wider">Action</span><p class="text-sm text-neutral-900 dark:text-white" id="logDetailAction"></p></div>
        <div><span class="text-xs text-neutral-500 uppercase tracking-wider">Time</span><p class="text-sm text-neutral-900 dark:text-white" id="logDetailTime"></p></div>
        <div><span class="text-xs text-neutral-500 uppercase tracking-wider">Admin ID</span><p class="text-sm text-neutral-900 dark:text-white font-mono" id="logDetailAdmin"></p></div>
        <div><span class="text-xs text-neutral-500 uppercase tracking-wider">Reference ID</span><p class="text-sm text-neutral-900 dark:text-white font-mono" id="logDetailRef"></p></div>
        <div><span class="text-xs text-neutral-500 uppercase tracking-wider">IP Address</span><p class="text-sm text-neutral-900 dark:text-white font-mono" id="logDetailIp"></p></div>
        <div><span class="text-xs text-neutral-500 uppercase tracking-wider">Details</span><pre class="text-sm text-neutral-900 dark:text-white bg-neutral-100 dark:bg-neutral-800 rounded-lg p-3 overflow-x-auto mt-1" id="logDetailDetails"></pre></div>
      </div>
    </div>
    <div class="px-6 py-4 border-t border-neutral-200 dark:border-white/5 flex justify-end">
      <button type="button" class="rounded-xl bg-neutral-900 dark:bg-white hover:bg-neutral-700 dark:hover:bg-neutral-200 text-white dark:text-neutral-900 px-5 py-2 text-sm font-medium shadow-sm transition" onclick="document.getElementById('logDetailModal').classList.add('hidden')">Close</button>
    </div>
  </div>
</div>

<script nonce="<%- nonce %>">
(function() {
  var toast = window.showToast || function(m, t) { alert(m); };
  var modal = window.modal || { confirm: function(o) { if (o.onConfirm && confirm(o.title)) o.onConfirm(); } };
  var unsaved = false;

  // -- Tab switching --------------------------------------------------------
  var tabBtns = document.querySelectorAll('.config-tab-btn');
  var panels  = document.querySelectorAll('.config-panel');
  var urlParams = new URLSearchParams(window.location.search);

  function showTab(tab) {
    tabBtns.forEach(function(btn) {
      if (btn.dataset.tab === tab) {
        btn.classList.add('text-neutral-900', 'dark:text-white', 'border-neutral-900', 'dark:border-white');
        btn.classList.remove('text-neutral-400', 'dark:text-neutral-500', 'border-transparent');
      } else {
        btn.classList.remove('text-neutral-900', 'dark:text-white', 'border-neutral-900', 'dark:border-white');
        btn.classList.add('text-neutral-400', 'dark:text-neutral-500', 'border-transparent');
      }
    });
    panels.forEach(function(p) {
      p.classList.toggle('hidden', p.dataset.configPanel !== tab);
    });
  }

  tabBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (unsaved && !confirm('You have unsaved changes. Discard them and switch tabs?')) return;
      showTab(this.dataset.tab);
      var url = new URL(window.location);
      url.searchParams.set('tab', this.dataset.tab);
      window.history.replaceState({}, '', url);
    });
  });

  var initialTab = urlParams.get('tab') || 'economy';
  showTab(initialTab);

  // -- Config form saving ---------------------------------------------------
  document.querySelectorAll('.config-form').forEach(function(form) {
    var category = form.dataset.category;

    // Track unsaved changes
    form.querySelectorAll('input, select').forEach(function(input) {
      input.addEventListener('change', function() { unsaved = true; });
      input.addEventListener('input', function() { unsaved = true; });
    });

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var data = {};
      var inputs = form.querySelectorAll('input, select, textarea');
      inputs.forEach(function(input) {
        if (input.type === 'checkbox') {
          data[input.name] = input.checked;
        } else if (input.type === 'number') {
          data[input.name] = parseFloat(input.value) || 0;
        } else {
          data[input.name] = input.value;
        }
      });

      var submitBtn = form.querySelector('button[type="submit"]');
      if (!submitBtn) return;
      var origText = submitBtn.textContent;
      submitBtn.textContent = 'Saving...';
      submitBtn.disabled = true;

      fetch('/admin/config/' + category, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      .then(function(r) { return r.json(); })
      .then(function(res) {
        if (res.success) {
          toast('Settings saved successfully!', 'success');
          unsaved = false;
        } else {
          toast(res.error || 'Failed to save settings.', 'error');
        }
      })
      .catch(function() { toast('Network error. Please try again.', 'error'); })
      .finally(function() {
        submitBtn.textContent = origText;
        submitBtn.disabled = false;
      });
    });
  });

  // -- Reset buttons --------------------------------------------------------
  document.querySelectorAll('.config-reset-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var form = this.closest('.config-form');
      if (!form) return;
      form.querySelectorAll('input[type="text"], input[type="number"]').forEach(function(input) {
        input.value = input.defaultValue;
      });
      form.querySelectorAll('input[type="checkbox"]').forEach(function(input) {
        input.checked = input.defaultChecked;
      });
      form.querySelectorAll('select').forEach(function(select) {
        var options = select.querySelectorAll('option');
        options.forEach(function(opt) { opt.selected = opt.defaultSelected; });
      });
      unsaved = false;
      toast('Form reset to saved values.', 'info');
    });
  });

  // -- Unsaved warning on navigate away -------------------------------------
  window.addEventListener('beforeunload', function(e) {
    if (unsaved) { e.preventDefault(); e.returnValue = ''; }
  });

  // -- Log detail modal -----------------------------------------------------
  window.showLogDetails = function(logId) {
    var rows = document.querySelectorAll('.log-row');
    var row = null;
    rows.forEach(function(r) {
      if (r.dataset.logId == logId) row = r;
    });
    if (!row) return;
    var cells = row.querySelectorAll('td');
    document.getElementById('logDetailId').textContent = logId;
    document.getElementById('logDetailAction').textContent = cells[1].textContent.trim();
    document.getElementById('logDetailTime').textContent = cells[0].textContent.trim();
    document.getElementById('logDetailAdmin').textContent = cells[2].textContent.trim();
    document.getElementById('logDetailRef').textContent = cells[3].textContent.trim();
    document.getElementById('logDetailIp').textContent = cells[4].textContent.trim();
    var detailsText = cells[5].textContent.trim();
    try {
      var parsed = JSON.parse(detailsText);
      document.getElementById('logDetailDetails').textContent = JSON.stringify(parsed, null, 2);
    } catch(e) {
      document.getElementById('logDetailDetails').textContent = detailsText;
    }
    document.getElementById('logDetailModal').classList.remove('hidden');
  };

  // -- Close modals on overlay click ----------------------------------------
  document.querySelectorAll('.fixed.inset-0').forEach(function(modalEl) {
    modalEl.addEventListener('click', function(e) {
      if (e.target === this) this.classList.add('hidden');
    });
  });

  // -- Product CRUD ---------------------------------------------------------
  var createBtn = document.getElementById('createProductBtn');
  if (createBtn) {
    createBtn.addEventListener('click', function() {
      var form = document.getElementById('createProductForm');
      var data = {};
      var inputs = form.querySelectorAll('input, select');
      inputs.forEach(function(input) {
        if (input.type === 'checkbox') { data[input.name] = input.checked; }
        else if (input.type === 'number') { data[input.name] = parseFloat(input.value) || 0; }
        else { data[input.name] = input.value; }
      });

      createBtn.textContent = 'Creating...';
      createBtn.disabled = true;

      fetch('/admin/config/products/create', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      .then(function(r) { return r.json(); })
      .then(function(res) {
        if (res.success) {
          toast('Product created!', 'success');
          setTimeout(function() { location.reload(); }, 800);
        } else {
          toast(res.error || 'Failed to create product.', 'error');
          createBtn.textContent = 'Create Product';
          createBtn.disabled = false;
        }
      })
      .catch(function() {
        toast('Network error.', 'error');
        createBtn.textContent = 'Create Product';
        createBtn.disabled = false;
      });
    });
  }

  // Product toggle
  document.querySelectorAll('.product-toggle-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var id = this.dataset.productId;
      var self = this;
      fetch('/admin/config/products/' + id + '/toggle', { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(res) {
          if (res.success) { toast('Product updated.', 'success'); setTimeout(function() { location.reload(); }, 500); }
          else toast(res.error || 'Failed.', 'error');
        })
        .catch(function() { toast('Network error.', 'error'); });
    });
  });

  // Product delete
  document.querySelectorAll('.product-delete-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var id = this.dataset.productId;
      var self = this.closest('tr');
      modal.confirm({
        title: 'Delete product?',
        body: 'This action cannot be undone.',
        danger: true,
        confirmLabel: 'Delete',
        onConfirm: function() {
          fetch('/admin/config/products/' + id + '/delete', { method: 'POST' })
            .then(function(r) { return r.json(); })
            .then(function(res) {
              if (res.success) { toast('Product deleted.', 'success'); if (self) self.remove(); }
              else toast(res.error || 'Failed.', 'error');
            })
            .catch(function() { toast('Network error.', 'error'); });
        }
      });
    });
  });

  // Product reorder
  document.querySelectorAll('.product-order-input').forEach(function(input) {
    input.addEventListener('change', function() {
      var id = this.dataset.productId;
      var order = parseInt(this.value, 10) || 0;
      fetch('/admin/config/products/' + id + '/order', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ displayOrder: order })
      })
      .then(function(r) { return r.json(); })
      .then(function(res) { if (res.success) toast('Order updated.', 'success'); })
      .catch(function() {});
    });
  });

  // Product duplicate
  document.querySelectorAll('.product-duplicate-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var id = this.dataset.productId;
      this.textContent = '...';
      fetch('/admin/config/products/' + id + '/duplicate', { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(res) {
          if (res.success) { toast('Product duplicated.', 'success'); setTimeout(function() { location.reload(); }, 500); }
          else toast(res.error || 'Failed.', 'error');
        })
        .catch(function() { toast('Network error.', 'error'); })
        .finally(function() { btn.textContent = 'Copy'; });
    });
  });

  // Product edit modal
  var productEditModal = document.getElementById('productEditModal');
  document.querySelectorAll('.product-edit-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var row = this.closest('tr');
      if (!row) return;
      var cells = row.querySelectorAll('td');
      var productId = row.dataset.productId;
      var name = cells[1].querySelector('.font-medium').textContent.trim();
      var desc = cells[1].querySelector('.text-xs') ? cells[1].querySelector('.text-xs').textContent.trim() : '';
      var actionType = cells[2].textContent.trim();
      var actionValue = cells[3].textContent.trim();
      var price = cells[4].textContent.trim().replace(/,/g, '');
      var icon = cells[1].querySelector('img') ? cells[1].querySelector('img').src : '';
      var featured = row.querySelector('.bg-amber-100, .dark\\\\:bg-amber-500\\/20') !== null;
      var hidden = row.querySelector('.bg-purple-100, .dark\\\\:bg-purple-500\\/20') !== null;
      var enabled = cells[6].querySelector('.bg-emerald-100') !== null;
      var maxPerUser = cells[5].textContent.trim();
      var orderInput = cells[0].querySelector('input');
      var displayOrder = orderInput ? orderInput.value : '0';

      document.getElementById('editProductId').value = productId;
      document.getElementById('editProductName').value = name;
      document.getElementById('editProductDesc').value = desc;
      document.getElementById('editProductActionType').value = actionType;
      document.getElementById('editProductActionValue').value = actionValue;
      document.getElementById('editProductPrice').value = price;
      document.getElementById('editProductIcon').value = icon;
      document.getElementById('editProductDisplayOrder').value = displayOrder;
      document.getElementById('editProductMaxPerUser').value = maxPerUser === '8' ? '' : maxPerUser;
      document.getElementById('editProductFeatured').checked = featured;
      document.getElementById('editProductHidden').checked = hidden;
      document.getElementById('editProductEnabled').checked = enabled;

      productEditModal.classList.remove('hidden');
    });
  });

  document.querySelectorAll('.product-edit-modal-close').forEach(function(btn) {
    btn.addEventListener('click', function() { productEditModal.classList.add('hidden'); });
  });

  document.getElementById('saveEditProductBtn').addEventListener('click', function() {
    var form = document.getElementById('editProductForm');
    var data = {};
    var inputs = form.querySelectorAll('input, select');
    inputs.forEach(function(input) {
      if (input.type === 'checkbox') { data[input.name] = input.checked; }
      else if (input.type === 'number') { data[input.name] = parseFloat(input.value) || 0; }
      else if (input.name !== 'editProductId') { data[input.name] = input.value; }
    });

    var id = document.getElementById('editProductId').value;
    var btn = this;
    btn.textContent = 'Saving...';
    btn.disabled = true;

    fetch('/admin/config/products/' + id + '/update', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (res.success) {
        toast('Product updated!', 'success');
        setTimeout(function() { location.reload(); }, 500);
      } else {
        toast(res.error || 'Failed to update product.', 'error');
        btn.textContent = 'Save Changes';
        btn.disabled = false;
      }
    })
    .catch(function() {
      toast('Network error.', 'error');
      btn.textContent = 'Save Changes';
      btn.disabled = false;
    });
  });

  // Product search/filter
  var productSearchInput = document.getElementById('productSearch');
  var productFilterSelect = document.getElementById('productFilter');
  var clearProductFilters = document.getElementById('clearProductFilters');

  function applyProductFilters() {
    var params = new URLSearchParams(window.location.search);
    params.set('tab', 'products');
    if (productSearchInput && productSearchInput.value) params.set('productSearch', productSearchInput.value);
    else params.delete('productSearch');
    if (productFilterSelect && productFilterSelect.value) params.set('productFilter', productFilterSelect.value);
    else params.delete('productFilter');
    params.delete('productPage');
    window.location.search = params.toString();
  }

  if (productSearchInput) {
    var debounceTimer;
    productSearchInput.addEventListener('input', function() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(applyProductFilters, 500);
    });
  }
  if (productFilterSelect) productFilterSelect.addEventListener('change', applyProductFilters);
  if (clearProductFilters) {
    clearProductFilters.addEventListener('click', function() {
      if (productSearchInput) productSearchInput.value = '';
      if (productFilterSelect) productFilterSelect.value = '';
      applyProductFilters();
    });
  }

  // -- Coupon CRUD ----------------------------------------------------------
  var createCouponPanel = document.getElementById('createCouponPanel');
  var showCreateCouponBtn = document.getElementById('showCreateCouponBtn');
  var cancelCreateCoupon = document.getElementById('cancelCreateCoupon');

  if (showCreateCouponBtn) {
    showCreateCouponBtn.addEventListener('click', function() {
      createCouponPanel.classList.toggle('hidden');
    });
  }
  if (cancelCreateCoupon) {
    cancelCreateCoupon.addEventListener('click', function() {
      createCouponPanel.classList.add('hidden');
    });
  }

  // Generate coupon code
  var generateBtn = document.getElementById('generateCouponCode');
  var codeInput = document.getElementById('couponCodeInput');
  if (generateBtn && codeInput) {
    generateBtn.addEventListener('click', function() {
      var chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
      var code = '';
      for (var i = 0; i < 8; i++) code += chars.charAt(Math.floor(Math.random() * chars.length));
      codeInput.value = code;
    });
  }

  // Create coupon
  var createCouponBtn = document.getElementById('createCouponBtn');
  if (createCouponBtn) {
    createCouponBtn.addEventListener('click', function() {
      var form = document.getElementById('createCouponForm');
      var data = {};
      var inputs = form.querySelectorAll('input, select');
      inputs.forEach(function(input) {
        if (input.type === 'checkbox') { data[input.name] = input.checked; }
        else if (input.type === 'number') { data[input.name] = parseFloat(input.value) || 0; }
        else { data[input.name] = input.value; }
      });

      createCouponBtn.textContent = 'Creating...';
      createCouponBtn.disabled = true;

      fetch('/admin/config/coupons/create', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      .then(function(r) { return r.json(); })
      .then(function(res) {
        if (res.success) {
          toast('Coupon created!', 'success');
          setTimeout(function() { location.reload(); }, 800);
        } else {
          toast(res.error || 'Failed to create coupon.', 'error');
          createCouponBtn.textContent = 'Create Coupon';
          createCouponBtn.disabled = false;
        }
      })
      .catch(function() {
        toast('Network error.', 'error');
        createCouponBtn.textContent = 'Create Coupon';
        createCouponBtn.disabled = false;
      });
    });
  }

  // Coupon toggle
  document.querySelectorAll('.coupon-toggle-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var id = this.dataset.couponId;
      fetch('/admin/config/coupons/' + id + '/toggle', { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(res) {
          if (res.success) { toast('Coupon updated.', 'success'); setTimeout(function() { location.reload(); }, 500); }
          else toast(res.error || 'Failed.', 'error');
        })
        .catch(function() { toast('Network error.', 'error'); });
    });
  });

  // Coupon delete
  document.querySelectorAll('.coupon-delete-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var id = this.dataset.couponId;
      var row = this.closest('tr');
      modal.confirm({
        title: 'Delete coupon?',
        body: 'This action cannot be undone.',
        danger: true,
        confirmLabel: 'Delete',
        onConfirm: function() {
          fetch('/admin/config/coupons/' + id + '/delete', { method: 'POST' })
            .then(function(r) { return r.json(); })
            .then(function(res) {
              if (res.success) { toast('Coupon deleted.', 'success'); if (row) row.remove(); }
              else toast(res.error || 'Failed.', 'error');
            })
            .catch(function() { toast('Network error.', 'error'); });
        }
      });
    });
  });

  // Coupon duplicate
  document.querySelectorAll('.coupon-duplicate-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var id = this.dataset.couponId;
      this.textContent = '...';
      fetch('/admin/config/coupons/' + id + '/duplicate', { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(res) {
          if (res.success) { toast('Coupon duplicated.', 'success'); setTimeout(function() { location.reload(); }, 500); }
          else toast(res.error || 'Failed.', 'error');
        })
        .catch(function() { toast('Network error.', 'error'); })
        .finally(function() { btn.textContent = 'Copy'; });
    });
  });

  // Coupon edit modal
  var couponEditModal = document.getElementById('couponEditModal');
  document.querySelectorAll('.coupon-edit-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var row = this.closest('tr');
      if (!row) return;
      var cells = row.querySelectorAll('td');
      var couponId = row.dataset.couponId;
      var code = cells[0].textContent.trim();
      var desc = cells[1].textContent.trim();
      var rewardParts = cells[2].textContent.trim().split(' x');
      var actionType = rewardParts[0];
      var actionValue = rewardParts[1] || '';
      var usesText = cells[3].textContent.trim();
      var maxUses = usesText.split(' | ')[0];
      var perUserLimit = usesText.split(' | ')[1] ? usesText.split(' | ')[1].replace('/user', '') : '1';
      var expiresText = cells[4].textContent.trim();
      var enabled = cells[5].querySelector('.bg-emerald-100') !== null;

      document.getElementById('editCouponId').value = couponId;
      document.getElementById('editCouponCode').value = code;
      document.getElementById('editCouponDesc').value = desc === '-' ? '' : desc;
      document.getElementById('editCouponActionType').value = actionType;
      document.getElementById('editCouponActionValue').value = actionValue;
      document.getElementById('editCouponMaxUses').value = maxUses === '8' ? '0' : maxUses;
      document.getElementById('editCouponPerUserLimit').value = perUserLimit || '1';
      document.getElementById('editCouponStartsAt').value = '';
      document.getElementById('editCouponExpiresAt').value = expiresText !== 'Never' ? expiresText : '';
      document.getElementById('editCouponEnabled').checked = enabled;

      couponEditModal.classList.remove('hidden');
    });
  });

  document.querySelectorAll('.coupon-edit-modal-close').forEach(function(btn) {
    btn.addEventListener('click', function() { couponEditModal.classList.add('hidden'); });
  });

  document.getElementById('saveEditCouponBtn').addEventListener('click', function() {
    var form = document.getElementById('editCouponForm');
    var data = {};
    var inputs = form.querySelectorAll('input, select');
    inputs.forEach(function(input) {
      if (input.type === 'checkbox') { data[input.name] = input.checked; }
      else if (input.type === 'number') { data[input.name] = parseFloat(input.value) || 0; }
      else if (input.name !== 'editCouponId') { data[input.name] = input.value; }
    });

    var id = document.getElementById('editCouponId').value;
    var btn = this;
    btn.textContent = 'Saving...';
    btn.disabled = true;

    fetch('/admin/config/coupons/' + id + '/update', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (res.success) {
        toast('Coupon updated!', 'success');
        setTimeout(function() { location.reload(); }, 500);
      } else {
        toast(res.error || 'Failed to update coupon.', 'error');
        btn.textContent = 'Save Changes';
        btn.disabled = false;
      }
    })
    .catch(function() {
      toast('Network error.', 'error');
      btn.textContent = 'Save Changes';
      btn.disabled = false;
    });
  });

  // Coupon search
  var couponSearchInput = document.getElementById('couponSearch');
  var clearCouponSearch = document.getElementById('clearCouponSearch');

  function applyCouponSearch() {
    var params = new URLSearchParams(window.location.search);
    params.set('tab', 'coupons');
    if (couponSearchInput && couponSearchInput.value) params.set('couponSearch', couponSearchInput.value);
    else params.delete('couponSearch');
    params.delete('couponPage');
    window.location.search = params.toString();
  }

  if (couponSearchInput) {
    var debounceTimer2;
    couponSearchInput.addEventListener('input', function() {
      clearTimeout(debounceTimer2);
      debounceTimer2 = setTimeout(applyCouponSearch, 500);
    });
  }
  if (clearCouponSearch) {
    clearCouponSearch.addEventListener('click', function() {
      if (couponSearchInput) couponSearchInput.value = '';
      applyCouponSearch();
    });
  }

})();
</script>

