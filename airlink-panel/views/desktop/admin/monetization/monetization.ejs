<%- include('../../components/header', { title: 'Monetization Configuration' }) %>

<main class="min-h-screen m-auto bg-mono-bg text-white">
  <div class="flex min-h-screen">
    <div class="w-60 h-full"><%- include('../../components/template') %></div>
    <div id="page-content" class="flex-1 overflow-y-auto pt-16 pb-12">
      
      <!-- Top banner headers -->
      <div class="px-8 pt-5">
        <h1 class="text-base font-medium text-neutral-800 dark:text-white">Monetization Panel</h1>
        <p class="mt-0.5 text-sm text-neutral-500">Configure provider modules, customize offer values, view metrics, manage streaks, and fraud scores.</p>
      </div>

      <div class="px-8 mt-5">
        
        <!-- Tab bar -->
        <div class="flex gap-0.5 mb-6 border-b border-neutral-200 dark:border-neutral-700/40 overflow-x-auto">
          <button type="button" data-tab="general" class="mon-tab-btn px-4 py-2.5 text-sm font-medium transition -mb-px border-b-2 border-transparent hover:text-white text-neutral-400 whitespace-nowrap"><%- icon('settings', { class: 'w-4 h-4 inline mr-1.5 -mt-0.5' }) %>General</button>
          <button type="button" data-tab="providers" class="mon-tab-btn px-4 py-2.5 text-sm font-medium transition -mb-px border-b-2 border-transparent hover:text-white text-neutral-400 whitespace-nowrap"><%- icon('network', { class: 'w-4 h-4 inline mr-1.5 -mt-0.5' }) %>Providers</button>
          <button type="button" data-tab="placements" class="mon-tab-btn px-4 py-2.5 text-sm font-medium transition -mb-px border-b-2 border-transparent hover:text-white text-neutral-400 whitespace-nowrap"><%- icon('layout', { class: 'w-4 h-4 inline mr-1.5 -mt-0.5' }) %>Placements</button>
          <button type="button" data-tab="offers" class="mon-tab-btn px-4 py-2.5 text-sm font-medium transition -mb-px border-b-2 border-transparent hover:text-white text-neutral-400 whitespace-nowrap"><%- icon('package', { class: 'w-4 h-4 inline mr-1.5 -mt-0.5' }) %>Offers</button>
          <button type="button" data-tab="rewards" class="mon-tab-btn px-4 py-2.5 text-sm font-medium transition -mb-px border-b-2 border-transparent hover:text-white text-neutral-400 whitespace-nowrap"><%- icon('gift', { class: 'w-4 h-4 inline mr-1.5 -mt-0.5' }) %>Rewards</button>
          <button type="button" data-tab="economy" class="mon-tab-btn px-4 py-2.5 text-sm font-medium transition -mb-px border-b-2 border-transparent hover:text-white text-neutral-400 whitespace-nowrap"><%- icon('coins', { class: 'w-4 h-4 inline mr-1.5 -mt-0.5' }) %>Economy</button>
          <button type="button" data-tab="limits" class="mon-tab-btn px-4 py-2.5 text-sm font-medium transition -mb-px border-b-2 border-transparent hover:text-white text-neutral-400 whitespace-nowrap"><%- icon('shield-alert', { class: 'w-4 h-4 inline mr-1.5 -mt-0.5' }) %>Limits</button>
          <button type="button" data-tab="fraud" class="mon-tab-btn px-4 py-2.5 text-sm font-medium transition -mb-px border-b-2 border-transparent hover:text-white text-neutral-400 whitespace-nowrap"><%- icon('alert-octagon', { class: 'w-4 h-4 inline mr-1.5 -mt-0.5' }) %>Fraud Flags</button>
          <button type="button" data-tab="analytics" class="mon-tab-btn px-4 py-2.5 text-sm font-medium transition -mb-px border-b-2 border-transparent hover:text-white text-neutral-400 whitespace-nowrap"><%- icon('bar-chart-3', { class: 'w-4 h-4 inline mr-1.5 -mt-0.5' }) %>Analytics</button>
          <button type="button" data-tab="scheduler" class="mon-tab-btn px-4 py-2.5 text-sm font-medium transition -mb-px border-b-2 border-transparent hover:text-white text-neutral-400 whitespace-nowrap"><%- icon('clock', { class: 'w-4 h-4 inline mr-1.5 -mt-0.5' }) %>Scheduler</button>
          <button type="button" data-tab="flags" class="mon-tab-btn px-4 py-2.5 text-sm font-medium transition -mb-px border-b-2 border-transparent hover:text-white text-neutral-400 whitespace-nowrap"><%- icon('toggle-right', { class: 'w-4 h-4 inline mr-1.5 -mt-0.5' }) %>Flags</button>
          <button type="button" data-tab="logs" class="mon-tab-btn px-4 py-2.5 text-sm font-medium transition -mb-px border-b-2 border-transparent hover:text-white text-neutral-400 whitespace-nowrap"><%- icon('file-text', { class: 'w-4 h-4 inline mr-1.5 -mt-0.5' }) %>Logs</button>
          <button type="button" data-tab="notifications" class="mon-tab-btn px-4 py-2.5 text-sm font-medium transition -mb-px border-b-2 border-transparent hover:text-white text-neutral-400 whitespace-nowrap"><%- icon('bell', { class: 'w-4 h-4 inline mr-1.5 -mt-0.5' }) %>Notifications</button>
        </div>

        <!-- Metric overview boxes -->
        <div class="grid grid-cols-2 lg:grid-cols-6 gap-4 mb-6">
          <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3">
            <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">Generated Today</p>
            <p class="text-2xl font-bold text-neutral-800 dark:text-white tabular-nums"><%= stats.coinsGeneratedToday %></p>
          </div>
          <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3">
            <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">Spent Today</p>
            <p class="text-2xl font-bold text-neutral-800 dark:text-white tabular-nums"><%= stats.coinsSpentToday %></p>
          </div>
          <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3">
            <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">Total Outstanding</p>
            <p class="text-2xl font-bold text-neutral-800 dark:text-white tabular-nums"><%= stats.totalOutstanding %></p>
          </div>
          <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3">
            <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">Active Earners</p>
            <p class="text-2xl font-bold text-neutral-800 dark:text-white tabular-nums"><%= stats.activeEarners %></p>
          </div>
          <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3">
            <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">Completions Today</p>
            <p class="text-2xl font-bold text-neutral-800 dark:text-white tabular-nums"><%= stats.completedOffersCount %></p>
          </div>
          <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3">
            <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">Inflation Rate</p>
            <p class="text-2xl font-bold text-neutral-800 dark:text-white tabular-nums"><%= stats.inflationRate %>%</p>
          </div>
        </div>

        <!-- Form save/reset toast indicators -->
        <div id="statusToast" class="hidden fixed bottom-5 right-5 bg-green-500 text-black px-4 py-2 rounded-xl text-sm font-semibold shadow-lg z-50"></div>

        <!-- ═══ GENERAL TAB ════════════════════════════════════════════════════ -->
        <div id="tab-panel-general" class="tab-content-panel hidden space-y-5">
          <div class="bg-white dark:bg-white/5 rounded-xl border border-neutral-200 dark:border-white/5 shadow-sm dark:shadow-none">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-50 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">General Monetization Configurations</h2>
            <form class="monetization-form" data-category="monetization">
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 px-5 py-5">
                <div>
                  <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Enable Monetization</label>
                  <select name="enabled" class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
                    <option value="true" <%= monetization.enabled ? 'selected' : '' %>>Enabled</option>
                    <option value="false" <%= !monetization.enabled ? 'selected' : '' %>>Disabled</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Maintenance Mode</label>
                  <select name="maintenanceMode" class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
                    <option value="true" <%= monetization.maintenanceMode ? 'selected' : '' %>>Enabled</option>
                    <option value="false" <%= !monetization.maintenanceMode ? 'selected' : '' %>>Disabled</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Require Login</label>
                  <select name="requireLogin" class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
                    <option value="true" <%= monetization.requireLogin ? 'selected' : '' %>>Enabled</option>
                    <option value="false" <%= !monetization.requireLogin ? 'selected' : '' %>>Disabled</option>
                  </select>
                </div>
              </div>
              <div class="px-5 pb-5 border-t border-neutral-200 dark:border-white/5 pt-4 flex justify-end gap-3">
                <button type="submit" class="rounded-xl bg-neutral-900 dark:bg-white hover:bg-neutral-700 dark:hover:bg-neutral-200 text-white dark:text-neutral-900 px-5 py-2 text-sm font-medium shadow-sm transition">Save Configuration</button>
              </div>
            </form>
          </div>
        </div>

        <!-- ═══ PROVIDERS TAB ══════════════════════════════════════════════════ -->
        <div id="tab-panel-providers" class="tab-content-panel hidden space-y-5">
          <% providers.forEach(provider => { %>
            <div class="bg-white dark:bg-white/5 rounded-xl border border-neutral-200 dark:border-white/5 shadow-sm dark:shadow-none mb-6">
              <div class="flex justify-between items-center px-5 py-3.5 bg-neutral-50 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">
                <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white flex items-center">
                  <span class="inline-block w-2.5 h-2.5 rounded-full mr-2 <%= provider.status === 'HEALTHY' ? 'bg-green-500' : 'bg-red-500' %>"></span>
                  <%= provider.name %> Settings
                </h2>
                <div class="flex items-center gap-3">
                  <button type="button" onclick="testProvider('<%= provider.id %>')" class="text-xs bg-white/5 border border-white/10 hover:bg-white/10 px-3 py-1.5 rounded-lg font-semibold transition">Test Configuration</button>
                </div>
              </div>
              <form class="monetization-form" data-category="monetization">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 px-5 py-5">
                  <div>
                    <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Enable <%= provider.name %></label>
                    <select name="<%= provider.id %>Enabled" class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
                      <option value="true" <%= monetization[provider.id + 'Enabled'] ? 'selected' : '' %>>Enabled</option>
                      <option value="false" <%= !monetization[provider.id + 'Enabled'] ? 'selected' : '' %>>Disabled</option>
                    </select>
                  </div>
                  <% provider.fields.forEach(field => { %>
                    <div>
                      <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2"><%= field.label %></label>
                      <input type="<%= field.type %>" name="<%= provider.id %><%= field.key.charAt(0).toUpperCase() + field.key.slice(1) %>" 
                        value="<%= monetization[provider.id + field.key.charAt(0).toUpperCase() + field.key.slice(1)] || '' %>"
                        class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
                    </div>
                  <% }); %>
                </div>
                <div class="px-5 pb-5 border-t border-neutral-200 dark:border-white/5 pt-4 flex justify-end gap-3">
                  <button type="submit" class="rounded-xl bg-neutral-900 dark:bg-white hover:bg-neutral-700 dark:hover:bg-neutral-200 text-white dark:text-neutral-900 px-5 py-2 text-sm font-medium shadow-sm transition">Save <%= provider.name %></button>
                </div>
              </form>
            </div>
          <% }); %>
        </div>

        <!-- ═══ PLACEMENTS TAB ═════════════════════════════════════════════════ -->
        <div id="tab-panel-placements" class="tab-content-panel hidden space-y-5">
          <div class="bg-white dark:bg-white/5 rounded-xl border border-neutral-200 dark:border-white/5 shadow-sm dark:shadow-none">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-50 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">Ad Placement Configuration</h2>
            <p class="text-xs text-neutral-500 px-5 pt-3">Choose which ad format appears at each position. Select "Disabled" to remove the placement. Each format requires its Zone ID configured in the Providers tab.</p>
            <form class="monetization-form" data-category="monetization">
              <div class="px-5 py-3 bg-neutral-50/50 dark:bg-white/[0.02] border-b border-neutral-200 dark:border-white/5">
                <p class="text-xs font-semibold text-neutral-600 dark:text-neutral-400 uppercase tracking-wider">Dashboard</p>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 px-5 py-5">
                <div>
                  <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Header (below title)</label>
                  <select name="placementDashboardHeader" class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
                    <option value="" <%= !monetization.placementDashboardHeader ? 'selected' : '' %>>Disabled</option>
                    <option value="728x90" <%= monetization.placementDashboardHeader === '728x90' ? 'selected' : '' %>>728×90 Leaderboard</option>
                    <option value="banner" <%= monetization.placementDashboardHeader === 'banner' ? 'selected' : '' %>>Responsive Banner</option>
                    <option value="300x250" <%= monetization.placementDashboardHeader === '300x250' ? 'selected' : '' %>>300×250 Rectangle</option>
                    <option value="native" <%= monetization.placementDashboardHeader === 'native' ? 'selected' : '' %>>Native Banner</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Middle (between stats & servers)</label>
                  <select name="placementDashboardMiddle" class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
                    <option value="" <%= !monetization.placementDashboardMiddle ? 'selected' : '' %>>Disabled</option>
                    <option value="300x250" <%= monetization.placementDashboardMiddle === '300x250' ? 'selected' : '' %>>300×250 Rectangle</option>
                    <option value="native" <%= monetization.placementDashboardMiddle === 'native' ? 'selected' : '' %>>Native Banner</option>
                    <option value="728x90" <%= monetization.placementDashboardMiddle === '728x90' ? 'selected' : '' %>>728×90 Leaderboard</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Bottom (after server list)</label>
                  <select name="placementDashboardBottom" class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
                    <option value="" <%= !monetization.placementDashboardBottom ? 'selected' : '' %>>Disabled</option>
                    <option value="728x90" <%= monetization.placementDashboardBottom === '728x90' ? 'selected' : '' %>>728×90 Leaderboard</option>
                    <option value="banner" <%= monetization.placementDashboardBottom === 'banner' ? 'selected' : '' %>>Responsive Banner</option>
                    <option value="native" <%= monetization.placementDashboardBottom === 'native' ? 'selected' : '' %>>Native Banner</option>
                  </select>
                </div>
              </div>

              <div class="px-5 py-3 bg-neutral-50/50 dark:bg-white/[0.02] border-y border-neutral-200 dark:border-white/5">
                <p class="text-xs font-semibold text-neutral-600 dark:text-neutral-400 uppercase tracking-wider">Instances</p>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 px-5 py-5">
                <div>
                  <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Top (below title)</label>
                  <select name="placementInstancesTop" class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
                    <option value="" <%= !monetization.placementInstancesTop ? 'selected' : '' %>>Disabled</option>
                    <option value="banner" <%= monetization.placementInstancesTop === 'banner' ? 'selected' : '' %>>Responsive Banner</option>
                    <option value="728x90" <%= monetization.placementInstancesTop === '728x90' ? 'selected' : '' %>>728×90 Leaderboard</option>
                    <option value="300x250" <%= monetization.placementInstancesTop === '300x250' ? 'selected' : '' %>>300×250 Rectangle</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Middle (between filters & list)</label>
                  <select name="placementInstancesMiddle" class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
                    <option value="" <%= !monetization.placementInstancesMiddle ? 'selected' : '' %>>Disabled</option>
                    <option value="native" <%= monetization.placementInstancesMiddle === 'native' ? 'selected' : '' %>>Native Banner</option>
                    <option value="300x250" <%= monetization.placementInstancesMiddle === '300x250' ? 'selected' : '' %>>300×250 Rectangle</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Bottom</label>
                  <select name="placementInstancesBottom" class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
                    <option value="" <%= !monetization.placementInstancesBottom ? 'selected' : '' %>>Disabled</option>
                    <option value="728x90" <%= monetization.placementInstancesBottom === '728x90' ? 'selected' : '' %>>728×90 Leaderboard</option>
                    <option value="banner" <%= monetization.placementInstancesBottom === 'banner' ? 'selected' : '' %>>Responsive Banner</option>
                  </select>
                </div>
              </div>

              <div class="px-5 py-3 bg-neutral-50/50 dark:bg-white/[0.02] border-y border-neutral-200 dark:border-white/5">
                <p class="text-xs font-semibold text-neutral-600 dark:text-neutral-400 uppercase tracking-wider">Earn</p>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 px-5 py-5">
                <div>
                  <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">After Link Section (Native)</label>
                  <select name="placementEarnNative" class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
                    <option value="" <%= !monetization.placementEarnNative ? 'selected' : '' %>>Disabled</option>
                    <option value="native" <%= monetization.placementEarnNative === 'native' ? 'selected' : '' %>>Native Banner</option>
                    <option value="300x250" <%= monetization.placementEarnNative === '300x250' ? 'selected' : '' %>>300×250 Rectangle</option>
                    <option value="728x90" <%= monetization.placementEarnNative === '728x90' ? 'selected' : '' %>>728×90 Leaderboard</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">After AFK Section (300×250)</label>
                  <select name="placementEarn300x250" class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
                    <option value="" <%= !monetization.placementEarn300x250 ? 'selected' : '' %>>Disabled</option>
                    <option value="300x250" <%= monetization.placementEarn300x250 === '300x250' ? 'selected' : '' %>>300×250 Rectangle</option>
                    <option value="native" <%= monetization.placementEarn300x250 === 'native' ? 'selected' : '' %>>Native Banner</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Below Streak (728×90)</label>
                  <select name="placementEarn728x90" class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
                    <option value="" <%= !monetization.placementEarn728x90 ? 'selected' : '' %>>Disabled</option>
                    <option value="728x90" <%= monetization.placementEarn728x90 === '728x90' ? 'selected' : '' %>>728×90 Leaderboard</option>
                    <option value="banner" <%= monetization.placementEarn728x90 === 'banner' ? 'selected' : '' %>>Responsive Banner</option>
                  </select>
                </div>
              </div>

              <div class="px-5 py-3 bg-neutral-50/50 dark:bg-white/[0.02] border-y border-neutral-200 dark:border-white/5">
                <p class="text-xs font-semibold text-neutral-600 dark:text-neutral-400 uppercase tracking-wider">Store, Wallet, Purchases, Redeem</p>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 px-5 py-5">
                <div>
                  <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Store Top</label>
                  <select name="placementStoreTop" class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
                    <option value="" <%= !monetization.placementStoreTop ? 'selected' : '' %>>Disabled</option>
                    <option value="banner" <%= monetization.placementStoreTop === 'banner' ? 'selected' : '' %>>Responsive Banner</option>
