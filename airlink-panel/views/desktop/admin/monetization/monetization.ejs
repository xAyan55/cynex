        <!-- ═══ FRAUD TAB ══════════════════════════════════════════════════════ -->
        <div id="tab-panel-fraud" class="tab-content-panel hidden space-y-5">
          <div class="bg-white dark:bg-white/5 rounded-xl border border-neutral-200 dark:border-white/5 shadow-sm">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-50 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">Active Fraud Violations</h2>
            
            <div class="overflow-x-auto">
              <table class="w-full text-left border-collapse text-sm">
                <thead>
                  <tr class="bg-neutral-50 dark:bg-white/5 text-neutral-500 font-semibold border-b border-neutral-200 dark:border-white/5">
                    <th class="px-5 py-3">User ID</th>
                    <th class="px-5 py-3">Type</th>
                    <th class="px-5 py-3">Severity</th>
                    <th class="px-5 py-3">IP Address</th>
                    <th class="px-5 py-3">Status</th>
                    <th class="px-5 py-3 text-right">Actions</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-neutral-200 dark:divide-white/5">
                  <% if (fraudLogs.length === 0) { %>
                    <tr>
                      <td colspan="6" class="px-5 py-8 text-center text-neutral-500">No active fraud alerts detected.</td>
                    </tr>
                  <% } else { %>
                    <% fraudLogs.forEach(log => { %>
                      <tr class="hover:bg-neutral-50/50 dark:hover:bg-white/[0.02] transition">
                        <td class="px-5 py-3 font-semibold text-neutral-800 dark:text-white">User #<%= log.userId %></td>
                        <td class="px-5 py-3 text-neutral-400 text-xs font-mono"><%= log.type %></td>
                        <td class="px-5 py-3">
                          <span class="inline-block px-2 py-0.5 rounded text-xs border <%= log.severity === 'HIGH' ? 'bg-red-500/10 text-red-400 border-red-500/20' : 'bg-amber-500/10 text-amber-400 border-amber-500/20' %>">
                            <%= log.severity %>
                          </span>
                        </td>
                        <td class="px-5 py-3 text-neutral-500 text-xs font-mono"><%= log.ipAddress || '—' %></td>
                        <td class="px-5 py-3">
                          <span class="inline-block w-2 h-2 rounded-full bg-amber-500 mr-1.5"></span>
                          <span class="text-xs text-amber-400"><%= log.status %></span>
                        </td>
                        <td class="px-5 py-3 text-right space-x-2">
                          <button onclick="resolveFraud(<%= log.id %>, 'RESOLVED')" class="text-xs bg-green-500/10 text-green-400 border border-green-500/20 hover:bg-green-500 hover:text-black px-2.5 py-1 rounded transition">Dismiss</button>
                          <button onclick="resolveFraud(<%= log.id %>, 'DISMISSED')" class="text-xs bg-white/5 border border-white/10 hover:bg-white/10 px-2.5 py-1 rounded transition text-neutral-400 hover:text-white">Ignore</button>
                        </td>
                      </tr>
                    <% }); %>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- ═══ ANALYTICS TAB ══════════════════════════════════════════════════ -->
        <div id="tab-panel-analytics" class="tab-content-panel hidden space-y-5">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div class="bg-white dark:bg-white/5 rounded-xl border border-neutral-200 dark:border-white/5 p-5">
              <h3 class="text-sm font-semibold text-neutral-800 dark:text-white mb-3">Daily Earnings Flow</h3>
              <div class="h-48 bg-neutral-100 dark:bg-neutral-700/20 rounded-xl flex items-center justify-center text-neutral-500 text-xs">
                Real-time chart will display monetization flow statistics.
              </div>
            </div>
            <div class="bg-white dark:bg-white/5 rounded-xl border border-neutral-200 dark:border-white/5 p-5">
              <h3 class="text-sm font-semibold text-neutral-800 dark:text-white mb-3">Provider Distributions</h3>
              <div class="h-48 bg-neutral-100 dark:bg-neutral-700/20 rounded-xl flex items-center justify-center text-neutral-500 text-xs">
                Chart represents top completed opportunities.
              </div>
            </div>
          </div>
        </div>

        <!-- ═══ SCHEDULER TAB ══════════════════════════════════════════════════ -->
        <div id="tab-panel-scheduler" class="tab-content-panel hidden space-y-5">
          <div class="bg-white dark:bg-white/5 rounded-xl border border-neutral-200 dark:border-white/5 shadow-sm">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-50 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">Background Cron Jobs</h2>
            
            <div class="p-5">
              <p class="text-sm text-neutral-500">Scheduler background workers handle AFK cleanups, expired sessions, and logs compaction on standard 60-second intervals.</p>
            </div>
          </div>
        </div>

        <!-- ═══ FLAGS TAB ══════════════════════════════════════════════════════ -->
        <div id="tab-panel-flags" class="tab-content-panel hidden space-y-5">
          <div class="bg-white dark:bg-white/5 rounded-xl border border-neutral-200 dark:border-white/5 shadow-sm">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-50 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">System Feature Flags</h2>
            <form class="monetization-form" data-category="monetization">
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 px-5 py-5">
                <div>
                  <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Enable Offers Section</label>
                  <select name="offersFeatureFlag" class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
                    <option value="true" <%= monetization.offersFeatureFlag !== false ? 'selected' : '' %>>Enabled</option>
                    <option value="false" <%= monetization.offersFeatureFlag === false ? 'selected' : '' %>>Disabled</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Enable AFK Section</label>
                  <select name="afkFeatureFlag" class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
                    <option value="true" <%= monetization.afkFeatureFlag !== false ? 'selected' : '' %>>Enabled</option>
                    <option value="false" <%= monetization.afkFeatureFlag === false ? 'selected' : '' %>>Disabled</option>
                  </select>
                </div>
              </div>
              <div class="px-5 pb-5 border-t border-neutral-200 dark:border-white/5 pt-4 flex justify-end gap-3">
                <button type="submit" class="rounded-xl bg-neutral-900 dark:bg-white hover:bg-neutral-700 dark:hover:bg-neutral-200 text-white dark:text-neutral-900 px-5 py-2 text-sm font-medium shadow-sm transition">Save Flags</button>
              </div>
            </form>
          </div>
        </div>

        <!-- ═══ LOGS TAB ═══════════════════════════════════════════════════════ -->
        <div id="tab-panel-logs" class="tab-content-panel hidden space-y-5">
          <div class="bg-white dark:bg-white/5 rounded-xl border border-neutral-200 dark:border-white/5 shadow-sm">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-50 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">Audit History logs</h2>
            <div class="p-5">
              <p class="text-sm text-neutral-500">View detailed operations inside the Configuration panel audit history logs.</p>
            </div>
          </div>
        </div>

        <!-- ═══ NOTIFICATIONS TAB ══════════════════════════════════════════════ -->
        <div id="tab-panel-notifications" class="tab-content-panel hidden space-y-5">
          <div class="bg-white dark:bg-white/5 rounded-xl border border-neutral-200 dark:border-white/5 shadow-sm">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-50 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">Notification Hooks</h2>
            <div class="p-5">
              <p class="text-sm text-neutral-500">Configure push hooks, webhooks, and alerts options.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</main>

<!-- Create/Edit Offer Modal -->
<div id="offerModal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4">
  <div class="bg-[#141414] border border-white/5 w-full max-w-lg rounded-2xl shadow-2xl p-6">
    <h3 id="modalTitle" class="text-lg font-bold text-white mb-4">Add Offer</h3>
    <form id="offerForm">
      <input type="hidden" id="offerId" name="id">
      <div class="space-y-4">
        <div>
          <label class="block text-xs font-semibold text-neutral-400 mb-1">Offer Name</label>
          <input type="text" id="offerName" name="name" required class="w-full bg-white/5 border border-white/5 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none focus:border-green-500/30">
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-semibold text-neutral-400 mb-1">Type</label>
            <select id="offerType" name="type" class="w-full bg-white/5 border border-white/5 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none focus:border-green-500/30">
              <option value="OFFER">Offer</option>
              <option value="ADS">Ads</option>
              <option value="CUSTOM">Custom</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-neutral-400 mb-1">Provider</label>
            <select id="offerProvider" name="provider" class="w-full bg-white/5 border border-white/5 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none focus:border-green-500/30">
              <option value="LINKVERTISE">Linkvertise</option>
              <option value="ADSTERRA">Adsterra</option>
              <option value="LOOTLABS">LootLabs</option>
            </select>
          </div>
        </div>
        <div>
          <label class="block text-xs font-semibold text-neutral-400 mb-1">Target Direct URL</label>
          <input type="text" id="offerTargetUrl" name="targetUrl" required class="w-full bg-white/5 border border-white/5 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none focus:border-green-500/30">
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-semibold text-neutral-400 mb-1">Cooldown (Seconds)</label>
            <input type="number" id="offerCooldown" name="cooldown" value="0" class="w-full bg-white/5 border border-white/5 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none focus:border-green-500/30">
          </div>
          <div>
            <label class="block text-xs font-semibold text-neutral-400 mb-1">Sort Order</label>
            <input type="number" id="offerSortOrder" name="sortOrder" value="0" class="w-full bg-white/5 border border-white/5 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none focus:border-green-500/30">
          </div>
        </div>
        
        <!-- Single Reward Selection (simplifies UI input to bind mapping array) -->
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-semibold text-neutral-400 mb-1">Reward Type</label>
            <select id="rewardType" class="w-full bg-white/5 border border-white/5 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none">
              <option value="COINS">Coins</option>
              <option value="RAM">RAM (MB)</option>
              <option value="CPU">CPU (%)</option>
              <option value="DISK">Disk (MB)</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-neutral-400 mb-1">Reward Value</label>
            <input type="number" id="rewardAmount" value="10" class="w-full bg-white/5 border border-white/5 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none">
          </div>
        </div>
      </div>
      
      <div class="flex justify-end gap-3 mt-6 border-t border-white/5 pt-4">
        <button type="button" onclick="closeOfferModal()" class="px-4 py-2 text-xs font-semibold border border-white/10 hover:bg-white/5 rounded-xl transition text-neutral-400">Cancel</button>
        <button type="submit" class="px-4 py-2 text-xs font-semibold bg-white text-black hover:bg-neutral-200 rounded-xl transition shadow">Save Offer</button>
      </div>
    </form>
  </div>
</div>

<script nonce="<%- nonce %>">
  // Simple Tab Selection System
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.mon-tab-btn');
    const panels = document.querySelectorAll('.tab-content-panel');

    function selectTab(tabId) {
      tabs.forEach(tab => {
        if (tab.getAttribute('data-tab') === tabId) {
          tab.classList.add('border-white', 'text-white');
          tab.classList.remove('border-transparent', 'text-neutral-400');
        } else {
          tab.classList.remove('border-white', 'text-white');
          tab.classList.add('border-transparent', 'text-neutral-400');
        }
      });

      panels.forEach(panel => {
        if (panel.id === `tab-panel-${tabId}`) {
          panel.classList.remove('hidden');
        } else {
          panel.classList.add('hidden');
        }
      });
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        selectTab(tab.getAttribute('data-tab'));
      });
    });

    // Default select first tab
    selectTab('general');
  });

  // Handle generalized forms submit
  const forms = document.querySelectorAll('.monetization-form');
  forms.forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      e.stopPropagation();
      const category = form.getAttribute('data-category');
      const formData = new FormData(form);
      const data = {};
      formData.forEach((value, key) => {
        data[key] = value;
      });

      try {
        const res = await fetch(`/admin/monetization/config/${category}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        const result = await res.json();
        if (result.success) {
          showToast('Configuration updated successfully!');
        } else {
          showToast('Failed to update: ' + result.error, true);
        }
      } catch (err) {
        showToast('Error sending configurations updates.', true);
      }
    }, true);
  });

  function showToast(message, isError = false) {
    const toast = document.getElementById('statusToast');
    toast.textContent = message;
    toast.className = isError 
      ? 'fixed bottom-5 right-5 bg-red-500 text-black px-4 py-2 rounded-xl text-sm font-semibold shadow-lg z-50' 
      : 'fixed bottom-5 right-5 bg-green-500 text-black px-4 py-2 rounded-xl text-sm font-semibold shadow-lg z-50';
    toast.classList.remove('hidden');
    setTimeout(() => {
      toast.classList.add('hidden');
    }, 3000);
  }

  // Manage Offers Modals & Calls
  const offerModal = document.getElementById('offerModal');
  const offerForm = document.getElementById('offerForm');

  if (offerForm) {
    offerForm.addEventListener('submit', saveOffer, true);
  }

  function openOfferModal() {
    offerForm.reset();
    document.getElementById('offerId').value = '';
    document.getElementById('modalTitle').textContent = 'Add Offer';
    offerModal.classList.remove('hidden');
  }

  function closeOfferModal() {
    offerModal.classList.add('hidden');
  }

  function editOffer(offer) {
    document.getElementById('offerId').value = offer.id;
    document.getElementById('offerName').value = offer.name;
    document.getElementById('offerType').value = offer.type;
    document.getElementById('offerProvider').value = offer.provider;
    document.getElementById('offerTargetUrl').value = offer.targetUrl;
    document.getElementById('offerCooldown').value = offer.cooldown;
    document.getElementById('offerSortOrder').value = offer.sortOrder;
    
    if (offer.rewards && offer.rewards.length > 0) {
      document.getElementById('rewardType').value = offer.rewards[0].rewardType;
      document.getElementById('rewardAmount').value = offer.rewards[0].amount;
    }

    document.getElementById('modalTitle').textContent = 'Edit Offer';
    offerModal.classList.remove('hidden');
  }

  async function saveOffer(e) {
    e.preventDefault();
    e.stopPropagation();
    const id = document.getElementById('offerId').value;
    const name = document.getElementById('offerName').value;
    const type = document.getElementById('offerType').value;
    const provider = document.getElementById('offerProvider').value;
    const targetUrl = document.getElementById('offerTargetUrl').value;
    const cooldown = document.getElementById('offerCooldown').value;
    const sortOrder = document.getElementById('offerSortOrder').value;
    
    // Package single reward definition
    const rewards = [{
      type: document.getElementById('rewardType').value,
      amount: document.getElementById('rewardAmount').value
    }];

    const endpoint = id ? `/admin/monetization/offers/${id}/update` : '/admin/monetization/offers';
    
    try {
      const res = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, type, provider, targetUrl, cooldown, sortOrder, rewards })
      });
      const result = await res.json();
      if (result.success) {
        window.location.reload();
      } else {
        alert('Failed: ' + result.error);
      }
    } catch {
      alert('Error saving offer details.');
    }
  }

  async function deleteOffer(id) {
    if (confirm('Are you sure you want to delete this offer?')) {
      try {
        const res = await fetch(`/admin/monetization/offers/${id}/delete`, { method: 'POST' });
        const result = await res.json();
        if (result.success) {
          window.location.reload();
        }
      } catch {
        alert('Error deleting offer.');
      }
    }
  }

  async function testProvider(providerId) {
    try {
      const res = await fetch(`/admin/monetization/test/${providerId}`, { method: 'POST' });
      const result = await res.json();
      if (result.success) {
        showToast(`${providerId} provider status: ${result.health.status} (${result.health.responseTime}ms)`);
      } else {
        showToast(`Failed: ${result.error}`, true);
      }
    } catch {
      showToast('Connection test request failed.', true);
    }
  }

  async function resolveFraud(id, status) {
    try {
      const res = await fetch(`/admin/monetization/fraud/${id}/resolve`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status })
      });
      const result = await res.json();
      if (result.success) {
        window.location.reload();
      }
    } catch {
      alert('Error updating status.');
    }
  }
</script>

<%- include('../../components/footer') %>
