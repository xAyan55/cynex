          </div>
          <div class="flex items-baseline gap-1">
            <span class="text-5xl font-extrabold text-white">$0</span>
            <span class="text-neutral-500 text-sm">/ forever</span>
          </div>
          <ul class="space-y-3.5 text-sm text-neutral-400 pt-2 border-t border-white/5">
            <li class="flex items-center gap-2.5">
              <%- icon('check', { class: 'w-4 h-4 text-brand-green shrink-0' }) %>
              1 Server Slot
            </li>
            <li class="flex items-center gap-2.5">
              <%- icon('check', { class: 'w-4 h-4 text-brand-green shrink-0' }) %>
