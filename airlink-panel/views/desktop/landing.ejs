<script nonce="<%- nonce %>">
  // Pricing toggle logic
  const toggleMonthly = document.getElementById('toggle-monthly');
  const toggleYearly = document.getElementById('toggle-yearly');
  
  const starterPrice = document.getElementById('starter-price');
  const starterPeriod = document.getElementById('starter-period');
  const proPrice = document.getElementById('pro-price');
  const proPeriod = document.getElementById('pro-period');

  toggleMonthly.addEventListener('click', () => {
    toggleMonthly.classList.add('bg-white/10', 'text-white');
    toggleMonthly.classList.remove('text-neutral-400');
    toggleYearly.classList.remove('bg-white/10', 'text-white');
    toggleYearly.classList.add('text-neutral-400');
    
    starterPrice.textContent = '$3.99';
    starterPeriod.textContent = '/ month';
    proPrice.textContent = '$7.99';
    proPeriod.textContent = '/ month';
  });

  toggleYearly.addEventListener('click', () => {
    toggleYearly.classList.add('bg-white/10', 'text-white');
    toggleYearly.classList.remove('text-neutral-400');
    toggleMonthly.classList.remove('bg-white/10', 'text-white');
    toggleMonthly.classList.add('text-neutral-400');
    
    starterPrice.textContent = '$39.99';
    starterPeriod.textContent = '/ year';
    proPrice.textContent = '$79.99';
    proPeriod.textContent = '/ year';
  });

  // FAQ collapse/expand
  function toggleFaq(index) {
    const ans = document.getElementById('faq-ans-' + index);
    const icon = document.getElementById('faq-icon-' + index);
    const isHidden = ans.classList.contains('hidden');
    
    if (isHidden) {
      ans.classList.remove('hidden');
      icon.classList.add('rotate-180');
    } else {
      ans.classList.add('hidden');
      icon.classList.remove('rotate-180');
    }
  }
</script>

