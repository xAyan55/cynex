<%- include('./components/header', { title: 'Premium Free Minecraft Hosting' }) %>

<main class="min-h-screen bg-[#07070a] text-white relative overflow-hidden font-['General_Sans',sans-serif]">
  <!-- Decorative background elements -->
  <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-brand-green/5 rounded-full blur-[120px] pointer-events-none animate-glow-pulse"></div>
  <div class="absolute top-1/3 right-1/4 w-[600px] h-[600px] bg-brand-purple/5 rounded-full blur-[150px] pointer-events-none animate-glow-pulse"></div>
  <div class="absolute bottom-10 left-1/3 w-[450px] h-[450px] bg-emerald-500/5 rounded-full blur-[100px] pointer-events-none"></div>

  <!-- Header Navbar -->
  <header class="sticky top-0 z-50 bg-[#07070a]/75 backdrop-blur-xl border-b border-white/5 py-4">
    <div class="max-w-7xl mx-auto px-6 flex justify-between items-center">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-brand-green to-emerald-400 flex items-center justify-center shadow-lg shadow-brand-green/20">
          <span class="font-extrabold text-black text-xl">C</span>
        </div>
        <span class="text-xl font-bold tracking-tight text-white bg-clip-text">Cynex<span class="text-brand-green text-shadow-glow">GP</span></span>
      </div>

      <nav class="hidden md:flex items-center gap-8 text-sm font-semibold text-neutral-400">
        <a href="#features" class="hover:text-white transition-colors">Features</a>
        <a href="#how-it-works" class="hover:text-white transition-colors">How It Works</a>
        <a href="#pricing" class="hover:text-white transition-colors">Pricing</a>
        <a href="#faq" class="hover:text-white transition-colors">FAQ</a>
      </nav>

      <div class="flex items-center gap-4">
        <% if (typeof user !== 'undefined' && user) { %>
          <%- include('./components/ui/Button', { variant: 'primary', label: 'Go to Dashboard', href: '/dashboard' }) %>
        <% } else { %>
          <a href="/login" class="text-sm font-semibold text-neutral-300 hover:text-white transition-colors">Sign In</a>
          <%- include('./components/ui/Button', { variant: 'primary', label: 'Start Free Hosting', href: '/register' }) %>
        <% } %>
      </div>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="max-w-7xl mx-auto px-6 pt-20 pb-24 grid lg:grid-cols-12 gap-16 items-center relative z-10">
    <div class="lg:col-span-7 space-y-8">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-xs font-semibold tracking-wide text-brand-green">
        <span class="w-2 h-2 rounded-full bg-brand-green animate-ping"></span>
        FREE SERVER DEPLOYMENT LIVE
      </div>
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight leading-[1.08] text-white">
        Next-Generation <br/>
        <span class="bg-gradient-to-r from-brand-green to-emerald-300 bg-clip-text text-transparent">Minecraft Hosting</span>
      </h1>
      <p class="text-lg text-neutral-400 max-w-xl leading-relaxed">
        Deploy fully customizable Minecraft servers instantly at zero cost. Scale resources, manage plugins, and play with friends on enterprise-grade hardware without paying a dime.
      </p>
      <div class="flex flex-wrap gap-4 pt-2">
        <%- include('./components/ui/Button', { variant: 'primary', label: 'Create Free Server', href: '/register' }) %>
        <%- include('./components/ui/Button', { variant: 'secondary', label: 'View Paid Plans', href: '#pricing' }) %>
      </div>

      <div class="flex gap-10 pt-4 text-left border-t border-white/5 max-w-md">
        <div>
          <h4 class="text-3xl font-extrabold text-white">25k+</h4>
          <p class="text-xs text-neutral-500 font-medium uppercase mt-1">Servers Created</p>
        </div>
        <div>
          <h4 class="text-3xl font-extrabold text-white">99.9%</h4>
          <p class="text-xs text-neutral-500 font-medium uppercase mt-1">Node Uptime</p>
        </div>
        <div>
          <h4 class="text-3xl font-extrabold text-white">&lt; 15s</h4>
          <p class="text-xs text-neutral-500 font-medium uppercase mt-1">Deployment Time</p>
        </div>
      </div>
    </div>

    <!-- Interactive Mock Dashboard Preview -->
    <div class="lg:col-span-5 relative">
      <div class="absolute -inset-1 rounded-2xl bg-gradient-to-tr from-brand-green/20 to-brand-purple/20 blur-xl opacity-75"></div>
      <div class="cynex-glass rounded-2xl p-6 border border-white/10 relative overflow-hidden">
        <!-- Window controls -->
        <div class="flex items-center gap-2 mb-6">
          <div class="w-3 h-3 rounded-full bg-red-500/50"></div>
          <div class="w-3 h-3 rounded-full bg-amber-500/50"></div>
          <div class="w-3 h-3 rounded-full bg-brand-green/50"></div>
          <span class="text-xs font-semibold text-neutral-500 ml-2">CynexGP Portal</span>
        </div>

        <div class="space-y-6">
          <!-- Server Status Header Widget -->
          <div class="flex justify-between items-start">
            <div>
              <h3 class="font-bold text-white text-base">Survival World</h3>
              <p class="text-xs text-neutral-400 mt-0.5">mc.cynexgp.net:25565</p>
            </div>
            <%- include('./components/ui/Badge', { status: 'online', label: 'Online' }) %>
          </div>

          <!-- Server Stats Ring/Usage Bars -->
          <div class="space-y-4 pt-2">
            <%- include('./components/ui/Progress', { value: 42, label: 'CPU Usage', color: 'green' }) %>
            <%- include('./components/ui/Progress', { value: 68, label: 'RAM Allocation (2.7GB / 4.0GB)', color: 'purple' }) %>
          </div>

          <!-- Active Players Panel -->
          <div class="bg-white/[0.02] border border-white/5 rounded-xl p-4">
            <div class="flex justify-between items-center text-xs font-bold text-neutral-400 mb-3">
              <span>Players Online</span>
              <span class="text-brand-green">14 / 20</span>
            </div>
            <div class="flex gap-2.5">
              <div class="w-8 h-8 rounded-lg bg-gradient-to-tr from-brand-purple to-indigo-500 flex items-center justify-center text-xs font-bold text-white">S</div>
              <div class="w-8 h-8 rounded-lg bg-gradient-to-tr from-emerald-400 to-brand-green flex items-center justify-center text-xs font-bold text-black">A</div>
              <div class="w-8 h-8 rounded-lg bg-neutral-800 flex items-center justify-center text-xs font-bold text-neutral-400">+12</div>
            </div>
          </div>

          <!-- Action bar -->
          <div class="flex gap-3 pt-2">
            <button class="flex-1 py-2 bg-red-500/10 border border-red-500/20 hover:bg-red-500/20 text-red-400 text-xs font-bold rounded-xl transition duration-300">Stop</button>
            <button class="flex-1 py-2 bg-brand-green text-black hover:bg-brand-green-hover text-xs font-bold rounded-xl transition duration-300">Restart</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="max-w-7xl mx-auto px-6 py-28 border-t border-white/5 relative z-10">
    <div class="text-center space-y-4 max-w-2xl mx-auto mb-20">
      <h2 class="text-xs font-bold uppercase tracking-widest text-brand-green">Features</h2>
      <h3 class="text-4xl md:text-5xl font-bold tracking-tight text-white">Full Control, No Strings Attached</h3>
      <p class="text-neutral-400">Everything you need to configure, extend, and run your multiplayer servers flawlessly.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <%- include('./components/ui/Card', { hover: true }) %>
        <div class="w-12 h-12 rounded-xl bg-brand-green/10 flex items-center justify-center mb-6">
          <%- icon('terminal', { class: 'w-6 h-6 text-brand-green' }) %>
        </div>
        <h4 class="text-xl font-bold text-white mb-2">Web Console</h4>
        <p class="text-neutral-400 text-sm leading-relaxed">
          Monitor your server logs in real-time, execute commands directly, and track server responses with zero latency.
        </p>
      </div>

      <%- include('./components/ui/Card', { hover: true }) %>
        <div class="w-12 h-12 rounded-xl bg-brand-purple/10 flex items-center justify-center mb-6">
          <%- icon('folder-open', { class: 'w-6 h-6 text-brand-purple' }) %>
        </div>
        <h4 class="text-xl font-bold text-white mb-2">File Manager</h4>
        <p class="text-neutral-400 text-sm leading-relaxed">
          Upload worlds, edit configs, install custom mods, and organize files using our responsive web file manager.
        </p>
      </div>

      <%- include('./components/ui/Card', { hover: true }) %>
        <div class="w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center mb-6">
          <%- icon('puzzle', { class: 'w-6 h-6 text-emerald-400' }) %>
        </div>
        <h4 class="text-xl font-bold text-white mb-2">Plugin Installer</h4>
        <p class="text-neutral-400 text-sm leading-relaxed">
          Search and install thousands of plugins directly from Modrinth and Spigot APIs with absolute ease.
        </p>
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section id="how-it-works" class="max-w-7xl mx-auto px-6 py-28 border-t border-white/5 relative z-10">
    <div class="text-center space-y-4 max-w-2xl mx-auto mb-20">
      <h2 class="text-xs font-bold uppercase tracking-widest text-brand-green">Workflow</h2>
      <h3 class="text-4xl md:text-5xl font-bold tracking-tight text-white">Three Steps to Play</h3>
      <p class="text-neutral-400">Get your server up and running in less than a minute.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-12 relative">
      <!-- Step 1 -->
      <div class="space-y-4 relative">
        <div class="w-10 h-10 rounded-full bg-brand-green/20 border border-brand-green/30 text-brand-green flex items-center justify-center font-bold text-base">1</div>
        <h4 class="text-xl font-bold text-white pt-2">Create an Account</h4>
        <p class="text-neutral-400 text-sm leading-relaxed">Sign up instantly with your email address. No credit card details required.</p>
      </div>
      <!-- Step 2 -->
      <div class="space-y-4 relative">
        <div class="w-10 h-10 rounded-full bg-brand-purple/20 border border-brand-purple/30 text-brand-purple flex items-center justify-center font-bold text-base">2</div>
        <h4 class="text-xl font-bold text-white pt-2">Configure & Deploy</h4>
        <p class="text-neutral-400 text-sm leading-relaxed">Choose your server software (Vanilla, Paper, Fabric), versions, RAM limits, and launch.</p>
      </div>
      <!-- Step 3 -->
      <div class="space-y-4 relative">
        <div class="w-10 h-10 rounded-full bg-emerald-500/20 border border-emerald-500/30 text-emerald-400 flex items-center justify-center font-bold text-base">3</div>
        <h4 class="text-xl font-bold text-white pt-2">Connect & Share</h4>
        <p class="text-neutral-400 text-sm leading-relaxed">Copy the server IP, share it with your friends, and jump directly into the game.</p>
      </div>
    </div>
  </section>

  <!-- Pricing Comparison Section -->
  <section id="pricing" class="max-w-7xl mx-auto px-6 py-28 border-t border-white/5 relative z-10">
    <div class="text-center space-y-4 max-w-2xl mx-auto mb-16">
