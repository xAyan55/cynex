  <!-- Testimonials Section -->
  <section class="max-w-7xl mx-auto px-6 py-28 border-t border-white/5 relative z-10">
    <div class="text-center space-y-4 max-w-2xl mx-auto mb-20">
      <h2 class="text-xs font-bold uppercase tracking-widest text-brand-green">Testimonials</h2>
      <h3 class="text-4xl md:text-5xl font-bold tracking-tight text-white">Loved by Players & Admins</h3>
      <p class="text-neutral-400">See what our server owners have to say about CynexGP performance and simplicity.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <%- include('./components/ui/Card', { hover: true }) %>
        <div class="flex items-center gap-1.5 mb-4">
          <% for(let i=0; i<5; i++) { %><%- icon('star', { class: 'w-4 h-4 fill-amber-400 text-amber-400' }) %><% } %>
        </div>
        <p class="text-neutral-300 text-sm leading-relaxed mb-6 italic">
          "I couldn't believe it was actually free. I set up a Paper server in seconds to play with my cousins. It sleeps when no one is playing, which is awesome, and starts back up when we join."
        </p>
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-gradient-to-tr from-brand-purple to-indigo-500 flex items-center justify-center font-bold text-sm text-white">K</div>
          <div>
            <h5 class="text-sm font-bold text-white">Kyle Bennett</h5>
            <p class="text-xs text-neutral-500">Survival Server Owner</p>
          </div>
        </div>
      </div>

      <%- include('./components/ui/Card', { hover: true }) %>
        <div class="flex items-center gap-1.5 mb-4">
          <% for(let i=0; i<5; i++) { %><%- icon('star', { class: 'w-4 h-4 fill-amber-400 text-amber-400' }) %><% } %>
        </div>
        <p class="text-neutral-300 text-sm leading-relaxed mb-6 italic">
          "The plugin manager is awesome! Searching and downloading Spigot plugins right inside the panel dashboard makes running a server so convenient. I upgraded to Starter for larger RAM limits."
        </p>
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-gradient-to-tr from-brand-green to-emerald-400 flex items-center justify-center font-bold text-sm text-black">M</div>
          <div>
            <h5 class="text-sm font-bold text-white">Marcus Vance</h5>
            <p class="text-xs text-neutral-500">Skyblock Admin</p>
          </div>
        </div>
      </div>

      <%- include('./components/ui/Card', { hover: true }) %>
        <div class="flex items-center gap-1.5 mb-4">
          <% for(let i=0; i<5; i++) { %><%- icon('star', { class: 'w-4 h-4 fill-amber-400 text-amber-400' }) %><% } %>
        </div>
        <p class="text-neutral-300 text-sm leading-relaxed mb-6 italic">
          "Fantastic UI design. The dark mode glassmorphism dashboard feels super premium. Files open instantly and console command response is fast. 10/10 developer work."
        </p>
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-neutral-800 flex items-center justify-center font-bold text-sm text-neutral-400">J</div>
          <div>
            <h5 class="text-sm font-bold text-white">Jessica Hall</h5>
            <p class="text-xs text-neutral-500">BungeeCord Developer</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section id="faq" class="max-w-4xl mx-auto px-6 py-28 border-t border-white/5 relative z-10">
    <div class="text-center space-y-4 mb-20">
      <h2 class="text-xs font-bold uppercase tracking-widest text-brand-green">FAQ</h2>
      <h3 class="text-4xl md:text-5xl font-bold tracking-tight text-white">Common Questions</h3>
    </div>

    <div class="space-y-4">
      <% 
        const faqs = [
          { q: 'Is CynexGP hosting really free?', a: 'Yes! Our Free Tier slot provides 1GB of dedicated RAM, 5GB storage, and a single core, letting you play with friends forever at zero cost.' },
          { q: 'How does server hibernation work?', a: 'To conserve resource pools on our free nodes, inactive free servers sleep when player count drops to zero for 10 minutes. The server wakes up instantly when you send a start command or join request.' },
          { q: 'Can I upload my own custom worlds and mods?', a: 'Absolutely. Using our web-based File Manager or SFTP credentials, you have full access to files, mod libraries, configurations, and world folders.' },
          { q: 'How does the provisioning queue work?', a: 'Free servers are placed in a deployment queue on creation to manage node loads. Once it reaches position #1, the server installs automatically on a node picked by our NodeAllocator.' },
          { q: 'Can I upgrade my free server to a premium plan?', a: 'Yes. Upgrading is seamless. Your files and world database are preserved, the resource limits are automatically expanded in our database, and queue checks are removed.' }
        ];
      %>
      <% faqs.forEach((faq, index) => { %>
        <div class="cynex-glass rounded-xl overflow-hidden border border-white/5">
          <button class="w-full flex justify-between items-center px-6 py-5 text-left font-bold text-white hover:bg-white/[0.02] transition duration-200 cursor-pointer" onclick="toggleFaq(<%= index %>)">
            <span><%= faq.q %></span>
            <svg id="faq-icon-<%= index %>" class="w-5 h-5 text-neutral-400 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div id="faq-ans-<%= index %>" class="hidden px-6 pb-6 text-sm text-neutral-400 leading-relaxed border-t border-white/5 pt-4">
            <%= faq.a %>
          </div>
        </div>
      <% }); %>
    </div>
  </section>

  <!-- Footer Section -->
  <footer class="border-t border-white/5 py-12 bg-black/40 text-neutral-500 text-sm">
    <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-lg bg-brand-green/20 flex items-center justify-center">
          <span class="font-bold text-brand-green text-sm">C</span>
        </div>
        <span class="text-base font-bold text-white">CynexGP</span>
