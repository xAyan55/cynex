      </div>

      <!-- Starter Premium Plan -->
      <%- include('./components/ui/Card', { hover: false, glow: 'green' }) %>
        <div class="space-y-6">
          <div class="flex justify-between items-start">
            <div>
              <h4 class="text-xl font-bold text-white">Starter Plan</h4>
              <p class="text-xs text-neutral-400 mt-1">Optimized for survival, zero lag</p>
            </div>
            <span class="px-2 py-1 rounded bg-brand-green/10 text-brand-green text-[10px] font-bold uppercase tracking-wider">Popular</span>
          </div>
          <div class="flex items-baseline gap-1">
            <span class="text-5xl font-extrabold text-white" id="starter-price">$3.99</span>
            <span class="text-neutral-500 text-sm" id="starter-period">/ month</span>
          </div>
          <ul class="space-y-3.5 text-sm text-neutral-400 pt-2 border-t border-white/5">
            <li class="flex items-center gap-2.5">
              <%- icon('check', { class: 'w-4 h-4 text-brand-green shrink-0' }) %>
              3 Server Slots
            </li>
            <li class="flex items-center gap-2.5">
              <%- icon('check', { class: 'w-4 h-4 text-brand-green shrink-0' }) %>
              4GB Dedicated RAM & 2 Cores
            </li>
            <li class="flex items-center gap-2.5">
              <%- icon('check', { class: 'w-4 h-4 text-brand-green shrink-0' }) %>
              15GB NVMe SSD storage
            </li>
            <li class="flex items-center gap-2.5">
              <%- icon('check', { class: 'w-4 h-4 text-brand-green shrink-0' }) %>
              Instant Provisioning (No Queues)
            </li>
            <li class="flex items-center gap-2.5">
              <%- icon('check', { class: 'w-4 h-4 text-brand-green shrink-0' }) %>
              24/7 Always Online (No Sleep)
            </li>
          </ul>
          <%- include('./components/ui/Button', { variant: 'primary', label: 'Upgrade to Starter', href: '/register', class: 'w-full pt-4' }) %>
        </div>
      </div>

      <!-- Pro Premium Plan -->
      <%- include('./components/ui/Card', { hover: false }) %>
        <div class="space-y-6">
          <div>
            <h4 class="text-xl font-bold text-neutral-300">Pro Plan</h4>
            <p class="text-xs text-neutral-500 mt-1">Excellent for large groups & modpacks</p>
          </div>
          <div class="flex items-baseline gap-1">
            <span class="text-5xl font-extrabold text-white" id="pro-price">$7.99</span>
            <span class="text-neutral-500 text-sm" id="pro-period">/ month</span>
          </div>
          <ul class="space-y-3.5 text-sm text-neutral-400 pt-2 border-t border-white/5">
            <li class="flex items-center gap-2.5">
              <%- icon('check', { class: 'w-4 h-4 text-brand-green shrink-0' }) %>
              6 Server Slots
            </li>
            <li class="flex items-center gap-2.5">
              <%- icon('check', { class: 'w-4 h-4 text-brand-green shrink-0' }) %>
              8GB Dedicated RAM & 4 Cores
            </li>
            <li class="flex items-center gap-2.5">
              <%- icon('check', { class: 'w-4 h-4 text-brand-green shrink-0' }) %>
              30GB NVMe SSD storage
            </li>
            <li class="flex items-center gap-2.5">
              <%- icon('check', { class: 'w-4 h-4 text-brand-green shrink-0' }) %>
              Instant deployment
            </li>
            <li class="flex items-center gap-2.5">
              <%- icon('check', { class: 'w-4 h-4 text-brand-green shrink-0' }) %>
              24/7 Always Online
            </li>
          </ul>
