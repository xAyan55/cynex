      <div class="inline-flex items-center gap-3 bg-white/5 border border-white/10 rounded-full p-1.5 mt-6">
        <button id="toggle-monthly" class="px-4 py-1.5 rounded-full text-xs font-semibold bg-white/10 text-white transition-all cursor-pointer">Monthly Billing</button>
