<%- include('./components/header', { title: 'The Complete Minecraft Freedom' }) %>

  <% const registerOrDashboard=(typeof user !=='undefined' && user) ? '/dashboard' : '/register' ; %>

    <main
      class="min-h-screen bg-mono-bg text-mono-text-primary relative overflow-hidden font-['General_Sans',sans-serif]">

      <!-- Header Navigation -->
      <header class="border-b border-mono-border bg-mono-bg/85 backdrop-blur-xl sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
          <a href="/" class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-xl bg-mono-accent flex items-center justify-center shadow-lg shadow-black/40">
              <span class="font-extrabold text-black text-lg">C</span>
            </div>
            <h1 class="text-mono-text-primary font-bold tracking-tight text-base">Cynex<span
                class="text-mono-text-secondary font-medium">GP</span></h1>
          </a>

          <nav class="hidden md:flex items-center gap-8 text-sm font-semibold text-mono-text-secondary">
            <a href="#features" class="hover:text-mono-text-primary transition-colors">Features</a>
            <a href="#why-us" class="hover:text-mono-text-primary transition-colors">Why CynexGP</a>
            <% if (typeof user !=='undefined' && user) { %>
              <a href="/dashboard" class="hover:text-mono-text-primary transition-colors">Dashboard</a>
              <% } else { %>
                <a href="https://docs.cynexgp.net" target="_blank"
                  class="hover:text-mono-text-primary transition-colors">Documentation</a>
                <% } %>
                  <a href="#faq" class="hover:text-mono-text-primary transition-colors">FAQ</a>
          </nav>

          <div class="flex items-center gap-6">
            <% if (typeof user !=='undefined' && user) { %>
              <a href="/dashboard"
                class="text-sm font-semibold text-mono-text-secondary hover:text-mono-text-primary transition-colors">Dashboard</a>
              <a href="/account"
                class="text-sm font-semibold text-mono-text-secondary hover:text-mono-text-primary transition-colors">Profile</a>
              <%- include('./components/ui/button', { variant: 'outline' , label: 'Logout' , href: '/logout' ,
                class: '!py-1.5' }) %>
                <% } else { %>
                  <a href="/login"
                    class="text-sm font-semibold text-mono-text-secondary hover:text-mono-text-primary transition-colors">Login</a>
                  <%- include('./components/ui/button', { variant: 'primary' , label: 'Register' , href: '/register' ,
                    class: '!py-1.5' }) %>
                    <% } %>
          </div>
        </div>
      </header>

      <!-- Centered Hero Section -->
      <section
        class="min-h-[90vh] lg:min-h-[95vh] flex flex-col justify-center items-center relative overflow-hidden bg-mono-bg">
        <!-- Overlay Layer 0: Minecraft Landscape Background Image -->
        <div class="absolute inset-0 bg-[url('/assets/bg-w.jpg')] bg-cover bg-center pointer-events-none opacity-50 z-0">
        </div>

        <!-- Overlay Layer 1: Solid Dark Overlay (55% opacity) -->
        <div class="absolute inset-0 bg-[#0f0f0f]/55 z-0 pointer-events-none"></div>

        <!-- Overlay Layer 2: Radial gradient fading smoothly to dark at the edges -->
        <div
          class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_20%,#0f0f0f_80%)] z-0 pointer-events-none">
        </div>

        <!-- Overlay Layer 3: Vertical Top & Bottom Fades -->
        <div
          class="absolute top-0 left-0 right-0 h-32 bg-gradient-to-b from-[#0f0f0f] to-transparent z-0 pointer-events-none">
        </div>
        <div
          class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-[#0f0f0f] to-transparent z-0 pointer-events-none">
        </div>

        <!-- Centered Hero Content -->
        <div
          class="max-w-[800px] w-full mx-auto px-6 text-center space-y-8 relative z-10 select-none flex flex-col items-center">
          <div
            class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-mono-muted border border-mono-border text-xs font-semibold text-mono-text-primary tracking-wide">
            <span class="w-1.5 h-1.5 rounded-full bg-brand-green animate-pulse"></span>
            Full-Featured Minecraft Panel
          </div>

          <h2 class="text-4xl md:text-6xl font-extrabold tracking-tight text-white leading-tight">
            The Complete <br class="hidden sm:inline" />
            Minecraft Panel
          </h2>

          <p class="text-sm text-mono-text-secondary leading-relaxed max-w-[600px] mx-auto">
            Manage servers, users, nodes, locations and more from a powerful, modern and lightweight dashboard.
          </p>

          <div class="flex flex-wrap items-center justify-center gap-4 pt-2">
            <%- include('./components/ui/button', { variant: 'primary' , label: 'Get Started' , href:
              registerOrDashboard,
              class: '!w-44 !h-11 !justify-center !rounded-xl !bg-white hover:!bg-neutral-100 hover:!shadow-none !text-black'
              }) %>
              <%- include('./components/ui/button', { variant: 'secondary' , label: 'Explore Dashboard' ,
                href: '#features' ,
                class: '!w-44 !h-11 !justify-center !rounded-xl !bg-transparent !border-mono-border !text-white hover:!bg-white/5 hover:!shadow-none'
                }) %>
          </div>
        </div>
      </section>

      <!-- Features Grid Section -->
      <section id="features" class="max-w-7xl mx-auto px-6 py-28 border-t border-mono-border relative z-10 bg-mono-bg">
        <div class="text-center space-y-4 mb-20">
          <h3 class="text-xs font-bold uppercase tracking-widest text-mono-text-secondary">Features</h3>
          <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-mono-text-primary">Everything You Need in One
            Place</h2>
          <p class="text-sm text-mono-text-secondary max-w-xl mx-auto">
            Powerful tools to manage your Minecraft infrastructure with ease.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Feature Card 1 -->
          <%- include('./components/ui/Card', { hover: true, class: 'space-y-4' }) %>
            <div
              class="w-10 h-10 rounded-xl bg-mono-muted border border-mono-border flex items-center justify-center text-mono-text-primary">
              <%- icon('cpu', { class: 'w-5 h-5' }) %>
            </div>
            <h4 class="text-lg font-bold text-mono-text-primary">Ryzen 9 Performance</h4>
            <p class="text-sm text-mono-text-secondary leading-relaxed">
              Optimized node orchestration with enterprise SSD arrays for latency-free block updates.
            </p>
        </div>

        <!-- Feature Card 2 -->
        <%- include('./components/ui/Card', { hover: true, class: 'space-y-4' }) %>
          <div
            class="w-10 h-10 rounded-xl bg-mono-muted border border-mono-border flex items-center justify-center text-mono-text-primary">
            <%- icon('terminal', { class: 'w-5 h-5' }) %>
          </div>
          <h4 class="text-lg font-bold text-mono-text-primary">Full Console Access</h4>
          <p class="text-sm text-mono-text-secondary leading-relaxed">
            Complete power controls, terminal access, startup arguments, and real-time resource dials.
          </p>
          </div>

          <!-- Feature Card 3 -->
          <%- include('./components/ui/Card', { hover: true, class: 'space-y-4' }) %>
            <div
              class="w-10 h-10 rounded-xl bg-mono-muted border border-mono-border flex items-center justify-center text-mono-text-primary">
              <%- icon('folder-open', { class: 'w-5 h-5' }) %>
            </div>
            <h4 class="text-lg font-bold text-mono-text-primary">Advanced SFTP Manager</h4>
            <p class="text-sm text-mono-text-secondary leading-relaxed">
              Browse, edit, rename, compress, and duplicate configuration folders directly from the browser sidebar.
            </p>
            </div>

            <!-- Feature Card 4 -->
            <%- include('./components/ui/Card', { hover: true, class: 'space-y-4' }) %>
              <div
                class="w-10 h-10 rounded-xl bg-mono-muted border border-mono-border flex items-center justify-center text-mono-text-primary">
                <%- icon('shield', { class: 'w-5 h-5' }) %>
              </div>
              <h4 class="text-lg font-bold text-mono-text-primary">DDoS Protected</h4>
              <p class="text-sm text-mono-text-secondary leading-relaxed">
                Robust network filtering and proxy gateways to protect your lobby from latency spikes and attacks.
              </p>
              </div>

              <!-- Feature Card 5 -->
              <%- include('./components/ui/Card', { hover: true, class: 'space-y-4' }) %>
                <div
                  class="w-10 h-10 rounded-xl bg-mono-muted border border-mono-border flex items-center justify-center text-mono-text-primary">
                  <%- icon('puzzle', { class: 'w-5 h-5' }) %>
                </div>
                <h4 class="text-lg font-bold text-mono-text-primary">Plugin Installer</h4>
                <p class="text-sm text-mono-text-secondary leading-relaxed">
                  Browse Modrinth plugin store directories directly inside the panel to install upgrades in one click.
                </p>
                </div>

                <!-- Feature Card 6 -->
                <%- include('./components/ui/Card', { hover: true, class: 'space-y-4' }) %>
                  <div
                    class="w-10 h-10 rounded-xl bg-mono-muted border border-mono-border flex items-center justify-center text-mono-text-primary">
                    <%- icon('users', { class: 'w-5 h-5' }) %>
                  </div>
                  <h4 class="text-lg font-bold text-mono-text-primary">Subuser Invites</h4>
                  <p class="text-sm text-mono-text-secondary leading-relaxed">
                    Grant administration access or folder access privileges to developers, admins, and friends.
                  </p>
                  </div>
                  </div>
      </section>

      <!-- Why CynexGP Section -->
      <section id="why-us" class="max-w-7xl mx-auto px-6 py-28 border-t border-mono-border relative z-10 bg-mono-bg">
        <div class="grid lg:grid-cols-12 gap-16 items-center">
          <div class="lg:col-span-5 space-y-6">
            <h3 class="text-xs font-bold uppercase tracking-widest text-mono-text-secondary">Visual Audit</h3>
            <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-mono-text-primary">Designed Like a Tool, Not a
              Pitch</h2>
            <p class="text-sm text-mono-text-secondary leading-relaxed">
              We built CynexGP for server owners who demand clean, uncluttered, and high-performance interfaces. No
              flashing templates, no bloated scripts—just clean, low-latency control panels.
            </p>
            <div class="space-y-4">
              <div class="flex items-start gap-3.5">
                <%- icon('check-circle', { class: 'w-5 h-5 text-brand-green mt-0.5 shrink-0' }) %>
                  <div>
                    <h4 class="text-sm font-bold text-mono-text-primary">100% Shared Theme</h4>
                    <p class="text-xs text-mono-text-secondary mt-1">Every element uses identical design variables for
                      visual cohesion.</p>
                  </div>
              </div>
              <div class="flex items-start gap-3.5">
                <%- icon('check-circle', { class: 'w-5 h-5 text-brand-green mt-0.5 shrink-0' }) %>
                  <div>
                    <h4 class="text-sm font-bold text-mono-text-primary">Zero Bloat</h4>
                    <p class="text-xs text-mono-text-secondary mt-1">No separate external layout structures. Clean asset
                      compilation.</p>
                  </div>
              </div>
            </div>
          </div>

          <div class="lg:col-span-7">
            <%- include('./components/ui/Card', { hover: false,
              class: '!p-0 overflow-hidden border-mono-border shadow-xl' }) %>
              <div class="px-6 py-5 border-b border-mono-border bg-white/[0.01]">
                <h4 class="text-sm font-bold text-mono-text-primary">Dashboard Technical Specs</h4>
              </div>
              <div class="overflow-x-auto">
                <table class="w-full text-left text-sm divide-y divide-mono-border">
                  <thead class="bg-white/[0.02] text-xs font-bold uppercase text-mono-text-secondary">
                    <tr>
                      <th class="px-6 py-4">Resource Management</th>
                      <th class="px-6 py-4">Dashboard Features</th>
                      <th class="px-6 py-4">Admin Capabilities</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-mono-border text-mono-text-secondary">
                    <tr class="hover:bg-white/[0.01]">
                      <td class="px-6 py-4 font-semibold text-mono-text-primary">Node Monitoring</td>
                      <td class="px-6 py-4">Real-time memory stats, threads & load dials</td>
                      <td class="px-6 py-4">Allocate CPU boundaries per user instance</td>
                    </tr>
                    <tr class="hover:bg-white/[0.01]">
                      <td class="px-6 py-4 font-semibold text-mono-text-primary">SFTP Integrations</td>
                      <td class="px-6 py-4">In-browser text editing, config updates</td>
                      <td class="px-6 py-4">Zip backups, upload schedules</td>
                    </tr>
                    <tr class="hover:bg-white/[0.01]">
                      <td class="px-6 py-4 font-semibold text-mono-text-primary">User Management</td>
                      <td class="px-6 py-4">Fine-grained invite keys, permissions</td>
                      <td class="px-6 py-4">Suspension controls, folder limits</td>
                    </tr>
                  </tbody>
                </table>
              </div>
          </div>
        </div>
        </div>
      </section>

      <!-- FAQ Accordion Section -->
      <section id="faq" class="max-w-4xl mx-auto px-6 py-28 border-t border-mono-border relative z-10 bg-mono-bg">
        <div class="text-center space-y-4 mb-20">
          <h3 class="text-xs font-bold uppercase tracking-widest text-mono-text-secondary">FAQ</h3>
          <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-mono-text-primary">Frequently Asked Questions
          </h2>
        </div>

        <div class="space-y-4">
          <% const faqs=[ { q: 'What software eggs are supported?' ,
            a: 'CynexGP supports Java edition servers (Paper, Purpur, Forge, Fabric), Bedrock Edition, BungeeCord, and pocketmine eggs out of the box.'
            }, { q: 'How do you monitor node performance?' ,
            a: 'We balance player instances dynamically across nodes, monitoring CPU cores, NVMe write states, and container statistics.'
            }, { q: 'Can I import my existing world files?' ,
            a: 'Yes, using the SFTP credentials tab or the browser file uploader, you can zip and deploy your existing configurations.'
            }, { q: 'Can I configure subuser access?' ,
            a: 'Yes, you can create invite keys with specific folder, console, or settings write scopes to add administrators.'
            } ]; faqs.forEach((faq, index)=> {
            %>
            <%- include('./components/ui/Card', { hover: false,
              class: '!p-5 border-mono-border hover:border-white/15 transition cursor-pointer select-none' }) %>
              <div class="flex items-center justify-between" onclick="toggleFaq(<%= index %>)">
                <h4 class="text-sm font-bold text-mono-text-primary">
                  <%= faq.q %>
                </h4>
                <span id="faq-icon-<%= index %>" class="text-mono-text-secondary transition duration-300 transform">
                  <%- icon('chevron-down', { class: 'w-4 h-4' }) %>
                </span>
              </div>
              <p id="faq-ans-<%= index %>"
                class="text-xs text-mono-text-secondary mt-3 leading-relaxed hidden border-t border-mono-border/50 pt-3">
                <%= faq.a %>
              </p>
        </div>
        <% }); %>
          </div>
      </section>

      <!-- Footer Section -->
      <footer class="border-t border-mono-border py-12 bg-mono-bg text-xs text-mono-text-secondary">
        <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6">
          <div class="flex items-center gap-3">
            <div class="w-7 h-7 rounded-lg bg-mono-accent flex items-center justify-center">
              <span class="font-extrabold text-black text-sm">C</span>
            </div>
            <p>&copy; 2026 CynexGP. All rights reserved.</p>
          </div>

          <div class="flex items-center gap-8 font-semibold">
            <a href="/terms" class="hover:text-mono-text-primary transition-colors">Terms of Service</a>
            <a href="/privacy" class="hover:text-mono-text-primary transition-colors">Privacy Policy</a>
            <div class="flex items-center gap-1.5 bg-white/5 border border-mono-border px-3 py-1 rounded-xl">
              <span class="w-1.5 h-1.5 rounded-full bg-brand-green animate-pulse"></span>
              All Systems Operational
            </div>
          </div>
        </div>
      </footer>
    </main>

    <script nonce="<%- nonce %>">
      // FAQ collapse/expand
      function toggleFaq(index) {
        const ans = document.getElementById('faq-ans-' + index);
        const icon = document.getElementById('faq-icon-' + index);
        const isHidden = ans.classList.contains('hidden');

        if (isHidden) {
          ans.classList.remove('hidden');
          icon.classList.add('rotate-180');
        } else {
          ans.classList.add('hidden');
          icon.classList.remove('rotate-180');
        }
      }
    </script>

    <%- include('./components/footer') %>