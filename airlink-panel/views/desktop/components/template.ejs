<!-- Sidebar -->
<div id="pc-sidebar" class="sidebar transition hidden lg:fixed lg:inset-y-0 lg:z-50 lg:flex lg:w-56 lg:flex-col left-0 font-['General_Sans',sans-serif]">
  <div id="pc-sidebar2" class="flex flex-col h-full bg-[#1a1a1a] border-r border-mono-border">

    <!-- Static top: logo -->
    <div class="pl-6 pt-5 pb-5 flex min-w-0 shrink-0 border-b border-mono-border">
      <a href="/dashboard" class="flex items-center min-w-0 gap-3">
        <img src="<%= settings.logo ? (settings.logo.startsWith('/') ? settings.logo : '/' + settings.logo) : '/assets/logo.png' %>" alt="Logo" class="w-9 h-9 rounded-xl object-contain shadow-lg shadow-black/40">
        <h1 class="text-mono-text-primary font-bold tracking-tight text-base truncate min-w-0"><%= settings.title || 'CynexGP' %></h1>
      </a>
    </div>

    <!-- Static: user info — clicking goes to account page -->
    <% if (typeof user !== 'undefined' && user) { %>
    <a href="/account" id="sidebar-account-link" class="sidebar-special-link flex items-center space-x-3.5 py-4 px-5 border-b border-white/5 shrink-0 hover:bg-white/[0.03] transition-colors group">
      <img class="h-9 w-9 rounded-xl border border-white/5 shrink-0 object-cover" src="<%= user.avatar ? user.avatar : 'https://api.dicebear.com/9.x/thumbs/svg?seed=' + encodeURIComponent(user.username) %>" alt="User avatar">
      <div class="min-w-0">
        <p class="text-sm font-semibold text-neutral-200 truncate group-hover:text-white transition-colors">
          <span id="sidebar-username"><%= user.username %></span>
          <span class="text-xs text-neutral-500">
            <sup class="mt-1">#<%= String(user.id).padStart(4, '0') %></sup>
          </span>
        </p>
        <p id="sidebar-description" class="text-xs text-neutral-400 truncate"><%= user.description || 'Minecraft Host Client' %></p>
      </div>
    </a>
    <% } else { %>
    <a href="/login" class="sidebar-special-link flex items-center space-x-3.5 py-4 px-5 border-b border-white/5 shrink-0 hover:bg-white/[0.03] transition-colors group">
      <div class="h-9 w-9 rounded-xl border border-white/5 shrink-0 bg-neutral-800 flex items-center justify-center">
        <%- icon('user', { class: 'w-4 h-4 text-neutral-400' }) %>
      </div>
      <div class="min-w-0">
        <p class="text-sm font-semibold text-neutral-200 truncate">
          <span>Guest</span>
        </p>
        <p class="text-xs text-neutral-400 truncate">Please Sign In</p>
      </div>
    </a>
    <% } %>

    <!-- Scrollable nav -->
    <nav class="flex-1 overflow-y-auto">
      <ul role="list" class="py-3 px-3 space-y-1">
        <%
        const sidebarItems = regularMenuItems || (global.uiComponentStore ? global.uiComponentStore.getSidebarItems(undefined, false) : []);
        if (!sidebarItems || sidebarItems.length === 0) {
        %>
          <li class="nav-item">
            <a href="/dashboard" class="nav-link text-neutral-400 hover:text-white px-4 py-2 flex items-center gap-3 rounded-xl text-sm font-medium transition-all duration-200" data-search="container instances servers">
              <%- icon('layout-dashboard', { class: 'w-4 h-4 text-neutral-400 shrink-0' }) %>
              <span>Servers</span>
            </a>
          </li>
        <% } else {
          sidebarItems.forEach(item => {
            const isDashboard = item.url === '/' || item.url === '/dashboard';
            const finalUrl = isDashboard ? '/dashboard' : item.url;
        %>
          <li class="nav-item">
            <a href="<%= finalUrl %>" class="nav-link text-neutral-400 hover:text-white px-4 py-2 flex items-center gap-3 rounded-xl text-sm font-medium transition-all duration-200"<% if (item.matchPrefix) { %> data-match-prefix="<%= item.matchPrefix %>"<% } %>>
              <%- item.icon %>
              <span><%= item.label === 'Servers' ? 'Dashboard' : item.label %></span>
            </a>
          </li>
        <% }); } %>

        <% if (typeof user !== 'undefined' && user && user.isAdmin === true) { %>
          <div class="px-4 text-neutral-500 text-[10px] font-bold uppercase tracking-widest pt-6 pb-2">Admin Panel</div>
          <li>
            <a href="/admin/overview" searchdata="admin overview control" class="transition nav-link text-neutral-400 hover:text-white px-4 py-2 flex items-center gap-3 rounded-xl text-sm font-medium">
              <%- icon('layout-grid', { class: 'w-4 h-4', strokeWidth: 1.5 }) %>
              <span>Overview</span>
            </a>
          </li>
          <li>
            <a href="/admin/settings" class="transition nav-link text-neutral-400 hover:text-white px-4 py-2 flex items-center gap-3 rounded-xl text-sm font-medium">
              <%- icon('settings', { class: 'w-4 h-4', strokeWidth: 1.5 }) %>
              <span>Settings</span>
            </a>
          </li>
          <li>
            <a href="/admin/config" class="transition nav-link text-neutral-400 hover:text-white px-4 py-2 flex items-center gap-3 rounded-xl text-sm font-medium">
              <%- icon('sliders-horizontal', { class: 'w-4 h-4', strokeWidth: 1.5 }) %>
              <span>Configuration</span>
            </a>
          </li>
          <li>
            <a href="/admin/servers" class="transition nav-link text-neutral-400 hover:text-white px-4 py-2 flex items-center gap-3 rounded-xl text-sm font-medium">
              <%- icon('server', { class: 'w-4 h-4', strokeWidth: 1.5 }) %>
              <span>Servers</span>
            </a>
          </li>
          <li>
            <a href="/admin/users" class="transition nav-link text-neutral-400 hover:text-white px-4 py-2 flex items-center gap-3 rounded-xl text-sm font-medium">
              <%- icon('users', { class: 'w-4 h-4', strokeWidth: 1.5 }) %>
              <span>Users</span>
            </a>
          </li>
          <li>
            <a href="/admin/nodes" class="transition nav-link text-neutral-400 hover:text-white px-4 py-2 flex items-center gap-3 rounded-xl text-sm font-medium">
              <%- icon('network', { class: 'w-4 h-4', strokeWidth: 1.5 }) %>
              <span>Nodes</span>
            </a>
          </li>
          <li>
            <a href="/admin/images" class="transition nav-link text-neutral-400 hover:text-white px-4 py-2 flex items-center gap-3 rounded-xl text-sm font-medium">
              <%- icon('box', { class: 'w-4 h-4', strokeWidth: 1.5 }) %>
              <span>Images</span>
            </a>
          </li>
          <li>
            <a href="/admin/addons" class="transition nav-link text-neutral-400 hover:text-white px-4 py-2 flex items-center gap-3 rounded-xl text-sm font-medium">
              <%- icon('puzzle', { class: 'w-4 h-4', strokeWidth: 1.5 }) %>
              <span>Addons</span>
            </a>
          </li>
          <li>
            <a href="/admin/cynexgp-cloud" class="transition nav-link text-neutral-400 hover:text-white px-4 py-2 flex items-center gap-3 rounded-xl text-sm font-medium">
              <%- icon('cloud', { class: 'w-4 h-4', strokeWidth: 1.5 }) %>
              <span>CynexGP Cloud</span>
            </a>
          </li>
          <li>
            <a href="/admin/apikeys" class="transition nav-link text-neutral-400 hover:text-white px-4 py-2 flex items-center gap-3 rounded-xl text-sm font-medium">
              <%- icon('key', { class: 'w-4 h-4', strokeWidth: 1.5 }) %>
              <span>API Keys</span>
            </a>
          </li>
        <% } %>
      </ul>
    </nav>

    <!-- Static bottom: logout -->
    <div class="shrink-0 border-t border-white/5">
      <a href="/logout" id="sidebar-logout-link" class="sidebar-special-link group flex gap-3 pl-6 py-4 text-sm font-semibold leading-6 text-red-400 hover:bg-red-500/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-red-500 transition-colors duration-200">
        <%- icon('log-out', { class: 'w-4 h-4 mt-1 shrink-0 text-red-400', strokeWidth: 1.5 }) %>
        <span>Logout</span>
      </a>
    </div>

  </div>
</div>

<script nonce="<%- nonce %>">
(function () {
  var wsProtocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
  var ws = new WebSocket(wsProtocol + '//' + window.location.host + '/online-check');
  ws.addEventListener('error', function () {});

  function markSpecialLinks(path) {
    var account = document.getElementById('sidebar-account-link');
    var logout  = document.getElementById('sidebar-logout-link');
    if (account) {
      var onAccount = path === '/account' || path.startsWith('/account/');
      account.style.background = onAccount ? 'rgba(255,255,255,0.03)' : '';
      account.style.borderColor = onAccount ? 'rgba(34,197,94,0.1)' : '';
    }
    
    // Auto highlight active nav item
    var navLinks = document.querySelectorAll('.nav-link');
    navLinks.forEach(function(link) {
      var href = link.getAttribute('href');
      var isActive = false;
      if (href === '/dashboard' && (path === '/dashboard' || path === '/')) {
        isActive = true;
      } else if (href !== '/dashboard' && path.startsWith(href)) {
        isActive = true;
      }
      if (isActive) {
        link.classList.add('bg-white/5', 'text-white', 'border', 'border-white/5');
        link.classList.remove('text-neutral-400');
      } else {
        link.classList.remove('bg-white/5', 'text-white', 'border', 'border-white/5');
        link.classList.add('text-neutral-400');
      }
    });
  }

  document.addEventListener('DOMContentLoaded', function () {
    markSpecialLinks(window.location.pathname);
  });
  document.addEventListener('al:navigated', function () {
    markSpecialLinks(window.location.pathname);
  });
})();
</script>

<div id="colcont" class="lg:pl-56 bg-mono-bg min-h-screen text-white">
  <!-- Topbar Search -->
  <div class="fixed top-0 left-0 lg:left-56 right-0 z-40 flex h-16 shrink-0 items-center gap-x-4 bg-mono-bg/85 backdrop-blur-xl border-b border-white/5 px-6">
    <div class="flex flex-1 gap-x-4 self-stretch lg:gap-x-6">
      <div class="relative flex flex-1 flex-col justify-center">

        <div class="flex items-center w-full max-w-sm px-4 py-2 h-9 rounded-xl border border-white/5 bg-white/[0.02] duration-200 hover:border-white/15 focus-within:border-brand-green/20" role="search">
          <%- icon('search', { class: 'h-4 w-4 text-neutral-500' }) %>
          <input id="searchInput"
            class="bg-transparent border-transparent ml-2 w-full focus-visible:ring-transparent border-none ring-transparent text-sm placeholder:text-neutral-500 text-neutral-200 focus-visible:outline-none"
            placeholder="Search servers, nodes..."
            type="search"
            role="combobox"
            aria-autocomplete="list"
            aria-expanded="false"
            aria-controls="searchResults"
            aria-label="Search"
            name="search"
            autocomplete="off"
            onfocus="showSearchResults()">
          <div aria-hidden="true" class="ml-2 px-1.5 py-0.5 text-[9px] font-bold text-neutral-500 bg-white/5 rounded border border-white/5 shrink-0">
            CTRL + K
          </div>
        </div>

        <div id="searchResults" role="listbox" aria-label="Search results" class="absolute bg-[#0c0c14] w-[19.5rem] rounded-xl shadow-2xl hidden mt-14 px-2 pb-2 border border-white/5 z-50">
        </div>
      </div>

      <script nonce="<%- nonce %>">
        document.addEventListener('keydown', function(event) {
          if (event.ctrlKey && event.key === 'k') {
            event.preventDefault();
            document.getElementById('searchInput').focus();
          }
        });

        function showSearchResults() {
          document.getElementById('searchResults').classList.remove('hidden');
          document.getElementById('searchInput').setAttribute('aria-expanded', 'true');
        }

        document.getElementById('searchInput').addEventListener('focus', showSearchResults);

        document.addEventListener('click', function(event) {
          var searchInput = document.getElementById('searchInput');
          var searchResults = document.getElementById('searchResults');
          if (!searchInput.contains(event.target) && !searchResults.contains(event.target)) {
            searchResults.classList.add('hidden');
            searchInput.setAttribute('aria-expanded', 'false');
          }
        });
      </script>
      <script nonce="<%- nonce %>" src="/javascript/search.js"></script>
    </div>
  </div>
</div>
<script nonce="<%- nonce %>">
(function () {
  var ov = document.getElementById('pl-overlay');
  if (!ov) return;
  ov.style.left   = '224px';
  ov.style.top    = '64px';
  ov.style.right  = '0';
  ov.style.bottom = '0';
  ov.style.display = 'flex';
})();
</script>
