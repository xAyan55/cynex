<%
  const var_status = typeof status !== 'undefined' ? status : 'neutral';
  const var_label = typeof label !== 'undefined' ? label : '';
  const var_class = typeof class_name !== 'undefined' ? class_name : (typeof class !== 'undefined' ? class : '');

  let badgeClass = 'inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-semibold uppercase tracking-wider ';
  let dotClass = 'w-1.5 h-1.5 rounded-full ';

  if (var_status === 'online' || var_status === 'running' || var_status === 'success') {
    badgeClass += 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20';
    dotClass += 'bg-emerald-400 animate-pulse';
  } else if (var_status === 'starting' || var_status === 'warning') {
    badgeClass += 'bg-amber-500/10 text-amber-400 border border-amber-500/20';
    dotClass += 'bg-amber-400 animate-pulse';
  } else if (var_status === 'stopping') {
    badgeClass += 'bg-orange-500/10 text-orange-400 border border-orange-500/20';
    dotClass += 'bg-orange-400 animate-pulse';
  } else if (var_status === 'offline' || var_status === 'stopped' || var_status === 'suspended' || var_status === 'danger' || var_status === 'error') {
    badgeClass += 'bg-red-500/10 text-red-400 border border-red-500/20';
    dotClass += 'bg-red-500';
  } else if (var_status === 'info' || var_status === 'blue') {
    badgeClass += 'bg-blue-500/10 text-blue-400 border border-blue-500/20';
    dotClass += 'bg-blue-400';
  } else {
    badgeClass += 'bg-neutral-500/10 text-neutral-400 border border-neutral-500/20';
    dotClass += 'bg-neutral-400';
  }

  badgeClass += ' ' + var_class;
%>
<span class="<%= badgeClass %>">
  <span class="<%= dotClass %>"></span>
  <%- var_label %>
</span>
