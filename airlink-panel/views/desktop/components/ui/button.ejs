<%
  const var_variant = typeof variant !== 'undefined' ? variant : 'secondary';
  const var_label = typeof label !== 'undefined' ? label : '';
  const var_href = typeof href !== 'undefined' ? href : null;
  const var_class = typeof class_name !== 'undefined' ? class_name : (typeof locals.class !== 'undefined' ? locals.class : '');
  const var_id = typeof id !== 'undefined' ? id : '';
  const var_attrs = typeof attrs !== 'undefined' ? attrs : '';

  let btnClass = 'inline-flex items-center justify-center gap-2 rounded-xl font-medium transition-all duration-300 text-sm disabled:opacity-50 disabled:cursor-not-allowed ';
  if (var_variant === 'primary') {
    btnClass += 'bg-mono-accent text-black hover:bg-white hover:scale-[1.02] hover:shadow-[0_0_25px_var(--color-mono-focus)] active:scale-95 px-5 py-2.5';
  } else if (var_variant === 'secondary') {
    btnClass += 'bg-mono-muted border border-mono-border text-mono-text-primary hover:bg-white/10 hover:text-mono-text-primary px-5 py-2.5';
  } else if (var_variant === 'danger') {
    btnClass += 'bg-red-500/10 border border-red-500/20 text-red-400 hover:bg-red-500/20 hover:text-red-300 px-5 py-2.5';
  } else if (var_variant === 'outline') {
    btnClass += 'border border-mono-border text-mono-text-secondary hover:text-mono-text-primary px-5 py-2.5';
  } else if (var_variant === 'glow') {
    btnClass += 'bg-mono-accent/10 border border-mono-accent/20 text-mono-text-primary hover:bg-mono-accent hover:text-black hover:scale-[1.02] hover:shadow-[0_0_25px_var(--color-mono-focus)] active:scale-95 px-5 py-2.5';
  }
  btnClass += ' ' + var_class;
%>

<% if (var_href) { %>
  <a href="<%= var_href %>" <% if(var_id) { %>id="<%= var_id %>"<% } %> class="<%= btnClass %>" <%- var_attrs %>>
    <%- var_label %>
  </a>
<% } else { %>
  <button <% if(var_id) { %>id="<%= var_id %>"<% } %> class="<%= btnClass %>" <%- var_attrs %>>
    <%- var_label %>
  </button>
<% } %>
