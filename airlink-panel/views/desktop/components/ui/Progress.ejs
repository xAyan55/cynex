<%
  const var_value = typeof value !== 'undefined' ? Number(value) : 0;
  const var_label = typeof label !== 'undefined' ? label : '';
  const var_color = typeof color !== 'undefined' ? color : 'green';
  const var_class = typeof class_name !== 'undefined' ? class_name : (typeof class !== 'undefined' ? class : '');

  let trackColor = 'bg-white/5';
  let barColor = 'bg-brand-green shadow-[0_0_10px_rgba(34,197,94,0.3)]';
  if (var_color === 'purple') {
    barColor = 'bg-brand-purple shadow-[0_0_10px_rgba(139,92,246,0.3)]';
  } else if (var_color === 'blue') {
    barColor = 'bg-blue-500 shadow-[0_0_10px_rgba(59,130,246,0.3)]';
  }
%>
<div class="space-y-2 <%= var_class %>">
  <% if (var_label) { %>
    <div class="flex justify-between text-xs font-semibold text-neutral-400">
      <span><%- var_label %></span>
      <span class="text-neutral-200"><%= Math.round(var_value) %>%</span>
    </div>
  <% } %>
  <div class="w-full h-2 rounded-full <%= trackColor %> overflow-hidden">
    <div class="h-full rounded-full <%= barColor %> transition-all duration-500" style="width: <%= Math.min(100, Math.max(0, var_value)) %>%"></div>
  </div>
</div>
