generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ──────────────────────────────────────────
// Enums
// ──────────────────────────────────────────

enum AllocationType {
  RAM
  CPU
  DISK
  BACKUP_SLOTS
  DATABASE_SLOTS
  PORTS
  SERVER_SLOTS
}

enum InstanceType {
  MINECRAFT
  LXC
}

enum AllocationSource {
  DEFAULT
  PURCHASE
  COUPON
  ADMIN_ADJUSTMENT
}

enum WalletTransactionType {
  PURCHASE
  ADMIN_ADJUSTMENT
  COUPON
  REWARD
  REFUND
  RENEWAL
  STORE_PURCHASE
}

enum ActionType {
  ADD_COINS
  ADD_RAM
  ADD_CPU
  ADD_DISK
  ADD_BACKUP_SLOTS
  ADD_SERVER_SLOTS
  ADD_PORTS
  ADD_DATABASES
  SERVER_UPGRADE
  SERVER_RENEW
}

enum ConfigCategory {
  ECONOMY
  STORE
  DEFAULTS
  RENEWALS
  LIMITS
  UI
  NOTIFICATIONS
  MONETIZATION
}

// ──────────────────────────────────────────
// Existing models (minimal changes)
// ──────────────────────────────────────────

model Users {
  id            Int              @id @default(autoincrement())
  email         String           @unique
  username      String?          @unique
  password      String
  isAdmin       Boolean          @default(false)
  description   String?          @default("No About Me")
  avatar        String?
  permissions   String?          @default("[]")
  loginAttempts Int              @default(0)
  lockedUntil   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  wallet              Wallet?
  allocations         UserAllocation[]
  storePurchases      StorePurchase[]
  couponRedemptions   CouponRedemption[]
  auditLogsAsUser     AuditLog[]     @relation("AuditLogUser")
  auditLogsAsAdmin    AuditLog[]     @relation("AuditLogAdmin")
  walletTransactions  WalletTransaction[]  @relation("WalletTransactionAdmin")
  servers             Server[]
  folders             ServerFolder[]
  apiKeys             ApiKey[]
  loginHistory        LoginHistory[]
  notifications       Notification[]
  earnSessions        EarnSession[]        @relation("UserEarnSessions")
  afkSessions         AfkSession[]         @relation("UserAfkSessions")
  streak              UserStreak?          @relation("UserStreakRelation")
  fraudLogs           MonetizationFraudLog[] @relation("UserFraudLogs")
  earnPrefs           UserEarnPreferences?  @relation("UserEarnPrefs")
}

model Session {
  id         String   @id @default(cuid())
  session_id String   @unique
  data       String
  expires    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Server {
  id               Int                @id @default(autoincrement())
  UUID             String             @unique @default(uuid())
  name             String
  description      String?
  createdAt        DateTime           @default(now())
  expiresAt        DateTime?
  Ports            String
  Memory           Int
  Cpu              Int
  Storage          Int
  Variables        String?
  StartCommand     String?
  dockerImage      String?
  sftpCredential   SftpCredential?
  allowStartupEdit Boolean            @default(false)
  Installing       Boolean            @default(true)
  Queued           Boolean            @default(true)
  Suspended        Boolean            @default(false)
  version          Int                @default(0)
  ownerId          Int
  nodeId           Int
  imageId          Int
  instanceType     InstanceType       @default(MINECRAFT)
  swap             Int?
  bandwidth        Int?
  ipv4             String?
  ipv6             String?
  osTemplate       String?
  rootPassword     String?

  node             Node               @relation(fields: [nodeId], references: [id])
  owner            Users              @relation(fields: [ownerId], references: [id])
  image            Images             @relation(fields: [imageId], references: [id])
  backups          Backup[]
  folder           ServerFolderMember?
}

model Images {
  id              Int      @id @default(autoincrement())
  UUID            String   @unique @default(uuid())
  name            String?
  description     String?
  author          String?
  authorName      String?
  createdAt       DateTime @default(now())
  meta            String?
  dockerImages    String?
  startup         String?
  stop            String?
  startup_done    String?
  config_files    String?
  info            String?
  scripts         String?
  variables       String?
  portRequirements String  @default("[]")

  servers         Server[]
}

model Node {
  id             Int      @id @default(autoincrement())
  name           String
  ram            Int      @default(0)
  cpu            Int      @default(0)
  disk           Int      @default(0)
  address        String   @default("127.0.0.1")
  port           Int      @default(3001)
  key            String
  createdAt      DateTime @default(now())
  allocatedPorts String?  @default("[]")
  sftpPort       Int      @default(3003)
  servers        Server[]
  storagePools   StoragePool[]
  networkPools   NetworkPool[]
  capability     NodeCapability?
}

model settings {
  id                        Int      @id @default(autoincrement())
  title                     String   @default("Airlink")
  description               String   @default("AirLink is a free and open source project by AirlinkLabs")
  logo                      String   @default("../assets/logo.png")
  favicon                   String   @default("../assets/favicon.ico")
  theme                     String   @default("default")
  lightTheme                String   @default("default")
  darkTheme                 String   @default("default")
  language                  String   @default("en")
  allowRegistration         Boolean  @default(false)
  uploadLimit               Int      @default(100)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  sftpPort                  Int      @default(3003)
  virusTotalApiKey          String?
  rateLimitEnabled          Boolean  @default(true)
  rateLimitRpm              Int      @default(100)
  bannedIps                 String   @default("[]")
  allowUserCreateServer     Boolean  @default(false)
  allowUserDeleteServer     Boolean  @default(false)
  loginWallpaper            String?
  registerWallpaper         String?
  loginMaxAttempts          Int      @default(5)
  loginLockoutMinutes       Int      @default(15)
  enforceDaemonHttps        Boolean  @default(false)
  behindReverseProxy        Boolean  @default(false)
  hashApiKeys               Boolean  @default(false)
  airlinkCloudApiKey        String?
  airlinkCloudBackupEnabled Boolean  @default(false)
  defaultServerLimit        Int      @default(0)
  defaultMaxMemory          Int      @default(512)
  defaultMaxCpu             Int      @default(100)
  defaultMaxStorage         Int      @default(5120)
}

model ServerFolder {
  id        Int                  @id @default(autoincrement())
  name      String
  ownerId   Int
  createdAt DateTime             @default(now())
  owner     Users                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members   ServerFolderMember[]

  @@index([ownerId])
}

model ServerFolderMember {
  id         Int          @id @default(autoincrement())
  folderId   Int
  serverUUID String       @unique
  folder     ServerFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  server     Server       @relation(fields: [serverUUID], references: [UUID], onDelete: Cascade)
}

model ApiKey {
  id          Int      @id @default(autoincrement())
  name        String
  key         String   @unique
  description String?
  permissions String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  active      Boolean  @default(true)
  userId      Int?
  user        Users?   @relation(fields: [userId], references: [id])
}

model LoginHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      Users    @relation(fields: [userId], references: [id])
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())
}

model PlayerStats {
  id           Int      @id @default(autoincrement())
  timestamp    DateTime @default(now())
  totalPlayers Int      @default(0)
  maxPlayers   Int      @default(0)
  onlineServers Int     @default(0)
  totalServers  Int     @default(0)

  @@index([timestamp])
}

model Addon {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?
  version     String
  author      String?
  enabled     Boolean  @default(true)
  mainFile    String   @default("index.ts")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AddonSetting {
  id        Int      @id @default(autoincrement())
  addonSlug String
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([addonSlug, key])
}

model Backup {
  id            Int      @id @default(autoincrement())
  UUID          String   @unique @default(uuid())
  name          String
  serverId      String
  filePath      String
  size          BigInt?
  createdAt     DateTime @default(now())
  server        Server   @relation(fields: [serverId], references: [UUID], onDelete: Cascade)
  airlinkCloudId String?

  @@index([serverId])
  @@index([createdAt])
}

model SftpCredential {
  id        Int      @id @default(autoincrement())
  serverId  String   @unique
  username  String
  password  String
  host      String
  port      Int
  expiresAt DateTime?
  createdAt DateTime @default(now())
  server    Server   @relation(fields: [serverId], references: [UUID], onDelete: Cascade)
}

// ──────────────────────────────────────────
// New Economy Models
// ──────────────────────────────────────────

/// Wallet is a cached balance. WalletTransaction is the immutable ledger.
/// Both are updated atomically inside the same Prisma transaction.
model Wallet {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  balance   Int      @default(0)
  version   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         Users                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

/// Immutable ledger — every balance change creates one record.
model WalletTransaction {
  id          Int                   @id @default(autoincrement())
  walletId    Int
  amount      Int
  type        WalletTransactionType
  reason      String
  referenceId String?
  adminId     Int?
  createdAt   DateTime              @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  admin  Users? @relation("WalletTransactionAdmin", fields: [adminId], references: [id])
}

/// Each record represents a resource grant (default, purchase, coupon, admin adjustment).
/// Allocated = SUM(amount) where source != DEFAULT + defaults from config.
/// Used = SUM(server.Memory/Cpu/Storage) for active servers.
/// Available = Allocated - Used.
model UserAllocation {
  id          Int              @id @default(autoincrement())
  userId      Int
  type        AllocationType
  amount      Int
  source      AllocationSource
  referenceId String?
  createdAt   DateTime         @default(now())

  user Users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

/// Data-driven store products. Future products require only a DB row + reward handler.
model StoreProduct {
  id                 Int        @id @default(autoincrement())
  name               String
  description        String?
  actionType         ActionType
  actionValue        Int
  price              Int
  icon               String?
  featured           Boolean    @default(false)
  hidden             Boolean    @default(false)
  maxPurchasePerUser Int?
  displayOrder       Int        @default(0)
  enabled            Boolean    @default(true)
  createdAt          DateTime   @default(now())

  purchases StorePurchase[]
}

model StorePurchase {
  id          Int        @id @default(autoincrement())
  userId      Int
  productId   Int?
  serverId    String?
  actionType  ActionType
  actionValue Int
  coinCost    Int
  createdAt   DateTime   @default(now())

  product StoreProduct? @relation(fields: [productId], references: [id])
  user    Users         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Coupons support scheduled promotions via startsAt/expiresAt.
/// Redeeming dispatches through the same RewardPipeline as Store purchases.
model Coupon {
  id            Int              @id @default(autoincrement())
  code          String           @unique
  description   String?
  actionType    ActionType
  actionValue   Int
  maxUses       Int              @default(0)
  perUserLimit  Int              @default(1)
  startsAt      DateTime?
  expiresAt     DateTime?
  enabled       Boolean          @default(true)
  createdAt     DateTime         @default(now())

  redemptions CouponRedemption[]
}

model CouponRedemption {
  id        Int      @id @default(autoincrement())
  couponId  Int
  userId    Int
  createdAt DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   Users  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([couponId, userId])
}

/// Typed, grouped configuration. ConfigService exposes typed accessors (no magic strings).
model Config {
  id          Int            @id @default(autoincrement())
  category    ConfigCategory
  key         String
  value       Json
  description String?

  @@unique([category, key])
}

/// Immutable audit trail. Every important action logs before/after state.
model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int?
  adminId     Int?
  action      String
  details     Json?
  referenceId String?
  ipAddress   String?
  createdAt   DateTime @default(now())

  user  Users? @relation("AuditLogUser", fields: [userId], references: [id])
  admin Users? @relation("AuditLogAdmin", fields: [adminId], references: [id])

  @@index([createdAt])
  @@index([action])
  @@index([userId])
}

/// Notifications for user events (purchases, renewals, expiry, etc.)
model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int
  type        String
  title       String
  message     String
  referenceId String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  user Users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

/// Future-proof plan model — enables plan-based server creation and upgrades.
model Plan {
  id          Int      @id @default(autoincrement())
  name        String
  memory      Int
  cpu         Int
  disk        Int
  backupSlots Int      @default(0)
  ports       Int      @default(0)
  price       Int
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

// ──────────────────────────────────────────
// Monetization Enums
// ──────────────────────────────────────────

enum ProviderType {
  LINKVERTISE
  ADSTERRA
  LOOTLABS
  CUSTOM
}

enum EarnType {
  OFFER
  AFK
  STREAK
  CUSTOM
  SURVEY
  ADS
}

enum EarnStatus {
  PENDING
  COMPLETED
  FAILED
  EXPIRED
}

enum RewardType {
  COINS
  RAM
  CPU
  DISK
  BACKUPS
  SERVER_SLOT
  CUSTOM
}

enum FraudSeverity {
  LOW
  MEDIUM
  HIGH
}

enum FraudStatus {
  FLAGGED
  RESOLVED
  DISMISSED
}

enum SessionStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

enum ProviderHealthStatus {
  HEALTHY
  DEGRADED
  OFFLINE
  UNKNOWN
}

// ──────────────────────────────────────────
// Monetization Models
// ──────────────────────────────────────────

model Offer {
  id                 Int           @id @default(autoincrement())
  name               String
  type               EarnType      @default(OFFER)
  provider           ProviderType
  targetUrl          String
  enabled            Boolean       @default(true)
  dailyLimit         Int           @default(0)     // 0 = unlimited
  cooldown           Int           @default(0)     // In seconds
  sortOrder          Int           @default(0)
  icon               String?
  description        String?
  
  // Custom Offer Conditions (Stored as JSON for dynamic evaluator scalability)
  // Example: {"minimumServers": 2, "emailVerified": true, "country": ["IN", "US"]}
  conditions         Json

  // Expiration, Scheduling & Categorization
  priority           Int           @default(0)
  category           String?
  tags               String        @default("[]")  // JSON array string
  startsAt           DateTime?
  expiresAt          DateTime?

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  rewards            OfferReward[] @relation("OfferRewards")
  sessions           EarnSession[] @relation("OfferSessions")
}

model OfferReward {
  id          Int        @id @default(autoincrement())
  offerId     Int
  rewardType  RewardType
  amount      Int

  offer       Offer      @relation("OfferRewards", fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId])
}

model EarnSession {
  id            Int           @id @default(autoincrement())
  userId        Int
  type          EarnType
  status        EarnStatus    @default(PENDING)
  provider      ProviderType?
  offerId       Int?
  token         String        @unique // HMAC security token
  coinsAwarded  Int           @default(0)
  
  // Client Metadata (Normalized JSON columns)
  ipAddress     String?
  browser       String?
  userAgent     String?
  country       String?
  fingerprint   String?
  metadata      Json
  
  // Callback Protection Fields
  nonce         String        @unique
  expiresAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime      @default(now())

  user  Users  @relation("UserEarnSessions", fields: [userId], references: [id], onDelete: Cascade)
  offer Offer? @relation("OfferSessions", fields: [offerId], references: [id], onDelete: SetNull)

  @@index([userId, type])
  @@index([token])
  @@index([createdAt])
}

model AfkSession {
  id            Int           @id @default(autoincrement())
  userId        Int
  startedAt     DateTime      @default(now())
  endedAt       DateTime?
  lastHeartbeat DateTime      @default(now())
  totalMinutes  Int           @default(0)
  coinsEarned   Int           @default(0)
  status        SessionStatus @default(ACTIVE)
  
  ipAddress     String?
  userAgent     String?
  fingerprint   String?
  createdAt     DateTime      @default(now())

  user Users @relation("UserAfkSessions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([createdAt])
}

model UserStreak {
  id            Int       @id @default(autoincrement())
  userId        Int       @unique
  currentStreak Int       @default(0)
  bestStreak    Int       @default(0)
  lastClaimDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user Users @relation("UserStreakRelation", fields: [userId], references: [id], onDelete: Cascade)
}

model MonetizationFraudLog {
  id          Int           @id @default(autoincrement())
  userId      Int
  type        String        // "velocity" | "multi_account" | "vpn" | "country_mismatch" | "anomaly"
  severity    FraudSeverity
  details     Json
  ipAddress   String?
  fingerprint String?
  status      FraudStatus   @default(FLAGGED)
  createdAt   DateTime      @default(now())

  user Users @relation("UserFraudLogs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model ProviderHealthRecord {
  id            Int                  @id @default(autoincrement())
  provider      ProviderType
  status        ProviderHealthStatus @default(UNKNOWN)
  responseTime  Int                  // In ms
  lastSuccess   DateTime?
  lastFailure   DateTime?
  errorMessage  String?
  createdAt     DateTime             @default(now())

  @@index([provider, createdAt])
}

model MonetizationSchedulerJob {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  cron        String
  enabled     Boolean   @default(true)
  lastRun     DateTime?
  nextRun     DateTime?
  maxRetries  Int       @default(3)
  backoff     Int       @default(300) // In seconds
  timeout     Int       @default(60)  // In seconds
  lastError   String?
  duration    Int       @default(0)   // Elapsed milliseconds
  lockedBy    String?   // Process ID or worker key
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model UserEarnPreferences {
  id                 Int     @id @default(autoincrement())
  userId             Int     @unique
  afkNotifications   Boolean @default(true)
  rewardNotifications Boolean @default(true)
  streakNotifications Boolean @default(true)
  offerNotifications Boolean @default(true)

  user Users @relation("UserEarnPrefs", fields: [userId], references: [id], onDelete: Cascade)
}

model ResourceProfile {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  memory      Int      // RAM in MB
  cpu         Int      // CPU limit in percent or cores
  storage     Int      // Storage in MB
  swap        Int      @default(0) // Swap in MB
  bandwidth   Int      @default(0) // Bandwidth limit in MB/s or total monthly cap
}

model ImageRegistry {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  distribution String
  release      String
  architecture String   @default("amd64")
  cloudImage   Boolean  @default(false)
  url          String
  checksum     String?
  minDisk      Int      @default(0) // in MB
  minRam       Int      @default(0) // in MB
  enabled      Boolean  @default(true)
  deprecated   Boolean  @default(false)
}

model StoragePool {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  driver      String   // e.g. "zfs", "btrfs", "dir", "lvm"
  source      String   // Path or ZFS pool name
  capacity    Int      // Total capacity in MB
  nodeId      Int
  node        Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
}

model NetworkPool {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  subnet      String   // e.g. "10.0.0.0/24"
  gateway     String?
  bridge      String   @default("lxdbr0")
  type        String   // "NAT", "bridged", "routed", "isolated"
  ips         String   // JSON array of available / allocated IPs
  nodeId      Int
  node        Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
}

model OperationQueue {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid())
  action      String   // e.g., "DEPLOY", "DELETE", "REINSTALL", "SNAPSHOT", "BACKUP"
  status      String   // "QUEUED", "RUNNING", "COMPLETED", "FAILED", "CANCELLED"
  payload     String   // JSON string of request parameters
  result      String?  // JSON string of result/error details
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  serverUUID  String
}

model NodeCapability {
  id              Int      @id @default(autoincrement())
  nodeId          Int      @unique
  node            Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  dockerInstalled Boolean  @default(false)
  dockerVersion   String?
  lxcInstalled    Boolean  @default(false)
  lxcVersion      String?
  lxdVersion      String?
  cgroupVersion   String?
  storageDriver   String?
  features        String   @default("[]") // JSON string of feature flags
}


